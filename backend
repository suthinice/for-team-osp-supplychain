 * แก้ไข: นับ Truck Type ให้ครอบคลุมทุกรูปแบบ
 */
function getDashboardData(serviceFilter, startDate, endDate) {
  try {
    const tz = getTz();
    const today = new Date();
    const todayKey = Utilities.formatDate(today, tz, 'yyyy-MM-dd');
    
    // ตัวแปรเก็บข้อมูล
    let totalCount = 0;
    let receiveCount = 0;
    let sendCount = 0;
    
    // Status วันนี้
    let todayTotal = 0;
    let todayWaiting = 0;
    let todayProgress = 0;
    let todayCompleted = 0;
    
    // ✅ Truck Types (นับจากทุกรายการ ไม่ใช่แค่วันนี้)
    let truck4w = 0;
    let truck6w = 0;
    let truck10w = 0;
    let truck22w = 0;
    
    // ✅ เพิ่มตัวแปร vendor pallets
    let vendorPallets = {
      'DHL': 0,
      'TNV': 0,
      'เก้าเลี้ยว': 0,
      'TRL': 0,
      'ลูกค้ารับเอง': 0
    };
    
    // กำหนด Service Types
    const serviceTypes = (serviceFilter === 'ALL') 
      ? ['AY', 'RJ', 'AY_EXPORT', 'AY_OEM', 'AY_FOC']
      : [serviceFilter];
    
    // Loop ดึงข้อมูล
    serviceTypes.forEach(sType => {
      const ssId = SS_CONFIG[sType];
      if (!ssId) return;
      
      const ss = SpreadsheetApp.openById(ssId);
      const sheet = ss.getSheetByName(SHEET_NAME) || ss.getSheets()[0];
      if (!sheet) return;
      
      const lastRow = sheet.getLastRow();
      if (lastRow < 2) return;
      
      // อ่านข้อมูล
      const data = sheet.getRange(2, 1, lastRow - 1, 22).getValues();
      
      // Column indexes
      const colJobStatus = 1;   // B: สถานะงาน
      const colTruckType = 3;   // D: ประเภทรถ
      const colDate = 4;        // E: วันที่จอง
      const colVendor = 5;         // F: ผู้ขนส่ง ✅ แก้จาก 14 เป็น 5
      const colPallets = 10;       // K: จำนวน Pallet ✅ แก้จาก 9 เป็น 10
      const colTimestampReg = 18; // S: TimeStamp_Register
      const colStatus = 19;     // T: Status_Transport
      
      for (let i = 0; i < data.length; i++) {
        const row = data[i];
        
        // กรองตามวันที่
        const bookingDate = row[colDate];
        let bookingDateKey = '';
        
        if (bookingDate instanceof Date) {
          bookingDateKey = Utilities.formatDate(bookingDate, tz, 'yyyy-MM-dd');
        } else if (bookingDate) {
          try {
            const tempDate = new Date(bookingDate);
            bookingDateKey = Utilities.formatDate(tempDate, tz, 'yyyy-MM-dd');
          } catch (e) {
            continue;
          }
        }
        
        // ตรวจสอบช่วงวันที่
        if (startDate && endDate) {
          if (bookingDateKey < startDate || bookingDateKey > endDate) {
            continue;
          }
        }
        
        // นับ Total
        totalCount++;
        
        // นับ Receive/Send
        const jobStatus = String(row[colJobStatus] || '').toLowerCase();
        if (jobStatus.includes('นำเข้า') || jobStatus.includes('รับ')) {
          receiveCount++;
        } else if (jobStatus.includes('ส่งออก') || jobStatus.includes('ส่ง')) {
          sendCount++;
        }
        
        // ✅ นับ Truck Types (ครอบคลุมทุกรูปแบบ)
        const truckType = String(row[colTruckType] || '').trim();
        
        // แสดง Log เพื่อดูว่าข้อมูลเป็นอะไร
        if (i < 5) { // แสดงแค่ 5 แถวแรก
          Logger.log('Row ' + (i+2) + ' Truck Type: "' + truckType + '"');
        }
        
        // นับ Truck Type
        if (truckType.match(/4\s*[wWล้อ]/i) || truckType === '4W' || truckType === '4w') {
          truck4w++;
        } else if (truckType.match(/6\s*[wWล้อ]/i) || truckType === '6W' || truckType === '6w') {
          truck6w++;
        } else if (truckType.match(/10\s*[wWล้อ]/i) || truckType === '10W' || truckType === '10w') {
          truck10w++;
        } else if (truckType.match(/22\s*[wWล้อ]/i) || truckType === '22W' || truckType === '22w' || 
                   truckType.includes('หัวลาก') || truckType.includes('เทรลเลอร์') || 
                   truckType.includes('trailer')) {
          truck22w++;
        }

        // ✅ นับ Pallet ต่อ Vendor
        const vendor = String(row[colVendor] || '').trim();
        const pallets = Number(row[colPallets] || 0);
        
        if (vendor && vendorPallets.hasOwnProperty(vendor)) {
          vendorPallets[vendor] += pallets;
        }
        
        // นับ Status วันนี้
        if (bookingDateKey === todayKey) {
          todayTotal++;
          
          if (row[colTimestampReg]) {
            const status = String(row[colStatus] || '').trim();
            
            if (status === 'In Progress' || status === 'กำลังดำเนินการ') {
              todayProgress++;
            } else if (status === 'Completed' || status === 'เสร็จสิ้น') {
              todayCompleted++;
            }
          } else {
            todayWaiting++;
          }
        }
      }
    });
    
    // ✅ คำนวณ % Receive / Send
    const receivePercent = totalCount > 0 ? Math.round((receiveCount / totalCount) * 100) : 0;
    const sendPercent = totalCount > 0 ? Math.round((sendCount / totalCount) * 100) : 0;

    // ✅ Log เพื่อตรวจสอบ
    Logger.log('=== Dashboard Data ===');
    Logger.log('Total Count: ' + totalCount);
    Logger.log('Today Total: ' + todayTotal);
    Logger.log('Today Waiting: ' + todayWaiting);
    Logger.log('Today Progress: ' + todayProgress);
    Logger.log('Today Completed: ' + todayCompleted);
    Logger.log('Truck 4W: ' + truck4w);
    Logger.log('Truck 6W: ' + truck6w);
    Logger.log('Truck 10W: ' + truck10w);
    Logger.log('Truck 22W: ' + truck22w);
    Logger.log('Truck Total: ' + (truck4w + truck6w + truck10w + truck22w));
    
    return {
      success: true,
      
      // Overview
      total: totalCount,
      receive: receiveCount,
      receivePercent: receivePercent,
      send: sendCount,
      sendPercent: sendPercent,
      
      // Today Status
      todayTotal: todayTotal,
      todayWaiting: todayWaiting,
      todayProgress: todayProgress,
      todayCompleted: todayCompleted,
      
      // Truck Types
      truck4w: truck4w,
      truck6w: truck6w,
      truck10w: truck10w,
      truck22w: truck22w,

      // ✅ เพิ่ม Vendor Pallets
      vendorPallets: vendorPallets
    };
    
  } catch (error) {
    Logger.log('❌ Error: ' + error.message);
    return {
      success: false,
      message: 'เกิดข้อผิดพลาด: ' + error.toString()
    };
  }
}

