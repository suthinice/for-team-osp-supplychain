function getExportData(serviceFilter, startDate, endDate) {
  try {
    const tz = getTz();
    const serviceTypes = serviceFilter === 'ALL'
      ? ['AY', 'RJ', 'AY_EXPORT', 'AY_OEM', 'AY_FOC']
      : [serviceFilter];

    const result = [];

    serviceTypes.forEach(sType => {
      const ssId = SS_CONFIG[sType];
      if (!ssId) return;

      const ss = SpreadsheetApp.openById(ssId);
      const sheet = ss.getSheetByName(SHEET_NAME) || ss.getSheets()[0];
      if (!sheet) return;

      const lastRow = sheet.getLastRow();
      if (lastRow < 2) return;

      const data = sheet.getRange(2, 1, lastRow - 1, 24).getValues();

      data.forEach(row => {
        const cellDate = row[4];
        let dateKey = '';

        if (cellDate instanceof Date) {
          dateKey = Utilities.formatDate(cellDate, tz, 'yyyy-MM-dd');
        } else if (cellDate) {
          try {
            const parts = String(cellDate).split('/');
            if (parts.length === 3) {
              const month = parts[0].padStart(2, '0');
              const day = parts[1].padStart(2, '0');
              const year = parts[2];
              const parsed = new Date(`${year}-${month}-${day}`);
              dateKey = Utilities.formatDate(parsed, tz, 'yyyy-MM-dd');
            } else {
              dateKey = Utilities.formatDate(new Date(cellDate), tz, 'yyyy-MM-dd');
            }
          } catch(e) {}
        }

        if (!dateKey || dateKey < startDate || dateKey > endDate) return;

        // ✅ แปลง DateTime เป็น String ก่อนส่ง (ลดขนาดข้อมูล)
        const formatDT = (val) => {
          if (!val) return '';
          if (val instanceof Date) return Utilities.formatDate(val, tz, 'dd/MM/yyyy HH:mm');
          return String(val);
        };

        result.push({
          date: dateKey,
          serviceType: sType,
          status: String(row[1] || ''),
          shipment: String(row[2] || ''),
          truckType: String(row[3] || ''),
          vendor: String(row[5] || ''),
          time: String(row[6] || ''),
          phone: String(row[9] || ''),
          pallets: Number(row[10] || 0),
          bookDateTime: formatDT(row[11]),       // ✅ แปลงเป็น String
          truckNo: String(row[12] || ''),
          trailerNo: String(row[13] || ''),
          customerName: String(row[15] || ''),
          registerDateTime: formatDT(row[18]),   // ✅ แปลงเป็น String
          confirmDateTime: formatDT(row[20]),    // ✅ แปลงเป็น String
          statusTransport: String(row[22] || ''),
          loadingDateTime: formatDT(row[23]),    // ✅ X: TimeStamp_Loading
          remark: String(row[0] || '')
        });
      });
    });

    Logger.log('✅ getExportData result count: ' + result.length);
    return { success: true, data: result };

  } catch (e) {
    Logger.log('❌ getExportData error: ' + e.message);
    return { success: false, message: e.message };
  }
}

