function updateDataBooking() {
  try {
    const tz = getTz();
    const ss = SpreadsheetApp.openById(DATA_BOOKING_SS_ID);

    // ✅ หา Sheet DataBooking หรือสร้างใหม่
    let sheet = ss.getSheetByName(DATA_BOOKING_SHEET_NAME);
    if (!sheet) {
      sheet = ss.insertSheet(DATA_BOOKING_SHEET_NAME);
    } else {
      sheet.clearContents();
    }

    // ✅ Headers เหมือนหน้า Export
    const headers = [
      'วันที่', 'Service', 'ช่วงเวลา', 'สถานะ', 'Shipment',
      'Pallet', 'ประเภทรถ', 'ทะเบียนรถ', 'ทะเบียนพ่วง', 'บริษัทขนส่ง',
      'เบอร์ติดต่อ', 'ชื่อลูกค้า', 'รายละเอียด',
      'BookDateTime', 'RegisterDateTime', 'ConfirmDateTime', 'Status ขนส่ง',
      'เบอร์คนขับ' // ✅ R เพิ่ม
    ];

    const allRows = [headers];

    // ✅ ดึงข้อมูลจาก AY และ RJ
    ['AY', 'RJ'].forEach(sType => {
      const ssId = SS_CONFIG[sType];
      if (!ssId) return;

      const sourceSS = SpreadsheetApp.openById(ssId);
      const sourceSheet = sourceSS.getSheetByName(SHEET_NAME) || sourceSS.getSheets()[0];
      if (!sourceSheet) return;

      const lastRow = sourceSheet.getLastRow();
      if (lastRow < 2) return;

      const data = sourceSheet.getRange(2, 1, lastRow - 1, 23).getValues();

      const formatDT = (val) => {
        if (!val) return '';
        if (val instanceof Date) return Utilities.formatDate(val, tz, 'dd/MM/yyyy HH:mm');
        return String(val);
      };

      data.forEach(row => {
        const cellDate = row[4];
        let dateKey = '';

        if (cellDate instanceof Date) {
          dateKey = Utilities.formatDate(cellDate, tz, 'yyyy-MM-dd');
        } else if (cellDate) {
          try {
            dateKey = Utilities.formatDate(new Date(cellDate), tz, 'yyyy-MM-dd');
          } catch(e) {}
        }

        if (!dateKey) return;

        allRows.push([
          dateKey,
          sType,
          String(row[6] || ''),       // G: ช่วงเวลา
          String(row[1] || ''),       // B: สถานะ
          "'" + String(row[2] || ''), // C: Shipment (force text)
          Number(row[10] || 0),       // K: Pallet
          String(row[3] || ''),       // D: ประเภทรถ
          String(row[12] || ''),      // M: ทะเบียนรถ
          (() => {
            const val = row[13];
            if (!val) return '';
            if (val instanceof Date) return Utilities.formatDate(val, tz, 'dd/MM/yyyy');
            return String(val);
          })(),                        // N: ทะเบียนพ่วง
          String(row[5] || ''),       // F: บริษัทขนส่ง
          String(row[9] || ''),       // J: เบอร์ติดต่อ
          String(row[15] || ''),      // P: ชื่อลูกค้า
          String(row[0] || ''),       // A: รายละเอียด
          formatDT(row[11]),          // L: BookDateTime
          formatDT(row[18]),          // S: RegisterDateTime
          formatDT(row[20]),          // U: ConfirmDateTime
          String(row[19] || ''),
          (() => {
            const val = row[9];
            if (!val || val === 0 || val === '0') return '';
            return "'" + String(val).replace(/\D/g, '');
          })()   // ✅ R: เบอร์คนขับ Column J
        ]);
      });

      Logger.log(`✅ ${sType}: ${data.length} rows`);
    });

    // ✅ เขียนข้อมูลทั้งหมด
    if (allRows.length > 1) {
      sheet.getRange(1, 1, allRows.length, headers.length).setValues(allRows);
    }

    // ✅ Format Header
    const headerRange = sheet.getRange(1, 1, 1, headers.length);
    headerRange.setBackground('#1e3a5f');
    headerRange.setFontColor('#ffffff');
    headerRange.setFontWeight('bold');
    headerRange.setHorizontalAlignment('center');
    sheet.setFrozenRows(1);

    // ✅ Format Shipment column เป็น Text
    sheet.getRange(2, 5, Math.max(allRows.length - 1, 1), 1).setNumberFormat('@');

    // ✅ Auto resize
    sheet.autoResizeColumns(1, headers.length);

    SpreadsheetApp.flush();
    Logger.log(`✅ DataBooking updated: ${allRows.length - 1} rows`);

    // ✅ Lookup ไปยัง Sheet SO อัตโนมัติ
    lookupDataBookingToSO();

    return { success: true, message: `อัปเดต DataBooking สำเร็จ ${allRows.length - 1} rows` };

  } catch(e) {
    Logger.log('❌ updateDataBooking error: ' + e.message);
    return { success: false, message: e.message };
  }
}

/**
 * ✅ Lookup DataBooking → Sheet SO
 * Key: SO Column BH (Shipment 7 หลัก) → DataBooking Column E (อาจมีหลายเลข)
 */
function lookupDataBookingToSO() {
  try {
    const tz = getTz();
    const ss = SpreadsheetApp.openById(DATA_BOOKING_SS_ID);

    // ✅ เปิด Sheet DataBooking
    const dbSheet = ss.getSheetByName(DATA_BOOKING_SHEET_NAME);
    if (!dbSheet) throw new Error('ไม่พบ Sheet DataBooking');

    const dbLastRow = dbSheet.getLastRow();
    if (dbLastRow < 2) {
      Logger.log('⚠️ DataBooking ไม่มีข้อมูล');
      return;
    }

    // ✅ อ่านข้อมูล DataBooking ที่ต้องการ
    const dbData = dbSheet.getRange(2, 1, dbLastRow - 1, 18).getValues();

    // ✅ สร้าง Map: shipmentNo (7 หลัก) → { colC, colO, colP, colH, colI }
    const shipmentMap = {};

    dbData.forEach(row => {
      const shipmentRaw = String(row[4] || '').replace(/^'/, '').trim(); // Column E
      if (!shipmentRaw) return;

      const formatVal = (val) => {
        if (!val) return '';
        if (val instanceof Date) return Utilities.formatDate(val, tz, 'dd/MM/yyyy HH:mm');
        return String(val);
      };

      const colA = (() => {
        const val = row[0];
        if (!val) return '';
        if (val instanceof Date) return Utilities.formatDate(val, tz, 'dd/MM/yyyy');
        return String(val);
      })();
      const colC = formatVal(row[2]);      // Column C
      const colH = String(row[7] || '');   // Column H
      const colI = String(row[8] || '');   // Column I
      const colO = formatVal(row[14]);     // Column O
      const colP = formatVal(row[15]);     // Column P
      const colQ = String(row[16] || '');  // Column Q ✅ เพิ่ม
      const colR = (() => {
        const val = String(row[17] || '').trim();
        if (!val || val === '0' || val === '000') return '';
        return "'" + val; // ✅ บังคับเป็น Text ไม่ให้ 0 หายไป
      })();

      // ✅ Split ด้วย , แล้ว Loop แต่ละเลข
      shipmentRaw.split(',').forEach(s => {
        const key = s.trim();
        if (key.length === 7) {
          shipmentMap[key] = { colA, colC, colO, colP, colH, colI, colQ, colR }; // ✅ เพิ่ม colR
        }
      });
    });

    Logger.log('✅ Shipment Map size: ' + Object.keys(shipmentMap).length);

    // ✅ เปิด Sheet SO
    const soSheet = ss.getSheetByName('SO');
    if (!soSheet) throw new Error('ไม่พบ Sheet SO');

    const soLastRow = soSheet.getLastRow();
    if (soLastRow < 2) {
      Logger.log('⚠️ Sheet SO ไม่มีข้อมูล');
      return;
    }

    const headers = [
      'BookingTime',    // BQ (69)
      'RegisterTime',   // BR (70)
      'ConfirmTime',    // BS (71)
      'TruckNo',        // BT (72)
