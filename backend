function uploadFilesToDrive(fileDataList, folderId) {
  try {
    const folder = DriveApp.getFolderById(folderId || UPLOAD_FOLDER_ID_CONFIG);
    const results = [];
    const errors = [];

    fileDataList.forEach(fileData => {
      try {
        const { fileName, mimeType, base64 } = fileData;

        // ✅ 1. ลบไฟล์เดิมใน Folder
        const existing = folder.getFilesByName(fileName);
        while (existing.hasNext()) {
          existing.next().setTrashed(true);
        }

        // ✅ 2. สร้างไฟล์ใหม่ชื่อเดิม
        const blob = Utilities.newBlob(
          Utilities.base64Decode(base64),
          mimeType,
          fileName
        );
        const newFile = folder.createFile(blob);
        Logger.log('✅ Uploaded: ' + fileName);

        // ✅ 3. คัดลอกข้อมูลเข้า Google Sheet (ถ้ามี config)
        const sheetConfig = UPLOAD_SHEET_CONFIG[fileName];
        if (sheetConfig?.ssId) {
          try {
            copyXlsxToSheet_(newFile, sheetConfig.ssId, sheetConfig.sheetName);
            Logger.log('✅ Copied to Sheet: ' + sheetConfig.sheetName);
            results.push(`${fileName} → Sheet ${sheetConfig.sheetName} ✅`);

            // ✅ ถ้า Upload SO หรือ DO → รัน updateDataBooking + lookupDataBookingToSO
            if (['ZSDR_SO', 'ZSDR_DO'].includes(fileName)) {
              try {
                updateDataBooking();
                Logger.log('✅ updateDataBooking TT เสร็จ');
              } catch(dbErr) {
                Logger.log('❌ updateDataBooking error: ' + dbErr.message);
              }
            }

            if (['ZSDRSO_MT', 'ZSDRDO_MT'].includes(fileName)) {
              try {
                // ✅ ไม่รันทันที แต่ตั้ง Trigger รันหลัง 2 นาทีแทน
                ScriptApp.newTrigger('updateDataBookingMT')
                  .timeBased()
                  .after(2 * 60 * 1000)
                  .create();
                Logger.log('✅ ตั้ง Trigger updateDataBookingMT เสร็จ');
              } catch(triggerErr) {
                Logger.log('❌ Trigger error: ' + triggerErr.message);
              }
            }

          } catch(copyErr) {
            Logger.log('❌ Copy error: ' + copyErr.message);
            errors.push(`${fileName} Upload สำเร็จแต่ Copy ไม่สำเร็จ: ${copyErr.message}`);
          }
        } else {
          results.push(`${fileName} ✅`);
        }

      } catch(fileErr) {
        Logger.log('❌ File error: ' + fileErr.message);
        errors.push(`${fileData.fileName}: ${fileErr.message}`);
      }
    });

    if (errors.length > 0) {
      return {
        success: false,
        message: `มีข้อผิดพลาด: ${errors.join(', ')}`
      };
    }

    return {
      success: true,
      message: `Upload สำเร็จ: ${results.join(', ')}`
    };

  } catch(e) {
    Logger.log('❌ uploadFilesToDrive error: ' + e.message);
    return {
      success: false,
      message: 'เกิดข้อผิดพลาด: ' + e.message
    };
  }
}

/**
 * ✅ อ่านข้อมูลจากไฟล์ xlsx ใน Drive แล้วคัดลอกเข้า Google Sheet
 */
function copyXlsxToSheet_(driveFile, targetSsId, targetSheetName) {
  // ✅ Copy ไฟล์ xlsx ไปที่ Root ก่อน แล้ว Convert เป็น Google Sheet
  const tempName = 'TEMP_IMPORT_' + new Date().getTime();
  
  // ✅ Copy ไฟล์ไปที่ Root Drive
  const tempFile = driveFile.makeCopy(tempName, DriveApp.getRootFolder());
  
  try {
    // ✅ Convert เป็น Google Sheet โดยใช้ Drive API v2
    const resource = {
      title: tempName,
      mimeType: 'application/vnd.google-apps.spreadsheet'
    };
    
    const convertedFile = Drive.Files.copy(resource, tempFile.getId(), { convert: true });
    
    try {
      // ✅ เปิด Converted Sheet
      const tempSS = SpreadsheetApp.openById(convertedFile.id);
      const tempSheet = tempSS.getSheets()[0];
      const lastRow = tempSheet.getLastRow();
      const lastCol = tempSheet.getLastColumn();

      if (lastRow === 0 || lastCol === 0) {
        throw new Error('ไฟล์ไม่มีข้อมูล');
      }

      const data = tempSheet.getRange(1, 1, lastRow, lastCol).getValues();

      // ✅ เปิด Target Sheet แล้วลบข้อมูลเดิม
      const targetSS = SpreadsheetApp.openById(targetSsId);
      let targetSheet = targetSS.getSheetByName(targetSheetName);

      if (!targetSheet) {
        targetSheet = targetSS.insertSheet(targetSheetName);
      } else {
        targetSheet.clearContents();
      }

      // ✅ วางข้อมูลทั้งหมด
      targetSheet.getRange(1, 1, data.length, data[0].length).setValues(data);
      SpreadsheetApp.flush();

      // ✅ Clean Sheet เฉพาะ SO เท่านั้น
      if (targetSheetName === 'SO') {
        cleanSheetData(targetSheet);
      }
      // ✅ DO ไม่ต้องทำ cleanSheetData

      Logger.log(`✅ Copied ${data.length} rows x ${data[0].length} cols to ${targetSheetName}`);

      // ✅ ถ้าเป็น Sheet SO → เขียนสูตรอัตโนมัติ
      if (targetSheetName === 'SO') {
        writeFormulasToSO(targetSsId, targetSheetName);
      }

    } finally {
      // ✅ ลบ Converted Temp File
      try { DriveApp.getFileById(convertedFile.id).setTrashed(true); } catch(e) {}
    }

  } finally {
    // ✅ ลบ Copied Temp File
    try { tempFile.setTrashed(true); } catch(e) {}
  }
}

