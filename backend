/**
 * ✅ ตรวจสอบว่า Code ซ้ำหรือไม่ (ในชีตเดียวกัน)
 */
function isCodeDuplicate(sheet, code) {
  const lastRow = sheet.getLastRow();
  if (lastRow < 2) return false;
  
  // Column R = index 18 (1-based) = 18
  const codes = sheet.getRange(2, 18, lastRow - 1, 1).getValues();
  
  return codes.some(row => String(row[0]).trim() === code);
}

/**
 * ✅ สร้าง Unique Code (ไม่ซ้ำในชีต)
 */
function calculateQueueNumber(sheet, bookingDate, currentRowIndex) {
  const tz = getTz();
  const targetDateKey = Utilities.formatDate(bookingDate, tz, "yyyy-MM-dd");
  const lastRow = sheet.getLastRow();

  if (lastRow < 2) return 1;

  // ✅ อ่านแค่ 2 Column ที่ใช้จริง
  const colE = sheet.getRange(2, 5, lastRow - 1, 1).getValues();  // Column E
  const colV = sheet.getRange(2, 22, lastRow - 1, 1).getValues(); // Column V

  let maxQueueToday = 0;
  let foundAnyInSameDate = false;

  for (let i = 0; i < colE.length; i++) {
    const rowNum = i + 2;
    if (rowNum === currentRowIndex) continue;

    const cellDate = colE[i][0];
    const queue = colV[i][0];

    if (!cellDate) continue;

    let rowDateKey = '';
    try {
      if (cellDate instanceof Date) {
        rowDateKey = Utilities.formatDate(cellDate, tz, "yyyy-MM-dd");
      } else {
        rowDateKey = Utilities.formatDate(new Date(cellDate), tz, "yyyy-MM-dd");
      }
    } catch(e) { continue; }

    if (rowDateKey === targetDateKey) {
      foundAnyInSameDate = true;
      const n = Number(queue);
      if (!isNaN(n) && n > maxQueueToday) {
        maxQueueToday = n;
      }
    }
  }

  if (!foundAnyInSameDate) return 1;

  const newQueue = maxQueueToday + 1;
  Logger.log('✅ Queue: ' + newQueue);
  return newQueue;
}

/**
 * ✅ ตรวจสอบรหัส 4 หลัก
 */
function verifyRegisterCode(code) {
  try {
    const tz = getTz();
    const today = new Date();
    const todayStr = Utilities.formatDate(today, tz, 'dd/MM/yyyy');
    const yesterday = new Date();
    yesterday.setDate(yesterday.getDate() - 1);
    const yesterdayStr = Utilities.formatDate(yesterday, tz, 'dd/MM/yyyy');

    const prefixMap = {
      '2': 'AY', '3': 'RJ', '4': 'AY_EXPORT',
      '5': 'AY_OEM', '6': 'AY_FOC'
    };

    const prefix = code.charAt(0);
    const serviceType = prefixMap[prefix];

    if (!serviceType) return { success: false, message: 'ไม่พบการจอง กรุณาตรวจสอบรหัสใหม่อีกครั้ง' };

    const ssId = SS_CONFIG[serviceType];
    if (!ssId) return { success: false, message: 'ไม่พบการจอง กรุณาตรวจสอบรหัสใหม่อีกครั้ง' };

    const ss = SpreadsheetApp.openById(ssId);
    const sheet = ss.getSheetByName(SHEET_NAME) || ss.getSheets()[0];
    if (!sheet) return { success: false, message: 'ไม่พบการจอง กรุณาตรวจสอบรหัสใหม่อีกครั้ง' };

    const data = sheet.getDataRange().getValues();

    const colDate        = 4;
    const colShipment    = 2;
    const colTruckNo     = 12;
    const colTruckType   = 3;
    const colDriverName  = 16;
    const colCode        = 17;
    const colTimeStampReg = 18;

    let foundRow = null;

    for (let i = 1; i < data.length; i++) {
      const row = data[i];
      const rowCode = String(row[colCode] || '').trim();

      if (rowCode !== code) continue;

      // ✅ เช็ควันที่
      const cellDate = row[colDate];
      let rowDateStr = '';

      if (cellDate instanceof Date) {
        rowDateStr = Utilities.formatDate(cellDate, tz, 'dd/MM/yyyy');
      } else {
        const parsed = parseDateString(String(cellDate));
        if (parsed) rowDateStr = Utilities.formatDate(parsed, tz, 'dd/MM/yyyy');
      }

      // ✅ ตรงกับวันนี้หรือเมื่อวาน → เก็บแล้วหยุด
      if (rowDateStr === todayStr || rowDateStr === yesterdayStr) {
        foundRow = { row, rowIndex: i + 1 };
        break;
      }
    }

    if (!foundRow) {
      return { success: false, message: 'ไม่พบการจอง กรุณาตรวจสอบรหัสใหม่อีกครั้ง' };
    }

    const { row, rowIndex } = foundRow;

    if (row[colTimeStampReg]) {
      return { success: false, message: 'รหัสนี้ลงทะเบียนแล้ว ไม่สามารถลงทะเบียนซ้ำได้' };
    }

    return {
      success: true,
      data: {
        serviceType,
        rowIndex,
        sheetId: ssId,
        driverName: String(row[colDriverName] || '-'),
        shipmentNo: String(row[colShipment] || '-'),
        truckNo: String(row[colTruckNo] || '-'),
        truckType: String(row[colTruckType] || '').trim(),
        code
      }
    };

  } catch (error) {
    return { success: false, message: 'เกิดข้อผิดพลาด: ' + (error.message || error.toString()) };
  }
}

/**
 * ✅ ลงทะเบียน Check-in (ใช้ Batch Update)
 */
function registerCheckIn(bookingData) {
  const lock = LockService.getScriptLock();
  
  try {
    lock.waitLock(30000);
    
    const tz = getTz();
    const ss = SpreadsheetApp.openById(bookingData.sheetId);
    const sheet = ss.getSheetByName(SHEET_NAME) || ss.getSheets()[0];
    
    if (!sheet) {
      lock.releaseLock();
      return { success: false, message: 'ไม่พบ Sheet' };
    }
    
    const rowIndex = bookingData.rowIndex;
    const now = new Date();
    
    Logger.log('=== Check-in Row ' + rowIndex + ' ===');
    
    // ดึงวันที่จอง
    const bookingDate = sheet.getRange(rowIndex, 5).getValue();
    
    if (!bookingDate) {
      lock.releaseLock();
      return { success: false, message: 'ไม่พบวันที่จอง' };
    }
    
    // เช็คว่า Check-in แล้วหรือยัง
    const existingTimestamp = sheet.getRange(rowIndex, 19).getValue();
    const existingQueue = sheet.getRange(rowIndex, 22).getValue();
    
    if (existingTimestamp && existingQueue) {
      lock.releaseLock();
      return {
        success: true,
        queueNumber: existingQueue,
        message: 'คุณ Check-in แล้ว คิวของคุณคือ: ' + existingQueue
      };
    }
    
    // คำนวณลำดับ
    const queueNumber = calculateQueueNumber(sheet, bookingDate, rowIndex);
    
    Logger.log('📝 อัปเดต Row ' + rowIndex + ' (Batch Update)');
    
    // ✅ อ่านแถวทั้งหมดก่อน
    const currentRow = sheet.getRange(rowIndex, 1, 1, 23).getValues()[0];
    Logger.log('📋 ค่าเดิม T (index 19): "' + currentRow[19] + '"');
    
    // ✅ อัปเดตค่าในแถว
    currentRow[18] = now;              // S (index 18)
    currentRow[19] = 'In Progress';    // T (index 19)
    currentRow[21] = queueNumber;      // V (index 21)
    currentRow[12] = bookingData.truckNo || '';         // ✅ M (index 12) ทะเบียนรถ
    currentRow[13] = bookingData.trailerNo || '';       // ✅ N (index 13) ทะเบียนพ่วง
    currentRow[9]  = bookingData.phone || currentRow[9];                  // ✅ J: Phone ทับเบอร์เดิม

    // ✅ คำนวณ Ontime/Late จาก Column G (timeSlot) vs Column S (now)
    const timeSlot = String(currentRow[6] || '').trim(); // G (index 6)
    const plannedDate = currentRow[4]; // E (index 4)
    const matchStart = timeSlot.match(/^(\d{1,2}):(\d{2})/); // ✅ ดึงเวลาเริ่มต้น

    Logger.log('🔍 timeSlot: "' + timeSlot + '"');
    Logger.log('🔍 plannedDate: "' + plannedDate + '"');
    Logger.log('🔍 matchStart: ' + JSON.stringify(matchStart));

    if (matchStart && plannedDate) {
      const endHour   = parseInt(matchStart[1], 10);
      const endMinute = parseInt(matchStart[2], 10);

      let bookDate = (plannedDate instanceof Date)
        ? plannedDate
        : parseDateString(String(plannedDate).trim());
      const deadlineStr = Utilities.formatDate(bookDate, tz, 'yyyy-MM-dd')
        + `T${String(endHour).padStart(2,'0')}:${String(endMinute).padStart(2,'0')}:00`;

      const deadline = new Date(deadlineStr);
      // ✅ Logic ใหม่
      if (now <= deadline) {
        currentRow[22] = 'Ontime';
      } else if (now <= new Date(deadline.getTime() + 15 * 60 * 1000)) {
        currentRow[22] = 'Late';
      } else {
        currentRow[22] = 'Out of time';
      }

      Logger.log(`⏱ Slot: ${timeSlot} | Deadline: ${deadline} | CheckIn: ${now} → ${currentRow[22]}`);
    }

    // ✅ เขียนทั้งแถวกลับไป
    sheet.getRange(rowIndex, 1, 1, 23).setValues([currentRow]);

    // ✅ เขียนทั้งแถวกลับไป
    sheet.getRange(rowIndex, 1, 1, 23).setValues([currentRow]);
    
    Logger.log('✅ เขียนค่าใหม่ (Batch):');
    Logger.log('   S: ' + currentRow[18]);
