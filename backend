/**
 * ✅ Dashboard: ดึงข้อมูลแบบ Date Range พร้อม Comparison
 */
function getDashboardDataRange(serviceType, startDateStr, endDateStr) {
  try {
    const tz = getTz();
    
    // แปลง Date String เป็น Date Object
    const startDate = parseDateString(startDateStr);
    const endDate = parseDateString(endDateStr);
    
    if (!startDate || !endDate) {
      return { success: false, message: 'วันที่ไม่ถูกต้อง' };
    }
    
    // ตั้งเวลาให้ครอบคลุมทั้งวัน
    const start = new Date(startDate.getFullYear(), startDate.getMonth(), startDate.getDate(), 0, 0, 0);
    const end = new Date(endDate.getFullYear(), endDate.getMonth(), endDate.getDate(), 23, 59, 59);
    
    // คำนวณจำนวนวัน
    const dayCount = Math.ceil((end - start) / (1000 * 60 * 60 * 24)) + 1;
    
    // ✅ กำหนดช่วงเปรียบเทียบ (Previous Period)
    const previousEnd = new Date(start);
    previousEnd.setDate(previousEnd.getDate() - 1);
    previousEnd.setHours(23, 59, 59);
    
    const previousStart = new Date(previousEnd);
    previousStart.setDate(previousStart.getDate() - (dayCount - 1));
    previousStart.setHours(0, 0, 0);
    
    // เตรียมตัวแปรสำหรับเก็บข้อมูล CURRENT PERIOD
    let totalBookings = 0;
    let totalReceive = 0;
    let totalSend = 0;
    let totalPallets = 0;
    let maxCapacity = 0;
    
    const truckTypeData = {
      '4W': { count: 0, pallets: 0 },
      '6W': { count: 0, pallets: 0 },
      '10W': { count: 0, pallets: 0 },
      '22W': { count: 0, pallets: 0 }
    };
    
    const slotData = {};
    
    // ✅ เตรียมตัวแปรสำหรับเก็บข้อมูล PREVIOUS PERIOD
    let previousTotalBookings = 0;
    
    // กำหนด Service Types ที่จะดึงข้อมูล
    const serviceTypes = (serviceType === 'ALL') 
      ? ['AY', 'RJ', 'AY_EXPORT', 'AY_OEM', 'AY_FOC']
      : [serviceType];
    
    // Loop ดึงข้อมูลจากแต่ละ Service
    serviceTypes.forEach(sType => {
      const ssId = SS_CONFIG[sType];
      if (!ssId) return;
      
      const ss = SpreadsheetApp.openById(ssId);
      const sheet = ss.getSheetByName(SHEET_NAME) || ss.getSheets()[0];
      if (!sheet) return;
      
      const data = sheet.getDataRange().getValues();
      
      // Column indexes
      const colStatus = 1;    // B: สถานะงาน
      const colTruckType = 3; // D: ประเภทรถ
      const colDate = 4;      // E: วันที่
      const colTime = 6;      // G: เวลา
      const colPallet = 10;   // K: Pallet
      
      for (let i = 1; i < data.length; i++) {
        const row = data[i];
        const cellDate = row[colDate];
        
        if (!cellDate) continue;
        
        // แปลงวันที่
        let rowDate = null;
        if (cellDate instanceof Date) {
          rowDate = new Date(cellDate.getFullYear(), cellDate.getMonth(), cellDate.getDate());
        } else {
          const parsed = parseDateString(String(cellDate));
          if (parsed) {
            rowDate = new Date(parsed.getFullYear(), parsed.getMonth(), parsed.getDate());
          }
        }
        
        if (!rowDate) continue;
        
        // ✅ เช็คว่าอยู่ใน CURRENT PERIOD หรือ PREVIOUS PERIOD
        const isInCurrentPeriod = (rowDate >= start && rowDate <= end);
        const isInPreviousPeriod = (rowDate >= previousStart && rowDate <= previousEnd);
        
        if (!isInCurrentPeriod && !isInPreviousPeriod) continue;
        
        // ✅ นับข้อมูล CURRENT PERIOD
        if (isInCurrentPeriod) {
          totalBookings++;
          
          const status = String(row[colStatus] || '').trim();
          if (status.includes('รับสินค้า')) totalReceive++;
          if (status.includes('ส่งสินค้า')) totalSend++;
          
          const truckType = String(row[colTruckType] || '').trim();
          const pallets = Number(row[colPallet]) || 0;
          
          totalPallets += pallets;
          
          // นับ Truck Type
          if (truckTypeData[truckType]) {
            truckTypeData[truckType].count++;
            truckTypeData[truckType].pallets += pallets;
          }
          
          // เก็บข้อมูล Slot พร้อมแยกประเภทรถ
          const timeSlot = String(row[colTime] || '').trim();
          if (timeSlot) {
            if (!slotData[timeSlot]) {
              slotData[timeSlot] = { 
                totalPallets: 0, 
                count: 0,
                truckBreakdown: {} // ✅ เพิ่มการนับแยกตามประเภท
              };
            }
            slotData[timeSlot].totalPallets += pallets;
            slotData[timeSlot].count++;
            
            // ✅ นับจำนวนรถแต่ละประเภท
            if (truckType) {
              if (!slotData[timeSlot].truckBreakdown[truckType]) {
                slotData[timeSlot].truckBreakdown[truckType] = 0;
              }
              slotData[timeSlot].truckBreakdown[truckType]++;
            }
          }
        }
        
        // ✅ นับข้อมูล PREVIOUS PERIOD (เฉพาะจำนวนคัน)
        if (isInPreviousPeriod) {
          previousTotalBookings++;
        }
      }
      
      // โหลด Average Capacity (ประมาณการ)
      // สมมติ 1 วัน = 17 slots × 96 PLT = 1,632 PLT
      maxCapacity += (1632 * dayCount);
    });
    
    // ✅ คำนวณ Comparison
    const difference = totalBookings - previousTotalBookings;
    const percentage = previousTotalBookings > 0 
      ? Math.round((difference / previousTotalBookings) * 100) 
      : 0;
    
    // คำนวณ Utilization
    const utilization = maxCapacity > 0 ? Math.round((totalPallets / maxCapacity) * 100) : 0;
    
    // หา Full Slots พร้อมรายละเอียดประเภทรถ
    const fullSlots = [];
    Object.keys(slotData).forEach(slot => {
      const slotInfo = slotData[slot];
      const slotCapacity = 96;
      
      if (slotInfo.totalPallets >= slotCapacity) {
        fullSlots.push({
          time: slot,
          pallets: slotInfo.totalPallets,
          max: slotCapacity,
          count: slotInfo.count,
          percentage: 100,
          truckBreakdown: slotInfo.truckBreakdown || {} // ✅ เพิ่มรายละเอียดประเภทรถ
        });
      }
    });
    
    // เตรียม Truck Type Array
    const truckTypes = Object.keys(truckTypeData).map(type => ({
      type: type,
      count: truckTypeData[type].count,
      pallets: truckTypeData[type].pallets,
      percentage: totalBookings > 0 ? Math.round((truckTypeData[type].count / totalBookings) * 100) : 0
    }));
    
    // ✅ คำนวณ Capacity ที่ว่าง (Available)
    const availablePallets = maxCapacity - totalPallets;
    const availablePercentage = maxCapacity > 0 
      ? Math.round((availablePallets / maxCapacity) * 100)
      : 0;
    
    return {
      success: true,
      data: {
        totalBookings: totalBookings,
        totalReceive: totalReceive,
        totalSend: totalSend,
        utilization: utilization,
        totalPallets: totalPallets,
        maxCapacity: maxCapacity,
        truckTypes: truckTypes,
        fullSlots: fullSlots,
        availablePercentage: availablePercentage,
        availablePallets: availablePallets,  // ✅ เพิ่ม
        dateRange: {
          start: Utilities.formatDate(start, tz, 'dd/MM/yyyy'),
          end: Utilities.formatDate(end, tz, 'dd/MM/yyyy'),
          days: dayCount
        },
        // ✅ ส่งข้อมูล Comparison กลับไป
        comparison: {
          currentTotal: totalBookings,
          previousTotal: previousTotalBookings,
          difference: difference,
          percentage: percentage,
          previousPeriod: {
            start: Utilities.formatDate(previousStart, tz, 'dd/MM/yyyy'),
            end: Utilities.formatDate(previousEnd, tz, 'dd/MM/yyyy')
          }
        }
      }
    };
    
  } catch (error) {
    return {
      success: false,
      message: 'เกิดข้อผิดพลาด: ' + (error.message || error.toString())
    };
  }
}

