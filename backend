function getRegisterList() {
  try {
    const ss = SpreadsheetApp.openById(SHEET_ID);
    const sheet = ss.getSheetByName(SHEET_NAME) || ss.getSheets()[0];
    
    if (!sheet) {
      return { success: false, message: 'ไม่พบ Sheet' };
    }
    
    const tz = getTz();
    const today = new Date();
    const todayKey = Utilities.formatDate(today, tz, 'yyyy-MM-dd');
    
    const lastRow = sheet.getLastRow();
    if (lastRow < 2) {
      return { success: true, data: [] };
    }
    
    // อ่านข้อมูลทั้งหมด (A:V = columns 1-22)
    const data = sheet.getRange(2, 1, lastRow - 1, 22).getValues();
    
    const result = [];
    
