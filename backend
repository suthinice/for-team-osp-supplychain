    Logger.log('deadline: ' + deadline);
    Logger.log('deadline+15: ' + new Date(deadline.getTime() + 15 * 60 * 1000));
    Logger.log('checkin: ' + checkin);
    Logger.log('status: ' + status);

    sheet.getRange(rowNum, 23).setValue(status);

  } catch (e) {
    Logger.log('updateStatusTransport error: ' + e.toString());
  }
}

function getAYDomesticDashboard() {
  try {
    const tz = getTz();
    const now = new Date();
    const todayStr = Utilities.formatDate(now, tz, 'yyyy-MM-dd');

    const ss = SpreadsheetApp.openById(SS_CONFIG['AY']);
    const sheet = ss.getSheetByName(SHEET_NAME) || ss.getSheets()[0];
    if (!sheet) return { success: false, message: 'ไม่พบ Sheet' };

    const data = sheet.getDataRange().getValues();
    const bookings = [];

    data.forEach((row, index) => {
      if (index === 0) return; // skip header

      const d = row[4]; // Column E = วันที่
      let rowDateStr = '';
      if (d instanceof Date) {
        rowDateStr = Utilities.formatDate(d, tz, 'yyyy-MM-dd');
      } else {
        rowDateStr = String(d || '').trim();
      }

      if (rowDateStr !== todayStr) return;

      const statusTransport = String(row[19] || '').trim(); // T = Status_Transport

      // ✅ คำนวณ status
      let status = 'Waiting';
      if (statusTransport === 'In Progress') status = 'In Progress';
      else if (statusTransport === 'Completed') status = 'Completed';

      // ✅ แปลง TimeStamp_Register เป็น string
      const tsRaw = row[18]; // S = TimeStamp_Register
      let tsStr = '-';
      if (tsRaw instanceof Date) {
        tsStr = Utilities.formatDate(tsRaw, getTz(), 'HH:mm');
      } else if (tsRaw) {
        tsStr = String(tsRaw).trim();
      }

      bookings.push({
        queue:     row[21] || '-',          // V = Queue Number
        time:      String(row[6] || '-'),   // G = ช่วงเวลา
        driver:    String(row[16] || '-'),  // Q = ชื่อคนขับ
        truckNo:   String(row[12] || '-'),  // M = ทะเบียนรถ
        truckType: String(row[3] || '-'),   // D = ประเภทรถ
        status:    status,
        ontime:    String(row[22] || ''),   // W = Ontime/Late
        checkinTime: tsStr,                 // S = เวลา Check-in จริง
      });
    });

    // เรียงตาม Queue น้อยไปมาก และ Completed อยู่ด้านล่างเสมอ
    bookings.sort((a, b) => {
      const aCompleted = a.status === 'Completed' ? 1 : 0;
      const bCompleted = b.status === 'Completed' ? 1 : 0;

      // ถ้า Completed ไม่เท่ากัน → Completed ลงไปด้านล่าง
      if (aCompleted !== bCompleted) return aCompleted - bCompleted;

      // ถ้า status เหมือนกัน → เรียงตาม Queue น้อยไปมาก
      const qa = parseInt(a.queue) || 9999;
      const qb = parseInt(b.queue) || 9999;
      return qa - qb;
    });

    return { success: true, data: bookings, date: todayStr };

  } catch (e) {
    return { success: false, message: e.toString() };
  }
}

