/**
 * Helper: แปลงค่า capacity (ถ้าเป็นตัวเลขให้เก็บเป็น Number, ถ้าว่างให้เป็น "")
 */
function parseCapacityValue(val) {
  if (val === null || val === undefined || val === '') return '';
  
  const num = Number(val);
  if (!isNaN(num)) return num;
  
  return '';
}

/**
 * Helper: แปลงเวลาไทย (เช่น "16:00 น") เป็นนาที (960)
 */
function parseThaiTime(timeStr) {
  if (!timeStr) return null;

  const str = String(timeStr).trim();
  
  // รูปแบบ: "16:00 น" หรือ "16:00"
  const match = str.match(/(\d{1,2}):(\d{2})/);
  if (!match) return null;

  const hour = parseInt(match[1], 10);
  const minute = parseInt(match[2], 10);

  if (hour < 0 || hour > 23 || minute < 0 || minute > 59) return null;

  return hour * 60 + minute;
}

/**
 * Helper: แปลงนาทีกลับเป็นเวลาไทย (960 → "16:00 น")
 */
function formatMinutesToThaiTime(minutes) {
  const hour = Math.floor(minutes / 60);
  const min = minutes % 60;
  
  return `${String(hour).padStart(2, '0')}:${String(min).padStart(2, '0')} น`;
}

