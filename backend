/**
 * ✅ คำนวณลำดับโหลดสินค้า = MAX(ลำดับวันนี้) + 1
 * ถ้าไม่มีลำดับเลย → เริ่มที่ 1
 */
function calculateQueueNumber(sheet, bookingDate, currentRowIndex) {
  const tz = getTz();
  const targetDateKey = Utilities.formatDate(bookingDate, tz, "yyyy-MM-dd");
  const lastRow = sheet.getLastRow();

  if (lastRow < 2) return 1;

  // ✅ อ่านแค่ 2 Column ที่ใช้จริง
  const colE = sheet.getRange(2, 5, lastRow - 1, 1).getValues();  // Column E
  const colV = sheet.getRange(2, 22, lastRow - 1, 1).getValues(); // Column V

  let maxQueueToday = 0;
  let foundAnyInSameDate = false;

  for (let i = 0; i < colE.length; i++) {
    const rowNum = i + 2;
    if (rowNum === currentRowIndex) continue;

    const cellDate = colE[i][0];
    const queue = colV[i][0];

    if (!cellDate) continue;

    let rowDateKey = '';
    try {
      if (cellDate instanceof Date) {
        rowDateKey = Utilities.formatDate(cellDate, tz, "yyyy-MM-dd");
      } else {
        rowDateKey = Utilities.formatDate(new Date(cellDate), tz, "yyyy-MM-dd");
      }
    } catch(e) { continue; }

    if (rowDateKey === targetDateKey) {
      foundAnyInSameDate = true;
      const n = Number(queue);
      if (!isNaN(n) && n > maxQueueToday) {
        maxQueueToday = n;
      }
    }
  }

  if (!foundAnyInSameDate) return 1;

  const newQueue = maxQueueToday + 1;
  Logger.log('✅ Queue: ' + newQueue);
  return newQueue;
}

