const CAPACITY_RECORD_SS_ID = '1KmeX8H5UhO2GL3JcOJ3TQ9Tf3s7JJZOOdoqprYrve30';

function recordDailyCapacity() {
  const tz = getTz();
  const now = new Date();
  const todayStr = Utilities.formatDate(now, tz, 'yyyy-MM-dd');

  // ✅ หาว่าวันนี้คือวันอะไร → map เป็น Column index ใน Sheet2
  // Sheet2: A=ช่วงเวลา, B=Monday, C=Tuesday, D=Wednesday, E=Thursday, F=Friday, G=Saturday, H=Sunday
  const dayOfWeek = Utilities.formatDate(now, tz, 'EEEE'); // "Monday", "Tuesday", ...
  const dayColumnMap = {
    'Monday':    1, // B
    'Tuesday':   2, // C
    'Wednesday': 3, // D
    'Thursday':  4, // E
    'Friday':    5, // F
    'Saturday':  6, // G
    'Sunday':    7  // H
  };
  const colIndex = dayColumnMap[dayOfWeek];
  if (colIndex === undefined) return;

  // ✅ นับ Capacity รวมทั้งวันของแต่ละ Service จาก Sheet2
  const services = ['AY', 'RJ', 'AY_EXPORT', 'AY_OEM', 'AY_FOC'];
  const totals = {};

  services.forEach(serviceType => {
    try {
      const ssId = SS_CONFIG[serviceType];
      const ss = SpreadsheetApp.openById(ssId);
      const sheet2 = ss.getSheets()[1]; // Sheet2
      if (!sheet2) { totals[serviceType] = 0; return; }

      const data = sheet2.getDataRange().getValues();
      let total = 0;

      data.forEach((row, index) => {
        if (index === 0) return; // skip header
        const capacity = Number(row[colIndex]) || 0;
        total += capacity;
      });

      totals[serviceType] = total;
    } catch (e) {
      totals[serviceType] = 0;
    }
  });

  // ✅ เขียนลง Google Sheet ปลายทาง (Sheet1 / Table1)
  const targetSS = SpreadsheetApp.openById(CAPACITY_RECORD_SS_ID);
  const targetSheet = targetSS.getSheets()[0]; // Sheet1
  if (!targetSheet) return;

  // เช็คซ้ำ ป้องกัน duplicate
  const existingData = targetSheet.getDataRange().getValues();
  const alreadyExists = existingData.some((row, index) => { 
    if (index === 0) return false; // ✅ skip header row
    const d = row[0];
    let rowDateStr = '';
    if (d instanceof Date) {
      rowDateStr = Utilities.formatDate(d, tz, 'yyyy-MM-dd');
    } else {
      rowDateStr = String(d || '').trim();
    }
    return rowDateStr === todayStr;
  });

  if (alreadyExists) return; // ไม่ record ซ้ำ

  targetSheet.appendRow([
    todayStr,
    totals['AY']        || 0, // B - AY Domestic
    totals['RJ']        || 0, // C - RJ Domestic
    totals['AY_EXPORT'] || 0, // D - AY Export
    totals['AY_OEM']    || 0, // E - AY OEM
    totals['AY_FOC']    || 0  // F - AY FOC
  ]);
}

