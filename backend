function clearColumns(sheet, colNumbers) {
  const lastRow = sheet.getLastRow();
  if (lastRow < 2) return;

  colNumbers.forEach(colNum => {
    const colData = sheet.getRange(2, colNum, lastRow - 1, 1).getValues();
    const clearRanges = [];

    colData.forEach((row, i) => {
      const val = String(row[0] || '').trim();
