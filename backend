function confirmLoadingNewTransaction(sheetId, rowIndex) {
  const lock = LockService.getScriptLock();
  try {
    lock.waitLock(30000);

    const tz = getTz();
    const ss = SpreadsheetApp.openById(sheetId);
    const sheet = ss.getSheetByName(SHEET_NAME) || ss.getSheets()[0];
    if (!sheet) {
      lock.releaseLock();
      return { success: false, message: 'ไม่พบ Sheet' };
    }

    const now = new Date();

    // ✅ เช็คว่ายืนยันแล้วหรือยัง (Column X = 24)
    const existing = sheet.getRange(rowIndex, 24).getValue();
    if (existing) {
      lock.releaseLock();
      return { success: false, message: 'รายการนี้ยืนยันไปแล้ว' };
    }

    // ✅ บันทึก Timestamp ลง Column X (24) เท่านั้น ไม่เปลี่ยน Status
    sheet.getRange(rowIndex, 24).setValue(now);
    SpreadsheetApp.flush();

    lock.releaseLock();
    return { success: true, message: 'ยืนยันการโหลดสินค้าสำเร็จ' };

  } catch(e) {
    try { lock.releaseLock(); } catch(ex) {}
    return { success: false, message: 'เกิดข้อผิดพลาด: ' + e.message };
  }
}

function getDailyDashboardData(startDate, endDate) {
  try {
    const tz = getTz();
    const today = Utilities.formatDate(new Date(), tz, 'dd/MM/yyyy');

    const ss = SpreadsheetApp.openById(DATA_BOOKING_SS_ID);
    const sheet = ss.getSheetByName('SO');
    if (!sheet) return { success: false, message: 'ไม่พบ Sheet SO' };

    const lastRow = sheet.getLastRow();
    if (lastRow < 2) return { success: false, message: 'ไม่มีข้อมูล' };

    // ✅ อ่านถึง Column BV (75)
    const data = sheet.getRange(2, 1, lastRow - 1, 75).getValues();

    // ✅ Cards 1-5
    let soTotal = 0;
    let sent = 0;
    let waitBilling = 0;
    let waitShipment = 0;
    let waitDO = 0;

    // ✅ Cards 6-10 (วันนี้)
    let todayShipmentSet = new Set();
    let todayQty = 0;
    let custcQty = 0;
    let ayQty = 0;
    let rjQty = 0;

    // ✅ กราฟ
    const agentMap = {};

    data.forEach(row => {
      const bc = Number(row[54] || 0);  // BC (index 54)
      const bm = String(row[64] || '').trim(); // BM (index 64)
      const bv = String(row[73] || '').trim(); // BV (index 73)
      const bh = String(row[59] || '').trim(); // BH (index 59)
      const aj = String(row[35] || '').trim(); // AJ (index 35)
      const u  = String(row[20] || '').trim(); // U (index 20)

      // ✅ Card 1-5: กรองตาม Column E
      const cellDateE = row[4];
      let dateKeyE = '';
      if (cellDateE instanceof Date) {
        dateKeyE = Utilities.formatDate(cellDateE, tz, 'yyyy-MM-dd');
      } else if (cellDateE) {
        try { dateKeyE = Utilities.formatDate(new Date(cellDateE), tz, 'yyyy-MM-dd'); } catch(e) {}
      }

      if (dateKeyE >= startDate && dateKeyE <= endDate) {
        soTotal += bc;  // ✅ Card 1: รวมทุก Row ที่อยู่ในช่วงวันที่
      }

      // ✅ Card 2-5: กรองตาม Column BJ ที่มีข้อมูล
      const cellDateBJ = row[61]; // BJ (index 61)
      let dateKeyBJ = '';
      if (cellDateBJ instanceof Date) {
        dateKeyBJ = Utilities.formatDate(cellDateBJ, tz, 'yyyy-MM-dd');
      } else if (cellDateBJ) {
        try { dateKeyBJ = Utilities.formatDate(new Date(cellDateBJ), tz, 'yyyy-MM-dd'); } catch(e) {}
      }

      // ✅ Card 2: ส่งแล้ว → กรองตาม Column BJ
      if (dateKeyBJ >= startDate && dateKeyBJ <= endDate) {
        if (bm === 'ส่งแล้ว') sent += bc;
      }

      // ✅ Card 3-5: กรองตาม Column E เหมือน Card 1
      if (dateKeyE >= startDate && dateKeyE <= endDate) {
        if (bm === 'สร้าง DO แล้ว') waitBilling += bc;
        else if (bm === 'รอสร้าง Shipment') waitShipment += bc;
        else if (bm === 'รอสร้าง DO') waitDO += bc;
      }

      // ✅ Cards 6-10: กรองตาม Column BV = วันนี้
      if (bv === today) {
        // Card 6: Unique Shipment
        if (bh) todayShipmentSet.add(bh);

        // Card 7: จัดส่งวันนี้
        todayQty += bc;

        // Card 8: ลูกค้าเข้ารับ
        if (aj === 'CUSTC') custcQty += bc;

        // Card 9: AY
        if (u.endsWith('11') && aj !== 'CUSTC') ayQty += bc;

        // Card 10: RJ
        if (u.endsWith('15') && aj !== 'CUSTC') rjQty += bc;
      }

      // ✅ กราฟ: กรองตาม Column E
      if (dateKeyE >= startDate && dateKeyE <= endDate) {
        const agent = String(row[64] || '').trim(); // BM
        if (agent && bc > 0) {
          agentMap[agent] = (agentMap[agent] || 0) + bc;
        }
      }
    });

    const chartData = Object.entries(agentMap)
      .map(([label, value]) => ({ label, value }))
      .sort((a, b) => b.value - a.value);

    // ✅ ดึงข้อมูล Table วันนี้ พร้อม Sum ขวดตามร้านค้า + ช่วงเวลา
    const todayTableMap = {};
    data.forEach(row => {
      const bv = String(row[73] || '').trim();
      if (bv !== today) return;

      const shopName = String(row[33] || '').trim();
      const timeSlot = String(row[68] || '').trim();
      const qty      = Number(row[38] || 0);
      const status   = String(row[74] || '').trim();

      const key = `${shopName}||${timeSlot}`;
      if (!todayTableMap[key]) {
        todayTableMap[key] = { shopName, timeSlot, qty: 0, status };
      }
      todayTableMap[key].qty += qty;
      if (status) todayTableMap[key].status = status;
    });

    const todayTableData = Object.values(todayTableMap)
      .sort((a, b) => a.timeSlot.localeCompare(b.timeSlot));

    return {
      success: true,
      cards: {
        soTotal, sent, waitBilling, waitShipment, waitDO,
        todayShipment: todayShipmentSet.size,
        todayQty, custcQty, ayQty, rjQty
      },
      data: chartData,
      todayTable: todayTableData // ✅ เพิ่ม
    };

  } catch(e) {
    Logger.log('❌ getDailyDashboardData error: ' + e.message);
    return { success: false, message: e.message };
  }
}

