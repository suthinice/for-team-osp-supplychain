          String(row[6] || ''),
          String(row[1] || ''),
          "'" + String(row[2] || ''),
          Number(row[10] || 0),
          String(row[3] || ''),
          String(row[12] || ''),
          (() => {
            const val = row[13];
            if (!val) return '';
            if (val instanceof Date) return Utilities.formatDate(val, tz, 'dd/MM/yyyy');
            return String(val);
          })(),
          String(row[5] || ''),
          String(row[9] || ''),
          String(row[15] || ''),
          String(row[0] || ''),
          formatDT(row[11]),
          formatDT(row[18]),
          formatDT(row[20]),
          String(row[19] || ''),
          (() => {
            const val = row[9];
            if (!val || val === 0 || val === '0') return '';
            return "'" + String(val).replace(/\D/g, '');
          })()
        ]);
      });

      Logger.log(`✅ MT DataBooking ${sType}: ${allRows.length - 1} rows`);
    });

    if (allRows.length > 1) {
      sheet.getRange(1, 1, allRows.length, headers.length).setValues(allRows);
    }

    const headerRange = sheet.getRange(1, 1, 1, headers.length);
    headerRange.setBackground('#1e3a5f');
    headerRange.setFontColor('#ffffff');
    headerRange.setFontWeight('bold');
    headerRange.setHorizontalAlignment('center');
    sheet.setFrozenRows(1);
    sheet.getRange(2, 5, Math.max(allRows.length - 1, 1), 1).setNumberFormat('@');
    sheet.autoResizeColumns(1, headers.length);

    SpreadsheetApp.flush();
    Logger.log(`✅ MT DataBooking updated: ${allRows.length - 1} rows`);

    // ✅ Lookup ไปยัง Sheet SO MT
    lookupDataBookingToSO_MT();

    // ✅ ลบ Trigger ที่สร้างไว้หลังรันเสร็จ
    ScriptApp.getProjectTriggers().forEach(trigger => {
      if (trigger.getHandlerFunction() === 'updateDataBookingMT') {
        ScriptApp.deleteTrigger(trigger);
      }
    });

    return { success: true, message: `อัปเดต MT DataBooking สำเร็จ ${allRows.length - 1} rows` };

  } catch(e) {
    Logger.log('❌ updateDataBookingMT error: ' + e.message);
    return { success: false, message: e.message };
  }
}

function lookupDataBookingToSO_MT() {
  try {
    const tz = getTz();
    const ss = SpreadsheetApp.openById(DATA_BOOKING_MT_SS_ID);

    const dbSheet = ss.getSheetByName(DATA_BOOKING_MT_SHEET_NAME);
    if (!dbSheet) throw new Error('ไม่พบ Sheet DataBooking MT');

    const dbLastRow = dbSheet.getLastRow();
    if (dbLastRow < 2) return;

    const dbData = dbSheet.getRange(2, 1, dbLastRow - 1, 18).getValues();

    const shipmentMap = {};

    dbData.forEach(row => {
      const shipmentRaw = String(row[4] || '').replace(/^'/, '').trim();
      if (!shipmentRaw) return;

      const formatVal = (val) => {
        if (!val) return '';
        if (val instanceof Date) return Utilities.formatDate(val, tz, 'dd/MM/yyyy HH:mm');
        return String(val);
      };

      const colA = (() => {
        const val = row[0];
        if (!val) return '';
        if (val instanceof Date) return Utilities.formatDate(val, tz, 'dd/MM/yyyy');
        return String(val);
      })();
      const colC = formatVal(row[2]);
      const colH = String(row[7] || '');
      const colI = String(row[8] || '');
      const colO = formatVal(row[14]);
      const colP = formatVal(row[15]);
      const colQ = String(row[16] || '');
      const colR = (() => {
        const val = String(row[17] || '').trim();
        if (!val || val === '0' || val === '000') return '';
        return "'" + val;
      })();

      shipmentRaw.split(',').forEach(s => {
        const key = s.trim();
        if (key.length === 7) {
          shipmentMap[key] = { colA, colC, colO, colP, colH, colI, colQ, colR };
        }
      });
    });

    Logger.log('✅ MT Shipment Map size: ' + Object.keys(shipmentMap).length);

    const soSheet = ss.getSheetByName('SO');
    if (!soSheet) throw new Error('ไม่พบ Sheet SO MT');

    const soLastRow = soSheet.getLastRow();
    if (soLastRow < 2) return;

    const headers = [
      'BookingTime', 'RegisterTime', 'ConfirmTime',
      'TruckNo', 'TrailerNo', 'BookingDate',
      'Status', 'DriverPhone'
    ];
    soSheet.getRange(1, 69, 1, headers.length).setValues([headers]);

    const headerRange = soSheet.getRange(1, 69, 1, headers.length);
    headerRange.setBackground('#1e3a5f');
    headerRange.setFontColor('#ffffff');
    headerRange.setFontWeight('bold');

    const bhValues = soSheet.getRange(2, 60, soLastRow - 1, 1).getValues();

    const resultRows = bhValues.map(row => {
      const bhVal = String(row[0] || '').trim();
      if (!bhVal) return ['', '', '', '', '', '', '', ''];

      const found = shipmentMap[bhVal];
      if (!found) return ['', '', '', '', '', '', '', ''];

      return [
        found.colC, found.colO, found.colP,
        found.colH, found.colI, found.colA,
        found.colQ, found.colR
      ];
    });

    soSheet.getRange(2, 69, resultRows.length, 8).setValues(resultRows);
    SpreadsheetApp.flush();

    Logger.log(`✅ MT lookupDataBookingToSO เสร็จ`);

  } catch(e) {
    Logger.log('❌ lookupDataBookingToSO_MT error: ' + e.message);
    throw e;
  }
}
