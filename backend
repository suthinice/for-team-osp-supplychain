    const row = sheet.getRange(rowNum, 1, 1, 23).getValues()[0];

    const bookingDate = row[4];
    const timeSlot = String(row[6] || '').trim();

    if (!bookingDate || !timeSlot || !checkinDateTime) return;

    const matchStart = timeSlot.match(/^(\d{1,2}):(\d{2})/); // ✅ ดึงเวลาเริ่มต้น
    if (!matchStart) return;

    const endHour   = parseInt(matchStart[1], 10);
    const endMinute = parseInt(matchStart[2], 10);

    const tz = getTz();
    let bookDate;
    if (bookingDate instanceof Date) {
      bookDate = bookingDate;
    } else {
      bookDate = parseDateString(String(bookingDate).trim());
    }

    const deadlineStr = Utilities.formatDate(bookDate, tz, 'yyyy-MM-dd')
      + ` ${String(endHour).padStart(2,'0')}:${String(endMinute).padStart(2,'0')}:00`;

    const deadline = new Date(deadlineStr.replace(' ', 'T'));

    const checkin = (checkinDateTime instanceof Date)
      ? checkinDateTime
      : new Date(checkinDateTime);

