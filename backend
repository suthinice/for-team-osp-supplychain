function getDashboardCapacityUtilize(dateStr, serviceFilter) {
  try {
    const tz = getTz();
    const targetSS = SpreadsheetApp.openById(CAPACITY_RECORD_SS_ID);
    const targetSheet = targetSS.getSheets()[0];
    if (!targetSheet) return { success: false, message: 'ไม่พบ Sheet' };

    const data = targetSheet.getDataRange().getValues();
    let capacityRow = null;

    for (let i = 1; i < data.length; i++) {
      const d = data[i][0];
      let rowDateStr = '';
      if (d instanceof Date) {
        rowDateStr = Utilities.formatDate(d, tz, 'yyyy-MM-dd');
      } else {
        rowDateStr = String(d || '').trim();
      }
      if (rowDateStr === dateStr) {
        capacityRow = data[i];
        break;
      }
    }

    const capacities = {
      AY:        capacityRow ? Number(capacityRow[1]) || 0 : 0,
      RJ:        capacityRow ? Number(capacityRow[2]) || 0 : 0,
      AY_EXPORT: capacityRow ? Number(capacityRow[3]) || 0 : 0,
      AY_OEM:    capacityRow ? Number(capacityRow[4]) || 0 : 0,
      AY_FOC:    capacityRow ? Number(capacityRow[5]) || 0 : 0
    };

    const services = serviceFilter && serviceFilter !== 'ALL'
      ? [serviceFilter]
      : ['AY', 'RJ', 'AY_EXPORT', 'AY_OEM', 'AY_FOC'];

    const used = {};
    services.forEach(serviceType => {
      try {
        const ssId = SS_CONFIG[serviceType];
        const ss = SpreadsheetApp.openById(ssId);
        const sheet = ss.getSheetByName(SHEET_NAME) || ss.getSheets()[0];
        if (!sheet) { used[serviceType] = 0; return; }

        const rows = sheet.getDataRange().getValues();
        let totalPallets = 0;
        rows.forEach((row, index) => {
          if (index === 0) return;
          const d = row[4];
          let rowDateStr = '';
          if (d instanceof Date) {
            rowDateStr = Utilities.formatDate(d, tz, 'yyyy-MM-dd');
          } else {
            rowDateStr = String(d || '').trim();
          }
          if (rowDateStr === dateStr) {
            totalPallets += Number(row[10]) || 0;
          }
        });
        used[serviceType] = totalPallets;
      } catch (e) {
        used[serviceType] = 0;
      }
    });

    // ✅ ถ้า ALL → รวมทุก Service เป็นตัวเดียว
    if (!serviceFilter || serviceFilter === 'ALL') {
      const totalUsed = services.reduce((sum, s) => sum + (used[s] || 0), 0);
      const totalCap = services.reduce((sum, s) => sum + (capacities[s] || 0), 0);
      return {
        success: true,
        mode: 'ALL',
        data: {
          used: totalUsed,
          capacity: totalCap,
          percent: totalCap > 0 ? Math.round((totalUsed / totalCap) * 100) : 0
        }
      };
    }

    // ✅ ถ้าเลือก Service เดียว
    const s = serviceFilter;
    return {
      success: true,
      mode: 'SINGLE',
      serviceType: s,
      data: {
        used: used[s] || 0,
        capacity: capacities[s] || 0,
        percent: capacities[s] > 0 ? Math.round(((used[s] || 0) / capacities[s]) * 100) : 0
      }
    };

  } catch (e) {
    return { success: false, message: e.toString() };
  }
}

