      const timeSlot = row[6];          // G: ช่วงเวลา
      const transportCompany = row[8];  // I: บริษัทขนส่ง
      const driverName = row[16];       // Q: ชื่อผู้ขับ
      const timestampReg = row[18];     // S: TimeStamp_Register
      const status = row[19];           // T: Status_Transport
      const queueNumber = row[21];      // V: ลำดับโหลดสินค้า
      
      // ✅ กรองเฉพาะที่มี TimeStamp_Register (ลงทะเบียนแล้ว)
      if (!timestampReg) continue;
      
      // ✅ กรองเฉพาะวันนี้
      let bookingDateKey = '';
      if (bookingDate instanceof Date) {
        bookingDateKey = Utilities.formatDate(bookingDate, tz, 'yyyy-MM-dd');
      } else if (bookingDate) {
        try {
          const tempDate = new Date(bookingDate);
          bookingDateKey = Utilities.formatDate(tempDate, tz, 'yyyy-MM-dd');
        } catch (e) {
          continue;
        }
      }
      
      if (bookingDateKey !== todayKey) continue;
      
      // ✅ แปลง TimeStamp_Register เป็นเวลา
      let checkInTime = '';
      if (timestampReg instanceof Date) {
        checkInTime = Utilities.formatDate(timestampReg, tz, 'HH:mm');
      }
      
      result.push({
        service: service || '-',
        queueNumber: queueNumber || '-',
        timeSlot: timeSlot || '-',
        checkInTime: checkInTime,
        transportCompany: transportCompany || '-',
        driverName: driverName || '-',
        status: status || 'Scheduled'
      });
