/**
 * ✅ ยืนยันการโหลดสินค้า (Confirm Loading)
 * - เปลี่ยน Status_Transport (T/20) เป็น "Completed"
 * - บันทึก TimeStamp_Billing (U/21)
 */
function confirmLoadingTransaction(sheetId, rowIndex, serviceType) {
  const lock = LockService.getScriptLock();
  
  try {
    lock.waitLock(30000);
    
    const tz = getTz();
    const ss = SpreadsheetApp.openById(sheetId);
    const sheet = ss.getSheetByName(SHEET_NAME) || ss.getSheets()[0];
    
    if (!sheet) {
      lock.releaseLock();
      return { success: false, message: 'ไม่พบ Sheet' };
    }
    
    const now = new Date();
    
    Logger.log('=== Confirm Loading Row ' + rowIndex + ' ===');
    
    // เช็คสถานะปัจจุบัน
    const currentStatus = sheet.getRange(rowIndex, 20).getValue(); // Column T
    
    if (currentStatus === 'Completed' || currentStatus === 'เสร็จสิ้น') {
      lock.releaseLock();
      return {
        success: false,
        message: 'รายการนี้ถูกยืนยันไปแล้ว'
      };
    }
    
    Logger.log('📝 อัปเดต Status และ Timestamp');
    
    // อัปเดต Column T: Status_Transport
    sheet.getRange(rowIndex, 20).setValue('Completed');
    Logger.log('✅ Column T (20): Completed');
    
    // อัปเดต Column U: TimeStamp_Billing
    sheet.getRange(rowIndex, 21).setValue(now);
    Logger.log('✅ Column U (21): ' + now);
    
    // Flush
    SpreadsheetApp.flush();
    Logger.log('💾 Flush สำเร็จ');
    
    // Verify
    const verifyStatus = sheet.getRange(rowIndex, 20).getValue();
    const verifyTimestamp = sheet.getRange(rowIndex, 21).getValue();
    
    Logger.log('🔍 ตรวจสอบ:');
    Logger.log('   Status: ' + verifyStatus);
    Logger.log('   Timestamp: ' + verifyTimestamp);
    
    lock.releaseLock();
    
    return {
      success: true,
      message: 'ยืนยันการโหลดสินค้าสำเร็จ'
    };
    
  } catch (error) {
    Logger.log('❌ Error: ' + error.message);
    
    try {
      lock.releaseLock();
    } catch (e) {}
    
    return {
      success: false,
      message: 'เกิดข้อผิดพลาด: ' + (error.message || error.toString())
    };
  }
}

