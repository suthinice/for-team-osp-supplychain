function getTz() {
  return TIMEZONE || Session.getScriptTimeZone();
}

function parseDateString(dateString) {
  if (!dateString) return null;

  const s = String(dateString).trim();

  // ✅ กรณี yyyy-MM-dd
  if (/^\d{4}-\d{2}-\d{2}$/.test(s)) {
    const [y, m, d] = s.split('-').map(n => parseInt(n, 10));
    return new Date(y, m - 1, d);
  }

  // ✅ กรณี MM/DD/YYYY
  if (/^\d{2}\/\d{2}\/\d{4}$/.test(s)) {
    const [m, d, y] = s.split('/').map(n => parseInt(n, 10));
    return new Date(y, m - 1, d);
  }

  // ✅ fallback (เผื่อกรณีเป็น Date object หรือ format อื่น)
  const parsed = new Date(s);
  if (!isNaN(parsed.getTime())) {
    return new Date(parsed.getFullYear(), parsed.getMonth(), parsed.getDate());
  }

  // ❌ แปลงไม่ได้จริง ๆ
  return null;
}


function sanitizePhone(phone) {
  const digits = String(phone || "").replace(/\D/g, "");
  return digits ? ("'" + digits) : "";
}

function calculatePalletValue(type) {
  if (!type) return 0;
  if (String(type).includes('4W') || String(type).includes('4 ล้อ')) return 3;
  if (String(type).includes('6W') || String(type).includes('6 ล้อ')) return 6;
  if (String(type).includes('10W') || String(type).includes('10 ล้อ')) return 12;
  if (String(type).includes('22W') || String(type).includes('พ่วง')) return 24;
  return 0;
}

/**
 * อนุญาตวันอาทิตย์หรือไม่:
 * - ถ้าไม่ใช่อาทิตย์ => true
 * - ถ้าเป็นอาทิตย์ => ดูใน ชีต3 ว่ามีวันนั้นและสถานะ "เปิด" หรือไม่
 */
function isSundayAllowed(deliveryDate, ssId) {
  // ✅ ใช้ getDay() (Local) เพื่อไม่หลุดวันเพราะ UTC
  if (deliveryDate.getDay() !== 0) return true;

  const sheet = SpreadsheetApp.openById(ssId).getSheetByName(SUNDAY_OVERRIDE_SHEET_NAME);
  if (!sheet || sheet.getLastRow() <= 1) return false;

  const values = sheet.getRange(2, 1, sheet.getLastRow() - 1, 2).getValues();
  const target = new Date(deliveryDate.getFullYear(), deliveryDate.getMonth(), deliveryDate.getDate()).getTime();

  return values.some(r => (r[0] instanceof Date) &&
    (new Date(r[0].getFullYear(), r[0].getMonth(), r[0].getDate()).getTime() === target) &&
    String(r[1] || "").trim() === 'เปิด'
  );
}

function getSlotCapacities(serviceType, dateString) {
  try {
    const ssId = SS_CONFIG[serviceType];
    if (!ssId) return { capacities: {}, rawData: [] };

    const ss = SpreadsheetApp.openById(ssId);
    const sheet = ss.getSheetByName(SHEET_NAME) || ss.getSheets()[0];
    if (!sheet) return { capacities: {}, rawData: [] };

    const tz = getTz();
    const dateObj = parseDateString(dateString);
    const formattedDate = Utilities.formatDate(dateObj, tz, "yyyy-MM-dd");

    // ✅ โหลด Capacity จาก Sheet2 ตามวัน
    const capacityMap = loadCapacityMapForDate_(ss, dateObj);

    const data = sheet.getDataRange().getValues();

    // column index (0-based)
    const colDetail = 0;
    const colStatus = 1;
    const colShipment = 2;
    const colTruckType = 3;
    const colDate = 4;
    const colVendor = 5;
    const colTime = 6;
    const colPhone = 9;
    const colPallet = 10;
    const colTruckNo = 12;
    const colTrailerNo = 13;

    const capacities = {};
    const list = [];

    // init ทุก slot ให้โชว์ box เสมอ
    getTimeSlotsForService(serviceType).forEach(slot => {
      const maxCap = (capacityMap[slot] != null)
        ? capacityMap[slot]
        : DEFAULT_CAPACITY;

      capacities[slot] = {
        totalPallets: 0,
        count: 0,
        max: maxCap
      };
    });

    for (let i = 1; i < data.length; i++) {
      const cellDate = data[i][colDate];

      let rowDate = "";
      if (cellDate instanceof Date) {
        rowDate = Utilities.formatDate(cellDate, tz, "yyyy-MM-dd");
      } else if (cellDate) {
        rowDate = String(cellDate).split("T")[0];
      }

      if (rowDate !== formattedDate) continue;

      const rowTime = String(data[i][colTime] || "").trim();
      if (!capacities[rowTime]) continue;

      const pallets = Number(data[i][colPallet]) || 0;

      capacities[rowTime].totalPallets += pallets;
      capacities[rowTime].count += 1;

      list.push({
        uuid: String(data[i][7] || ''),
        status: String(data[i][colStatus] || ''),
        shipment: String(data[i][colShipment] || ''),
        pallets: pallets,
        truckType: String(data[i][colTruckType] || ''),
        truckNo: String(data[i][colTruckNo] || ''),          // ✅ บังคับเป็น String
        trailerNo: (() => {                                   // ✅ แปลง Date เป็น String
          const val = data[i][colTrailerNo];
          if (!val) return '';
          if (val instanceof Date) return Utilities.formatDate(val, getTz(), 'dd/MM/yyyy');
          return String(val);
        })(),
        company: String(data[i][colVendor] || ''),
        phone: String(data[i][colPhone] || ''),
        remark: String(data[i][colDetail] || ''),
        time: rowTime,
        customerName: String(data[i][15] || '')
      });
    }

    return { capacities, rawData: list };

  } catch (error) {
    throw new Error("Server Error: " + error.toString());
  }
}


function isSundayAllowed(deliveryDate, ssId) {
  // ไม่ใช่วันอาทิตย์ => อนุญาต
  if (deliveryDate.getDay() !== 0) return true;

  const ss = SpreadsheetApp.openById(ssId);

  // ✅ รองรับหลายชื่อ: Sheet3 / ชีต3 (เพิ่มชื่ออื่นได้ถ้าคุณใช้ชื่อแบบอื่น)
  const possibleNames = ["Sheet3", "Sheet 3"];
  let sheet = null;
  for (const name of possibleNames) {
    sheet = ss.getSheetByName(name);
    if (sheet) break;
  }
  if (!sheet) return false; // ไม่เจอชีต => ถือว่าปิด

  const lastRow = sheet.getLastRow();
  if (lastRow < 2) return false; // ไม่มีข้อมูล => ปิด

  // อ่าน A2:B (วันที่, สถานะ)
  const values = sheet.getRange(2, 1, lastRow - 1, 2).getValues();

  // เทียบ “เฉพาะวัน” ไม่สนเวลา
  const target = new Date(deliveryDate.getFullYear(), deliveryDate.getMonth(), deliveryDate.getDate()).getTime();

  for (const [dateCell, statusCell] of values) {
    let rowTime = null;

    // A เป็น Date
    if (dateCell instanceof Date) {
      rowTime = new Date(dateCell.getFullYear(), dateCell.getMonth(), dateCell.getDate()).getTime();
    } else if (dateCell) {
      // A เป็นข้อความ เช่น 2026-01-24 หรือ 24/01/2026 (เผื่อไว้)
      const s = String(dateCell).trim();
      let d = null;

      if (/^\d{4}-\d{2}-\d{2}$/.test(s)) {
        const [y, m, da] = s.split("-").map(n => parseInt(n, 10));
        d = new Date(y, m - 1, da);
      } else if (/^\d{2}\/\d{2}\/\d{4}$/.test(s)) {
        const [da, m, y] = s.split("/").map(n => parseInt(n, 10));
        d = new Date(y, m - 1, da);
      }

      if (d) rowTime = new Date(d.getFullYear(), d.getMonth(), d.getDate()).getTime();
    }

    if (rowTime === null) continue;

    if (rowTime === target) {
      const status = String(statusCell || "").trim();
      // ✅ วันอาทิตย์จะ “จองได้” เฉพาะเมื่อสถานะ = เปิด
      return status === "เปิด";
    }
  }

  // ไม่พบวันนั้นในชีต => ปิด
  return false;
}

function checkTimeSlotCapacity(deliveryDate, timeSlot, ss) {
  // ss = SpreadsheetApp.openById(ssId) จะส่งมาก็ได้ เพื่อไม่ต้องเปิดซ้ำ
  const tz = getTz();
  const spreadsheet = ss || SpreadsheetApp.getActiveSpreadsheet();
  const sheet = spreadsheet.getSheetByName(SHEET_NAME) || spreadsheet.getSheets()[0];
  if (!sheet) return 0;

  const formattedDate = Utilities.formatDate(deliveryDate, tz, "yyyy-MM-dd");

  // column index (0-based) ตามโครงคุณ: E=4, G=6, K=10
  const colDate = 4;
  const colTime = 6;
  const colPallet = 10;

  const lastRow = sheet.getLastRow();
  if (lastRow < 2) return 0;

  const data = sheet.getRange(2, 1, lastRow - 1, 15).getValues();

  let total = 0;
  for (let i = 0; i < data.length; i++) {
    const r = data[i];

    // date
    const cellDate = r[colDate];
    let rowDate = "";
    if (cellDate instanceof Date) rowDate = Utilities.formatDate(cellDate, tz, "yyyy-MM-dd");
    else if (cellDate) rowDate = String(cellDate).split("T")[0];

    if (rowDate !== formattedDate) continue;

    // time
    const rowTime = String(r[colTime] || "").trim();
    if (rowTime !== String(timeSlot).trim()) continue;

    // pallets
    total += Number(r[colPallet]) || 0;
  }
  return total;
}


function getWeekdayColumnIndex_(dateObj) {
  // Monday=1 ... Sunday=7
  const day = dateObj.getDay(); // Sun=0..Sat=6
  const iso = day === 0 ? 7 : day; // Sun -> 7
  // Sheet2: A=slot, B=Mon, C=Tue, ... H=Sun
  // B คือคอลัมน์ที่ 2 => index = 2 + (iso-1)
  return 2 + (iso - 1);
}

function loadCapacityMapForDate_(ss, dateObj) {
  const sheet = ss.getSheetByName(CAPACITY_SHEET_NAME);
  const map = {};

  if (!sheet) return map;

  const lastRow = sheet.getLastRow();
  if (lastRow < 2) return map;

  const weekdayCol = getWeekdayColumnIndex_(dateObj);

  // อ่าน A2:A และคอลัมน์ของวันนั้น ๆ
  const slots = sheet.getRange(2, 1, lastRow - 1, 1).getValues(); // A
  const caps  = sheet.getRange(2, weekdayCol, lastRow - 1, 1).getValues(); // B..H

  for (let i = 0; i < slots.length; i++) {
    const slot = String(slots[i][0] || "").trim();
    if (!slot) continue;

    const raw = caps[i][0];
    const cap = (typeof raw === "number")
      ? raw
      : (raw !== "" && raw != null && !isNaN(Number(raw))) ? Number(raw) : null;

    // ถ้า cap เป็น 0 => เต็มทันที
    // ถ้า cap ว่าง/ไม่ใช่ตัวเลข => ใช้ DEFAULT_CAPACITY
    map[slot] = (cap === null) ? DEFAULT_CAPACITY : cap;
  }

  return map;
}

function saveBookingData(data) {
  try {
    const tz = getTz();
    const ssId = SS_CONFIG[data.serviceType];
    if (!ssId) return { success: false, message: "serviceType ไม่ถูกต้อง" };

    const bookingDateStr = (data.jobDate && String(data.jobDate).trim())
      ? String(data.jobDate).trim()
      : String(data.date || "").trim();

    if (!bookingDateStr) return { success: false, message: "กรุณาเลือกวันที่" };
    if (!data.time) return { success: false, message: "กรุณาเลือกช่วงเวลา" };

    const deliveryDate = parseDateString(bookingDateStr);
    const bookingMonth = deliveryDate.getMonth() + 1; // 1-12
    if (bookingMonth >= 7) {
      return { success: false, message: 'ฐานข้อมูลเต็ม ไม่สามารถเพิ่มการจองได้' };
    }

    // ✅ 1) ตรวจสอบ cutoff 09:00 (ยกเว้น AY_EXPORT)
    const now = new Date();
    const bangkokNow = new Date(now.toLocaleString('en-US', { timeZone: 'Asia/Bangkok' }));
    const currentHour = bangkokNow.getHours();
    const todayStr = Utilities.formatDate(bangkokNow, 'Asia/Bangkok', 'yyyy-MM-dd');

    const isAyExport = (data.serviceType === 'AY_EXPORT');
    const isUnlimited = String(data.bookingPermission || '').trim() === 'ตลอดเวลา'; // ✅ เพิ่ม

    if (!isAyExport && !isUnlimited && bookingDateStr === todayStr && currentHour >= 9) {
      return { success: false, message: 'ไม่สามารถจองวันนี้ได้ เนื่องจากเลยเวลา 09:00 น.' };
    }

    // ✅ เปิด SS ครั้งเดียว ใช้ต่อทุกที่
    const ss = SpreadsheetApp.openById(ssId);
    const sheet = ss.getSheetByName(SHEET_NAME) || ss.getSheets()[0];
    if (!sheet) return { success: false, message: "ไม่พบชีตสำหรับบันทึกข้อมูล" };

    // ✅ 2) เช็ค Holiday (Sheet3) — Frontend เช็ค Cache แล้ว Backend เช็คซ้ำเป็น Safety net
    if (isHoliday(ssId, bookingDateStr)) {
      return { success: false, message: 'ปิดทำการในวันที่เลือก ไม่สามารถจองได้' };
    }

    // ✅ 3) กฎวันอาทิตย์
    if (!isSundayAllowed(deliveryDate, ssId)) {
      return { success: false, message: "วันหยุดทำการ (โปรดเลือกวันทำการปกติ)" };
    }

    // ✅ 4) บริษัทขนส่ง
    let finalVendor = data.vendor || "";
    let otherVendor = "";
    if (data.vendor === "อื่นๆ") {
      finalVendor = data.vendorOther || "อื่นๆ";
      otherVendor = data.vendorOther || "";
      if (!otherVendor) return { success: false, message: "กรุณาระบุชื่อบริษัทขนส่งอื่นๆ" };
    }

    const pallets = calculatePalletValue(data.truckType);
    const formattedDate = Utilities.formatDate(deliveryDate, tz, "yyyy-MM-dd");

    // ✅ 5) ตรวจ Capacity จาก Sheet2
    const capacityMap = loadCapacityMapForDate_(ss, deliveryDate);
    const maxForThisSlot = (capacityMap[data.time] != null)
      ? capacityMap[data.time]
      : DEFAULT_CAPACITY;

    if (maxForThisSlot === 0) {
      return { success: false, message: "ไม่สามารถลงเวลานี้ได้เนื่องจากรอบจองเต็มแล้ว (Capacity = 0)" };
    }

    const currentTotal = checkTimeSlotCapacity(deliveryDate, data.time, ss);
    if ((currentTotal + pallets) > maxForThisSlot) {
      return { success: false, message: `ไม่สามารถลงเวลานี้ได้เนื่องจากรอบจองเต็มแล้ว (สูงสุด ${maxForThisSlot} Pallet)` };
    }

    // ✅ 6) บันทึกข้อมูล
    const registerCode = generateUniqueCode(sheet, deliveryDate, data.serviceType);

    const newRow = [
      data.remark || "",                               // A (1)
      data.jobStatus || "",                            // B (2)
      (data.shipmentNo ? "'" + formatShipment7Digits(data.shipmentNo) : ""), // C (3)
      data.truckType || "",                            // D (4)
      formattedDate,                                   // E (5)
      finalVendor,                                     // F (6)
      data.time || "",                                 // G (7)
      Utilities.getUuid(),                             // H (8)
      Session.getActiveUser().getEmail(),              // I (9)
      sanitizePhone(data.phone),                       // J (10)
      pallets || 0,                                    // K (11)
      new Date(),                                      // L (12)
      data.truckNo || "",                              // M (13)
      data.trailerNo || "",                            // N (14)
      otherVendor,                                     // O (15)
      data.customerName || "",                         // P (16)
      data.driverName || "",                           // Q (17)
      registerCode,                                    // R (18)
      "",                                              // S (19)
      "Scheduled",                                     // T (20)
      ""                                               // U (21)
    ];

    sheet.appendRow(newRow);
    return { success: true, message: "บันทึกการจองสำเร็จ" };

  } catch (error) {
    return { success: false, message: "เกิดข้อผิดพลาด: " + error.toString() };
  }
}


function formatShipment7Digits(shipmentStr) {
  if (!shipmentStr) return "";

  // เอาเฉพาะตัวเลข
  const digits = String(shipmentStr).replace(/[^0-9]/g, "");

  // ตัดเป็นชุดละ 7 หลัก
  const groups = [];
  for (let i = 0; i < digits.length; i += 7) {
    groups.push(digits.substring(i, i + 7));
  }

  return groups.join(",");
}

function loginUser(id, password) {
  try {
    const userId = String(id || '').trim();
    const pass = String(password || '').trim();

    if (!userId || !pass) {
      return { success: false, message: 'กรุณากรอก ID และรหัสผ่าน' };
    }

    const ss = SpreadsheetApp.openById(REGISTER_SS_ID);
    const sh = ss.getSheetByName(REGISTER_SHEET_NAME);
    if (!sh) return { success: false, message: 'ไม่พบ Sheet1 (Register)' };

    const lastRow = sh.getLastRow();
    if (lastRow < 2) return { success: false, message: 'ยังไม่มีผู้ใช้งานในระบบ' };

    // ✅ อ่าน A–K (14 คอลัมน์)
    const data = sh.getRange(2, 1, lastRow - 1, 14).getValues();

    // ✅ helper: แปลงค่าจากชีตให้เป็น string สะอาด (ตัด ' หน้า, ตัดช่องว่าง)
    const clean = (v) => String(v ?? '').replace(/^'/, '').trim();

    // ✅ หา user ด้วย ID (Column A)
    const row = data.find(r => clean(r[0]).toLowerCase() === userId.toLowerCase());
    if (!row) return { success: false, message: 'ไม่พบผู้ใช้งานนี้' };

    // ✅ Password = Column B
    const savedPass = clean(row[1]);
    if (savedPass !== pass) return { success: false, message: 'รหัสผ่านไม่ถูกต้อง' };

    // ✅ Status = Column J
    const statusRaw = clean(row[9]);
    const status = statusRaw.toLowerCase();

    if (status !== 'approve') {
