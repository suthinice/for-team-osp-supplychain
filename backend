 * ต้องตั้ง Trigger ด้วยตัวเอง (ดูด้านล่าง)
 */
function generateDailyReport() {
  try {
    const tz = getTz();
    const today = Utilities.formatDate(new Date(), tz, 'yyyy-MM-dd');
    const fileName = `Report_${today}`;

    const folder = DriveApp.getFolderById(REPORT_FOLDER_ID);

    // ✅ หาไฟล์ที่มีอยู่แล้ว หรือสร้างใหม่
    let spreadsheet = findOrCreateSpreadsheet(folder, fileName);

    // ✅ อัปเดต Sheet AY
    updateReportSheet(spreadsheet, 'AY', today, tz);

    // ✅ อัปเดต Sheet RJ
    updateReportSheet(spreadsheet, 'RJ', today, tz);

    Logger.log('✅ Report updated: ' + fileName);

  } catch(e) {
    Logger.log('❌ generateDailyReport error: ' + e.message);
  }
}

/**
 * หาไฟล์ที่มีชื่อนั้นใน Folder หรือสร้างใหม่
 */
function findOrCreateSpreadsheet(folder, fileName) {
  // ค้นหาไฟล์ชื่อนี้ใน Folder
  const files = folder.getFilesByName(fileName);

  if (files.hasNext()) {
    // ✅ มีอยู่แล้ว → เปิดใช้
    const file = files.next();
    Logger.log('📂 Found existing file: ' + fileName);
    return SpreadsheetApp.openById(file.getId());
  }

  // ✅ ไม่มี → สร้างใหม่
  const newSS = SpreadsheetApp.create(fileName);

  // ย้ายไปใส่ใน Folder ที่กำหนด
  const newFile = DriveApp.getFileById(newSS.getId());
  folder.addFile(newFile);

  // ลบออกจาก My Drive (ไม่ให้ซ้ำ)
  DriveApp.getRootFolder().removeFile(newFile);

  Logger.log('📄 Created new file: ' + fileName);
  return newSS;
}

/**
 * อัปเดตข้อมูลใน Sheet ตาม serviceType
 */
function updateReportSheet(spreadsheet, serviceType, dateStr, tz) {
  try {
    // ✅ หา Sheet หรือสร้างใหม่
    let sheet = spreadsheet.getSheetByName(serviceType);
    if (!sheet) {
      sheet = spreadsheet.insertSheet(serviceType);
    } else {
      sheet.clearContents(); // ล้างข้อมูลเดิม
    }

    // ✅ Headers (เหมือนหน้า Export)
    const headers = [
      'วันที่', 'Service', 'ช่วงเวลา', 'สถานะ', 'Shipment',
      'Pallet', 'ประเภทรถ', 'ทะเบียนรถ', 'ทะเบียนพ่วง', 'บริษัทขนส่ง',
      'เบอร์ติดต่อ', 'ชื่อลูกค้า', 'รายละเอียด',
      'BookDateTime', 'RegisterDateTime', 'ConfirmDateTime', 'Status ขนส่ง'
    ];

    // ✅ ดึงข้อมูลจาก Source Sheet
    const ssId = SS_CONFIG[serviceType];
    if (!ssId) {
      Logger.log('❌ ไม่พบ SS_CONFIG สำหรับ ' + serviceType);
      return;
    }

    const sourceSS = SpreadsheetApp.openById(ssId);
    const sourceSheet = sourceSS.getSheetByName(SHEET_NAME) || sourceSS.getSheets()[0];
    if (!sourceSheet) return;

    const lastRow = sourceSheet.getLastRow();
    if (lastRow < 2) {
      // ✅ ไม่มีข้อมูล ใส่แค่ Header
      sheet.getRange(1, 1, 1, headers.length).setValues([headers]);
      formatHeaderRow(sheet, headers.length);
      return;
    }

    const data = sourceSheet.getRange(2, 1, lastRow - 1, 23).getValues();
    const rows = [];

    data.forEach(row => {
      const cellDate = row[4]; // Column E
      let dateKey = '';

      if (cellDate instanceof Date) {
        dateKey = Utilities.formatDate(cellDate, tz, 'yyyy-MM-dd');
      } else if (cellDate) {
        try {
          const parts = String(cellDate).split('/');
          if (parts.length === 3) {
            dateKey = `${parts[2]}-${parts[0].padStart(2,'0')}-${parts[1].padStart(2,'0')}`;
          } else {
            dateKey = Utilities.formatDate(new Date(cellDate), tz, 'yyyy-MM-dd');
          }
        } catch(e) {}
      }

      // ✅ กรองเฉพาะวันนี้
      if (dateKey !== dateStr) return;

      // ✅ แปลง DateTime เป็น String
      const formatDT = (val) => {
        if (!val) return '';
        if (val instanceof Date) return Utilities.formatDate(val, tz, 'dd/MM/yyyy HH:mm');
        return String(val);
      };

      rows.push([
        dateKey,
        serviceType,
        String(row[6] || ''),      // G: ช่วงเวลา
        String(row[1] || ''),      // B: สถานะ
        "'" + String(row[2] || ''),      // C: Shipment (force text)
        Number(row[10] || 0),      // K: Pallet
        String(row[3] || ''),      // D: ประเภทรถ
        String(row[12] || ''),     // M: ทะเบียนรถ
        String(row[13] || ''),     // N: ทะเบียนพ่วง
        String(row[5] || ''),      // F: บริษัทขนส่ง
        String(row[9] || ''),      // J: เบอร์ติดต่อ
        String(row[15] || ''),     // P: ชื่อลูกค้า
        String(row[0] || ''),      // A: รายละเอียด
        formatDT(row[11]),         // L: BookDateTime
        formatDT(row[18]),         // S: RegisterDateTime
        formatDT(row[20]),         // U: ConfirmDateTime
        String(row[19] || '')      // T: Status ขนส่ง
      ]);
    });

    // ✅ เขียน Header + Data
    const allData = [headers, ...rows];
    sheet.getRange(1, 1, allData.length, headers.length).setValues(allData);

    // ✅ Format Header
    formatHeaderRow(sheet, headers.length);

    // ✅ บังคับ Column Shipment (E = คอลัมน์ที่ 5) เป็น Text
    sheet.getRange(2, 5, Math.max(rows.length, 1), 1).setNumberFormat('@');

    // ✅ Auto resize columns
    sheet.autoResizeColumns(1, headers.length);

    Logger.log(`✅ ${serviceType}: ${rows.length} rows written`);

  } catch(e) {
    Logger.log(`❌ updateReportSheet (${serviceType}) error: ` + e.message);
  }
}

