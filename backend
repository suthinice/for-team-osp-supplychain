/**
 * ✅ เขียน Header + สูตร Column BC-BM ใน Sheet SO
 */
function writeFormulasToSO(targetSsId, targetSheetName) {
  try {
    const ss = SpreadsheetApp.openById(targetSsId);
    const sheet = ss.getSheetByName(targetSheetName);
    if (!sheet) throw new Error('ไม่พบ Sheet: ' + targetSheetName);

    const lastRow = sheet.getLastRow();
    if (lastRow < 2) {
      Logger.log('⚠️ ไม่มีข้อมูลใน Sheet SO');
      return;
    }

    Logger.log('📝 เขียนสูตร ArrayFormula SO lastRow: ' + lastRow);

    const START_COL = 55; // BC

    // ✅ Headers
    const headers = [
      'Qty Bottle',          // BC
      'DO No',               // BD
      'DO Date',             // BE
      'Plan GI Date',        // BF
      'Shipment Date',       // BG
      'Shipment Number',     // BH
      'Delivery Date on DO', // BI
      'Billing Date',        // BJ
      'Channel TT',          // BK
      'Bill No',             // BL
      'Reason for Pending',  // BM
      'AgentName',           // BN
      'SpecProcessing',      // BO
      'TruckType'            // BP
    ];

    sheet.getRange(1, START_COL, 1, headers.length).setValues([headers]);

    // ✅ Format Header
    const headerRange = sheet.getRange(1, START_COL, 1, headers.length);
    headerRange.setBackground('#1e3a5f');
    headerRange.setFontColor('#ffffff');
    headerRange.setFontWeight('bold');

    // ✅ ลบสูตรเดิม Row 2 ลงไปก่อน
    sheet.getRange(2, START_COL, lastRow - 1, headers.length).clearContent();

    // ✅ เขียน ArrayFormula แค่ Row 2 แถวเดียว
    const arrayFormulas = [
      // BC: Qty Bottle
      `=ARRAYFORMULA(IF(ROW(A2:A)>ROW(A${lastRow}),,IF(M2:M>=1,AM2:AM,0)))`,
      // BD: DO No
      `=ARRAYFORMULA(IF(ROW(A2:A)>ROW(A${lastRow}),,IFERROR(VLOOKUP(A2:A,DO!C:D,2,0),"")))`,
      // BE: DO Date
      `=ARRAYFORMULA(IF(ROW(A2:A)>ROW(A${lastRow}),,IFERROR(VLOOKUP(A2:A,DO!C:O,13,0),"")))`,
      // BF: Plan GI Date
      `=ARRAYFORMULA(IF(ROW(A2:A)>ROW(A${lastRow}),,IFERROR(VLOOKUP(BD2:BD,DO!D:P,13,0),"")))`,
      // BG: Shipment Date
      `=ARRAYFORMULA(IF(ROW(A2:A)>ROW(A${lastRow}),,IFERROR(VLOOKUP(BD2:BD,DO!D:BR,67,0),"")))`,
      // BH: Shipment Number
      `=ARRAYFORMULA(IF(ROW(A2:A)>ROW(A${lastRow}),,IFERROR(VLOOKUP(BD2:BD,DO!D:G,4,0),"")))`,
      // BI: Delivery Date on DO
      `=ARRAYFORMULA(IF(ROW(A2:A)>ROW(A${lastRow}),,IFERROR(VLOOKUP(BD2:BD,DO!D:V,19,0),"")))`,
      // BJ: Billing Date
      `=ARRAYFORMULA(IF(ROW(A2:A)>ROW(A${lastRow}),,IFERROR(VLOOKUP(BD2:BD,DO!D:T,17,0),"")))`,
      // BK: Channel TT
      `=ARRAYFORMULA(IF(ROW(A2:A)>ROW(A${lastRow}),,LEFT(AE2:AE,3)))`,
      // BL: Bill No
      `=ARRAYFORMULA(IF(ROW(A2:A)>ROW(A${lastRow}),,IFERROR(VLOOKUP(BD2:BD,DO!D:BG,55,0),"")))`,
      // BM: Reason for Pending
      `=ARRAYFORMULA(IF(ROW(A2:A)>ROW(A${lastRow}),,IF(BD2:BD="","รอสร้าง DO",IF((BD2:BD<>"")*(BJ2:BJ<>""),"ส่งแล้ว",IF((BD2:BD<>"")*(BH2:BH<>"")*(BJ2:BJ=""),"สร้าง DO แล้ว",IF((BD2:BD<>"")*(BH2:BH=""),"รอสร้าง Shipment",""))))))`,
      // BN: AgentName
      `=ARRAYFORMULA(IF(ROW(A2:A)>ROW(A${lastRow}),,IFERROR(VLOOKUP(BH2:BH,DO!G:BE,51,0),"")))`,
      // BO: SpecProcessing
      `=ARRAYFORMULA(IF(ROW(A2:A)>ROW(A${lastRow}),,IFERROR(VLOOKUP(BH2:BH,DO!G:BN,60,0),"")))`,
      // BP: TruckType
      `=ARRAYFORMULA(IF(ROW(A2:A)>ROW(A${lastRow}),,IFERROR(VLOOKUP(BO2:BO,TruckType!A:C,3,0),"")))`
    ];

    // ✅ เขียนทีละ Column แค่ Row 2
    arrayFormulas.forEach((formula, idx) => {
      sheet.getRange(2, START_COL + idx).setFormula(formula);
    });

    // ✅ Format Column BV (74) เป็น Text
    const dataRows = lastRow - 1;
    sheet.getRange(2, 74, dataRows, 1).setNumberFormat('@');

    SpreadsheetApp.flush();
    Logger.log('✅ เขียน ArrayFormula SO เสร็จ');

  } catch(e) {
    Logger.log('❌ writeFormulasToSO error: ' + e.message);
    throw e;
  }
}

/**
 * ✅ ลบ Row ที่ Column A เป็นค่า Blank (เร็วกว่าเดิม)
 */
function deleteBlankRowsInColA(sheet) {
  const lastRow = sheet.getLastRow();
  if (lastRow < 2) return;

  const lastCol = sheet.getLastColumn();
  const data = sheet.getRange(2, 1, lastRow - 1, lastCol).getValues();

  // ✅ เก็บเฉพาะ Row ที่ Column A ไม่ว่าง
  const filtered = data.filter(row => String(row[0] || '').trim() !== '');

  // ✅ ลบข้อมูลเดิมทั้งหมด
  sheet.getRange(2, 1, lastRow - 1, lastCol).clearContent();

  // ✅ เขียนใหม่ทั้งหมดครั้งเดียว
  if (filtered.length > 0) {
    sheet.getRange(2, 1, filtered.length, lastCol).setValues(filtered);
  }

  Logger.log('✅ ลบ Blank Rows เสร็จ เหลือ: ' + filtered.length + ' rows');
}

