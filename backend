function _findUserRow_(sh, userId) {
  const lastRow = sh.getLastRow();
  if (lastRow < 2) return -1;

  const data = sh.getRange(2, 1, lastRow - 1, 11).getValues(); // A..K
  const idx = data.findIndex(r => String(r[0]).replace(/^'/, '').trim().toLowerCase() === String(userId).trim().toLowerCase());
  return idx === -1 ? -1 : (idx + 2); // +2 เพราะเริ่มที่ row 2
}

function _requireAdmin_(adminId) {
  const ss = SpreadsheetApp.openById(REGISTER_SS_ID);
  const sh = ss.getSheetByName(REGISTER_SHEET_NAME);
