<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>OSP Truck Slot Booking</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🚛</text></svg>">

  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#25408E',
            secondary: '#1a2d63',
            danger: '#ED1C24',
            success: '#00B050',
            warning: '#FFDE17',
          },
        },
      },
    }
  </script>
  <script src="https://cdn.sheetjs.com/xlsx-0.20.1/package/dist/xlsx.full.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

  <!-- chartjs-plugin-datalabels -->
  <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/chartjs-plugin-datalabels/2.2.0/chartjs-plugin-datalabels.min.js"></script>

  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest"></script>

  <style>
    body { font-family: 'Sarabun', sans-serif; background-color: #f8fafc; font-size: 15px; }
    
    /* ========== LOGIN STYLES ========== */
    @keyframes fadeUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

    .enter { animation: fadeUp .35s cubic-bezier(.16,1,.3,1) both; }
    .fade-in { animation: fadeIn .2s ease-out both; }

    .view { display: none; }
    .view.active { display: block; }

    .focus-ring:focus { outline: none; box-shadow: 0 0 0 4px rgba(37,64,142,.15); border-color: rgba(37,64,142,.6); }

    @keyframes spin { to { transform: rotate(360deg); } }
    .spinner { width: 16px; height: 16px; border-radius: 999px; border: 2px solid rgba(255,255,255,.5); border-top-color: #fff; animation: spin .7s linear infinite; }

    .btn-disabled { opacity: .6; pointer-events: none; }
    
    /* ========== MAIN APP STYLES ========== */
    .sidebar-transition { transition: all 0.3s ease-in-out; }
    
    .sidebar-collapsed {
      width: 80px !important;
    }

    .sidebar-collapsed .sidebar-text {
      opacity: 0;
      width: 0;
      overflow: hidden;
      white-space: nowrap;
    }

    .sidebar-collapsed .sidebar-logo-text {
      display: none;
    }

    .sidebar-collapsed .nav-item {
      justify-content: center;
      padding-left: 0.5rem;
      padding-right: 0.5rem;
    }

    .sidebar-collapsed .nav-item + div p {
      opacity: 0;
      height: 0;
      overflow: hidden;
      margin: 0;
      padding: 0;
    }
    
    .sidebar-toggle-btn {
      transition: transform 0.3s ease;
    }
    
    .sidebar-collapsed .sidebar-toggle-btn {
      transform: rotate(180deg);
    }
    
    .slot-card:hover:not(.full) { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(37, 64, 142, 0.1); }
    .slot-selected { border-color: #25408E; background-color: #eff6ff; }
    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: #f1f1f1; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }

    .modal-backdrop { background-color: rgba(0, 0, 0, 0.6); backdrop-filter: blur(4px); }
    .animate-zoom-in { animation: zoomIn 0.2s cubic-bezier(0.16, 1, 0.3, 1); }
    @keyframes zoomIn { from { transform: scale(0.9) translateY(10px); opacity: 0; } to { transform: scale(1) translateY(0); opacity: 1; } }
    .animate-slide-up { animation: slideUp 0.3s ease-out; }
    @keyframes slideUp { from { transform: translateY(10px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

    .form-input-balanced{
      width:100%; padding:0.6rem 1rem; background:#f8fafc; border:1px solid #e2e8f0;
      border-radius:0.75rem; font-size:0.9375rem; transition:all 0.2s;
    }
    .form-input-balanced:focus{
      outline:none; border-color:#25408E; box-shadow:0 0 0 3px rgba(37,64,142,0.1); background:#fff;
    }
    .label-required::after{ content:" *"; color:#ED1C24; }

    .shipment-tip {
      position: relative;
      cursor: help;
    }
    .shipment-tip:hover .tip-box {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }
    .tip-box {
      opacity: 0;
      pointer-events: none;
      position: absolute;
      left: 0;
      top: 110%;
      z-index: 50;
      width: min(520px, 80vw);
      padding: 10px 12px;
      border-radius: 14px;
      border: 1px solid rgb(226 232 240);
      background: white;
      box-shadow: 0 18px 50px rgba(15, 23, 42, 0.15);
      transform: translateY(-4px);
      transition: 0.15s ease;
      font-size: 12px;
      color: rgb(51 65 85);
    }
    .tip-box .mono {
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      word-break: break-all;
    }

    @keyframes bounce-slow {
      0%, 100% {
        transform: translateY(0);
      }
      50% {
        transform: translateY(-10px);
      }
    }

    .animate-bounce-slow {
      animation: bounce-slow 2s ease-in-out infinite;
    }

    .quick-action-btn {
      transition: all 0.2s ease;
    }
    
    .quick-action-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(37, 64, 142, 0.15);
    }
    
    .quick-action-btn:active {
      transform: translateY(0);
    }

    .cursor-help {
      cursor: help;
    }

    .pl-13 {
      padding-left: 3.25rem;
    }

    /* ========== LOGIN/MAIN TOGGLE ========== */
    #login-container {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      width: 100vw; /* ✅ เพิ่ม */
      position: fixed; /* ✅ เพิ่ม */
      top: 0; /* ✅ เพิ่ม */
      left: 0; /* ✅ เพิ่ม */
      background: linear-gradient(to bottom right, #25408E, #4a69bd);
      z-index: 9999; /* ✅ เพิ่ม */
    }

    #main-app {
      display: none;
      width: 100%; /* ✅ เพิ่ม */
    }

    #main-app.active {
      display: flex;
      width: 100%; /* ✅ เพิ่ม */
    }

    #login-container.hidden {
      display: none;
    }

    /* ✅ Filters Container - บังคับให้อยู่บรรทัดเดียว */
    .filters-container {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: nowrap;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .filter-item {
      flex-shrink: 0;
      white-space: nowrap;
    }

    .search-box {
      width: 280px;
      min-width: 280px;
    }

    .filter-divider {
      width: 1px;
      height: 2rem;
      background-color: #e2e8f0;
      flex-shrink: 0;
    }

    .filters-container::-webkit-scrollbar {
      height: 4px;
    }

    .filters-container::-webkit-scrollbar-track {
      background: transparent;
    }

    .filters-container::-webkit-scrollbar-thumb {
      background: #cbd5e1;
      border-radius: 2px;
    }

    .filters-container::-webkit-scrollbar-thumb:hover {
      background: #94a3b8;
    }

    @media (max-width: 1023px) {
      #sidebar {
        transform: translateX(-100%) !important;  /* ✅ ซ่อนออกนอกจอตั้งแต่แรก */
        position: fixed !important;
        width: 240px !important;
      }
      
      #sidebar.translate-x-0 {
        transform: translateX(0) !important;  /* ✅ เปิดเมื่อกดปุ่ม hamburger */
      }

      #main-content {
        width: 100% !important;
        margin-left: 0 !important;
        flex: 1 !important;
      }
      
      #main-app {
        display: block !important;
      }
    }

    @media (min-width: 1024px) {
      #main-app {
        display: flex !important;
      }
      #sidebar {
        position: relative !important;
        transform: none !important;
      }
    }

  </style>
</head>

<body class="flex min-h-screen">

  <!-- ========================================== -->
  <!-- LOGIN CONTAINER -->
  <!-- ========================================== -->
<div id="login-container">
  <div class="fixed inset-0 z-0">
    <img src="https://lh3.googleusercontent.com/d/1qU8HqCBb0hrUImzmhZmD67-BKHJSJZKG"
         class="w-full h-full object-cover" alt="background">
    <div class="absolute inset-0 bg-black/30"></div>
  </div>

  <main class="relative z-10 w-full max-w-md px-4">

      <!-- Branding -->
      <div class="text-center mb-6">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-white/10 backdrop-blur border border-white/20 mb-3 shadow-xl">
          <span class="text-3xl">🚚</span>
        </div>
        <h1 class="text-2xl font-black text-white tracking-tight drop-shadow">OSP Booking System</h1>
        <p class="text-white/60 text-xs mt-1">ระบบจัดการการจองรับ/ส่งสินค้า</p>
      </div>

      <section class="bg-white/10 backdrop-blur-xl rounded-3xl shadow-2xl border border-white/20 overflow-hidden">

        <!-- Top tabs -->
        <div class="px-5 pt-5">
          <div class="flex gap-1.5 p-1 bg-white/10 rounded-2xl">
            <button id="tab-login"
              class="tab-btn flex-1 px-3 py-2 rounded-xl text-xs font-bold text-white bg-white/20 shadow"
              onclick="switchView('login')">เข้าสู่ระบบ</button>
            <button id="tab-register"
              class="tab-btn flex-1 px-3 py-2 rounded-xl text-xs font-bold text-white/60"
              onclick="switchView('register')">สมัครสมาชิก</button>
            <button id="tab-forgot"
              class="tab-btn flex-1 px-3 py-2 rounded-xl text-xs font-bold text-white/60"
              onclick="switchView('forgot')">เปลี่ยนรหัสผ่าน</button>
          </div>
        </div>

        <!-- Content -->
        <div class="px-5 py-5">

          <!-- Alert -->
          <div id="alert" class="hidden fade-in mb-4 rounded-2xl border px-4 py-3 text-sm">
            <div class="font-bold" id="alert-title">แจ้งเตือน</div>
            <div id="alert-msg" class="mt-0.5"></div>
          </div>

          <!-- LOGIN VIEW -->
          <div id="view-login" class="view active">
            <div class="space-y-3">
              <div>
                <label class="text-xs font-bold text-white/70 uppercase">ID Name</label>
                <input id="login-id" type="text" placeholder="เช่น 12345"
                  class="mt-1 w-full rounded-2xl border border-white/20 bg-white/10 backdrop-blur px-4 py-3 text-sm text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-white/30 transition" />
              </div>
              <div>
                <label class="text-xs font-bold text-white/70 uppercase">รหัสผ่าน</label>
                <input id="login-pass" type="password" placeholder="••••••••"
                  class="mt-1 w-full rounded-2xl border border-white/20 bg-white/10 backdrop-blur px-4 py-3 text-sm text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-white/30 transition" />
              </div>

              <button id="btn-login" onclick="handleLogin()"
                class="mt-2 w-full rounded-2xl bg-primary text-white font-black py-3 text-sm hover:bg-secondary transition active:scale-[0.99] flex items-center justify-center gap-2 shadow-lg">
                <span id="login-btn-text">เข้าสู่ระบบ</span>
                <span id="login-spinner" class="hidden spinner"></span>
              </button>

              <div class="flex items-center justify-between text-xs mt-2">
                <button class="text-white/50 hover:text-white font-semibold transition" onclick="switchView('forgot')">เปลี่ยนรหัสผ่าน?</button>
                <button class="text-white/50 hover:text-white font-semibold transition" onclick="switchView('register')">ยังไม่มีบัญชี → สมัครสมาชิก</button>
              </div>
            </div>
          </div>

          <!-- REGISTER VIEW -->
          <div id="view-register" class="view">
            <div class="space-y-3">
              <div>
                <label class="text-xs font-bold text-white/70 uppercase">โปรดตั้ง ID</label>
                <input id="reg-id" type="text" placeholder="เช่น nice123"
                  class="mt-1 w-full rounded-2xl border border-white/20 bg-white/10 backdrop-blur px-4 py-3 text-sm text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-white/30 transition" />
              </div>

              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label class="text-xs font-bold text-white/70 uppercase">ชื่อ</label>
                  <input id="reg-first" type="text" placeholder="ชื่อ"
                    class="mt-1 w-full rounded-2xl border border-white/20 bg-white/10 backdrop-blur px-4 py-3 text-sm text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-white/30 transition" />
                </div>
                <div>
                  <label class="text-xs font-bold text-white/70 uppercase">นามสกุล</label>
                  <input id="reg-last" type="text" placeholder="นามสกุล"
                    class="mt-1 w-full rounded-2xl border border-white/20 bg-white/10 backdrop-blur px-4 py-3 text-sm text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-white/30 transition" />
                </div>
              </div>

              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label class="text-xs font-bold text-white/70 uppercase">อีเมล</label>
                  <input id="reg-email" type="email" placeholder="name@company.com"
                    class="mt-1 w-full rounded-2xl border border-white/20 bg-white/10 backdrop-blur px-4 py-3 text-sm text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-white/30 transition" />
                </div>
                <div>
                  <label class="text-xs font-bold text-white/70 uppercase">เบอร์โทร</label>
                  <input id="reg-phone" type="tel" placeholder="08xxxxxxxx"
                    class="mt-1 w-full rounded-2xl border border-white/20 bg-white/10 backdrop-blur px-4 py-3 text-sm text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-white/30 transition" />
                </div>
              </div>

              <div>
                <label class="text-xs font-bold text-white/70 uppercase">บริษัท</label>
                <select id="reg-company" onchange="toggleDepartmentField()"
                  class="mt-1 w-full rounded-2xl border border-white/20 bg-white/10 backdrop-blur px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-white/30 transition">
                  <option value="" class="text-slate-800">-- เลือกบริษัท --</option>
                  <option value="DHL" class="text-slate-800">DHL</option>
                  <option value="เก้าเลี้ยว" class="text-slate-800">เก้าเลี้ยว</option>
                  <option value="TNV" class="text-slate-800">TNV</option>
                  <option value="OSP" class="text-slate-800">OSP</option>
                  <option value="TRL" class="text-slate-800">TRL</option>
                </select>
              </div>

              <!-- ✅ Dropdown แผนก (แสดงเฉพาะตอนเลือก OSP) -->
              <div id="reg-department-wrap" class="hidden">
                <label class="text-xs font-bold text-white/70 uppercase">แผนก</label>
                <select id="reg-department"
                  class="mt-1 w-full rounded-2xl border border-white/20 bg-white/10 backdrop-blur px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-white/30 transition">
                  <option value="" class="text-slate-800">-- เลือกแผนก --</option>
                  <option value="Supply Chain Officer" class="text-slate-800">Supply Chain Officer</option>
                  <option value="Transportation" class="text-slate-800">Transportation</option>
                  <option value="Warehouse" class="text-slate-800">Warehouse</option>
                  <option value="Warehouse Team Billing" class="text-slate-800">Warehouse Team Billing</option>
                  <option value="Warehouse Team Loading" class="text-slate-800">Warehouse Team Loading</option>
                  <option value="Sales Agent" class="text-slate-800">Sales Agent</option>
                  <option value="Sales LMT" class="text-slate-800">Sales LMT</option>
                  <option value="Sales Strategy" class="text-slate-800">Sales Strategy</option>
                  <option value="Sales MT" class="text-slate-800">Sales MT</option>
                  <option value="IB" class="text-slate-800">IB</option>
                  <option value="Customer Service" class="text-slate-800">Customer Service</option>
                  <option value="Planning" class="text-slate-800">Planning</option>
                </select>
              </div>

              <div>
                <label class="text-xs font-bold text-white/70 uppercase">ตั้งรหัสผ่าน</label>
                <input id="reg-pass" type="password" placeholder="อย่างน้อย 6 ตัว"
                  class="mt-1 w-full rounded-2xl border border-white/20 bg-white/10 backdrop-blur px-4 py-3 text-sm text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-white/30 transition" />
              </div>

              <div>
                <label class="text-xs font-bold text-white/70 uppercase">ยืนยันรหัสผ่าน</label>
                <input id="reg-pass2" type="password" placeholder="ยืนยันรหัสผ่าน"
                  class="mt-1 w-full rounded-2xl border border-white/20 bg-white/10 backdrop-blur px-4 py-3 text-sm text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-white/30 transition" />
              </div>

              <button id="btn-register" onclick="handleRegister()"
                class="mt-2 w-full rounded-2xl bg-white text-slate-900 font-black py-3 text-sm hover:bg-white/90 transition active:scale-[0.99] flex items-center justify-center gap-2 shadow-lg">
                <span id="reg-btn-text">สมัครสมาชิก</span>
                <span id="reg-spinner" class="hidden spinner"></span>
              </button>

              <p class="text-xs text-white/40 mt-2">* สมัครแล้วสถานะจะเป็น Waiting รอผู้ดูแล Approve</p>
            </div>
          </div>

          <!-- FORGOT VIEW -->
          <div id="view-forgot" class="view">
            <div class="space-y-3">
              <div>
                <label class="text-xs font-bold text-white/70 uppercase">ID NAME</label>
                <input id="fp-id" type="text" placeholder="เช่น 12345"
                  class="mt-1 w-full rounded-2xl border border-white/20 bg-white/10 backdrop-blur px-4 py-3 text-sm text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-white/30 transition" />
              </div>
              <div>
                <label class="text-xs font-bold text-white/70 uppercase">รหัสผ่านเดิม</label>
                <input id="fp-oldpass" type="password" placeholder="กรอกรหัสผ่านเดิม"
                  class="mt-1 w-full rounded-2xl border border-white/20 bg-white/10 backdrop-blur px-4 py-3 text-sm text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-white/30 transition" />
              </div>
              <div>
                <label class="text-xs font-bold text-white/70 uppercase">รหัสผ่านใหม่</label>
                <input id="fp-pass" type="password" placeholder="ตั้งรหัสผ่านใหม่"
                  class="mt-1 w-full rounded-2xl border border-white/20 bg-white/10 backdrop-blur px-4 py-3 text-sm text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-white/30 transition" />
              </div>
              <div>
                <label class="text-xs font-bold text-white/70 uppercase">ยืนยันรหัสผ่านใหม่</label>
                <input id="fp-pass2" type="password" placeholder="ยืนยันรหัสผ่านใหม่"
                  class="mt-1 w-full rounded-2xl border border-white/20 bg-white/10 backdrop-blur px-4 py-3 text-sm text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-white/30 transition" />
              </div>

              <button id="btn-reset" onclick="handleResetPassword()"
                class="mt-2 w-full rounded-2xl bg-primary text-white font-black py-3 text-sm hover:bg-secondary transition active:scale-[0.99] flex items-center justify-center gap-2 shadow-lg">
                <span id="reset-btn-text">อัปเดตรหัสผ่าน</span>
                <span id="reset-spinner" class="hidden spinner"></span>
              </button>
            </div>
          </div>

        </div>
      </section>

      <!-- Footer -->
      <p class="text-center text-white/40 text-xs mt-4">© 2026 OSP Booking System</p>
    </main>
  </div>

  <!-- ========================================== -->
  <!-- MAIN APP CONTAINER -->
  <!-- ========================================== -->
  <div id="main-app" class="flex min-h-screen w-full">

  <!-- Sidebar Overlay (จอเล็กเท่านั้น) -->
  <div id="sidebar-overlay"
    class="fixed inset-0 z-40 hidden bg-black/40 backdrop-blur-[2px] lg:hidden"
    onclick="closeSidebar()"></div>

  <!-- Sidebar -->
  <aside id="sidebar"
    class="sidebar-transition sidebar-collapsed fixed inset-y-0 left-0 z-50 bg-primary text-white lg:relative lg:inset-auto"
    style="width: 80px; flex-shrink: 0;">
    <div class="flex flex-col h-full">
      <!-- Header with Logo & Toggle -->
      <div class="p-6 border-b border-white/10 flex items-center justify-between">
        <div class="flex items-center gap-3 min-w-0">
          <!-- Logo Icon -->
          <div class="flex-shrink-0">
            <i data-lucide="package-check" class="w-7 h-7"></i>
          </div>
          
          <!-- Logo Text (ซ่อนตอน collapse) -->
          <h1 class="sidebar-text sidebar-logo-text text-xl font-bold tracking-wider whitespace-nowrap">
            OSP BOOKING
          </h1>
        </div>

        <!-- ปุ่ม Toggle (จอใหญ่เท่านั้น) -->
        <button 
          onclick="toggleSidebarDesktop()"
          class="sidebar-toggle-btn hidden lg:flex p-2 rounded-lg hover:bg-white/10 transition"
          aria-label="Toggle sidebar"
          title="ปิด/เปิด Sidebar">
          <i data-lucide="chevron-left" class="w-5 h-5"></i>
        </button>

        <!-- ปุ่มปิด (จอเล็กเท่านั้น) -->
        <button 
          onclick="closeSidebar()"
          class="lg:hidden p-2 rounded-lg hover:bg-white/10 transition"
          aria-label="Close sidebar">
          <i data-lucide="x" class="w-5 h-5"></i>
