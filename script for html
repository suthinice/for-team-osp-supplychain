    // Helper: แปลงเวลาไทย (Client-side) เช่น "00:00 น" → 0 นาที, "16:00 น" → 960 นาที
    function parseThaiTimeLocal(timeStr) {
      if (!timeStr) return null;

      const str = String(timeStr).trim();
      
      // รองรับหลายรูปแบบ:
      // "00:00 น" "01:00 น" "16:00 น" หรือ "00:00" "01:00" "16:00"
      const match = str.match(/(\d{1,2}):(\d{2})/);
      
      if (!match) return null;

      const hour = parseInt(match[1], 10);
      const minute = parseInt(match[2], 10);

      // ✅ รองรับ 00:00 - 23:59
      if (hour < 0 || hour > 23 || minute < 0 || minute > 59) return null;

      return hour * 60 + minute;
    }

    // Helper: แปลงนาทีเป็นเวลา (Client-side) เช่น 0 → "00:00 น", 960 → "16:00 น"
    function formatMinutesToThaiTimeLocal(minutes) {
      const hour = Math.floor(minutes / 60);
      const min = minutes % 60;
      
      return `${String(hour).padStart(2, '0')}:${String(min).padStart(2, '0')} น`;
    }

    // ===============================
    // ✅ เช็คสิทธิ์การจองฝั่ง Client (ไม่ต้องรอ Server)
    // ===============================
    function checkUserCanBookLocal(stopBooking, startBooking) {
      if (!stopBooking) {
        return { allowed: true };
      }

      // เวลาปัจจุบัน (เวลาไทย)
      const now = new Date();
      const currentHour = now.getHours();
      const currentMinute = now.getMinutes();
      const currentTimeInMinutes = currentHour * 60 + currentMinute;

      // แปลงเวลา stop/start
      const stopTime = parseThaiTimeLocal(stopBooking);
      const startTime = parseThaiTimeLocal(startBooking);

      if (stopTime === null) {
        return { allowed: true };
      }

      // เช็คว่าอยู่ในช่วงห้ามจองหรือไม่
      if (startTime !== null && startTime > stopTime) {
        // กรณี start > stop (เช่น stop=16:00, start=20:00)
        if (currentTimeInMinutes >= stopTime && currentTimeInMinutes < startTime) {
          const startStr = formatMinutesToThaiTimeLocal(startTime);
          return {
            allowed: false,
            message: 'ไม่สามารถจองได้ในขณะนี้',
            nextAvailable: `สามารถจองได้อีกครั้งเมื่อเวลา ${startStr}`
          };
        }
      } else if (startTime !== null && startTime < stopTime) {
        // กรณีข้ามวัน (เช่น stop=22:00, start=08:00)
        if (currentTimeInMinutes >= stopTime || currentTimeInMinutes < startTime) {
          const startStr = formatMinutesToThaiTimeLocal(startTime);
          return {
            allowed: false,
            message: 'ไม่สามารถจองได้ในขณะนี้',
            nextAvailable: `สามารถจองได้อีกครั้งเมื่อเวลา ${startStr}${currentTimeInMinutes >= stopTime ? ' (พรุ่งนี้)' : ''}`
          };
        }
      }

      return { allowed: true };
    }

