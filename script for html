    function adminLoadUsers() {
      const user = getCurrentUser();
      const adminId = user.id;
      const filter = document.getElementById('admin-filter')?.value || 'Waiting';
      const tbody = document.getElementById('admin-users-tbody');
      if (tbody) tbody.innerHTML = `<tr><td colspan="8" class="px-4 py-6 text-center text-slate-400">Loading...</td></tr>`;

      google.script.run
        .withSuccessHandler((res) => {
          if (!res?.success) {
            if (tbody) tbody.innerHTML = `<tr><td colspan="8" class="px-4 py-6 text-center text-red-600">${res?.message || 'โหลดไม่สำเร็จ'}</td></tr>`;
            return;
          }
          const users = res.users || [];
          if (!tbody) return;

          if (users.length === 0) {
            tbody.innerHTML = `<tr><td colspan="8" class="px-4 py-6 text-center text-slate-400">ไม่มีข้อมูล</td></tr>`;
            return;
          }

          tbody.innerHTML = users.map(u => {
            const fullName = `${u.firstName || ''} ${u.lastName || ''}`.trim();
            const status = String(u.status || '');
            const role = String(u.role || 'User');

            return `
              <tr class="hover:bg-slate-50">
                <td class="px-4 py-3 font-mono">${u.id}</td>
                <td class="px-4 py-3 font-semibold text-slate-700">${fullName || '-'}</td>
                <td class="px-4 py-3">${u.company || '-'}</td>
                <td class="px-4 py-3">${u.email || '-'}</td>
                <td class="px-4 py-3">${u.phone || '-'}</td>
                <td class="px-4 py-3 font-bold">${status || '-'}</td>
                <td class="px-4 py-3">${role}</td>
                <td class="px-4 py-3 text-center">
