    function handleResetPassword() {
      const id = document.getElementById('fp-id')?.value?.trim();
      const oldPass = document.getElementById('fp-oldpass')?.value || '';
      const newPass = document.getElementById('fp-pass')?.value || '';
      const newPass2 = document.getElementById('fp-pass2')?.value || '';

      if (!id || !oldPass || !newPass || !newPass2) {
