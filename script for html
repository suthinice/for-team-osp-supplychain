      // โหลดข้อมูล booking
      google.script.run
        .withSuccessHandler((res) => {
          // ✅ ซ่อน Loading
          hideLoadingPopup();

          if (!res?.success) {
            showToast('error', 'โหลดไม่สำเร็จ', res?.message || 'ไม่พบข้อมูล');
            return;
          }

          const b = res.booking;

          // ✅ Helper function เพื่อป้องกัน null
          const setValueIfExists = (id, value) => {
            const el = document.getElementById(id);
            if (el) {
              el.value = value || '';
            } else {
              console.warn(`⚠️ Element not found: #${id}`);
            }
          };

          // เติมข้อมูลลงฟอร์ม
          setValueIfExists('edit-uuid', b.uuid);
          setValueIfExists('edit-service-type', currentService);
          setValueIfExists('edit-job-status', b.jobStatus);
          setValueIfExists('edit-job-date', b.date);
          setValueIfExists('edit-shipment-no', b.shipmentNo);
          setValueIfExists('edit-time', b.time);
          setValueIfExists('edit-truck-type', b.truckType);
          setValueIfExists('edit-truck-no', b.truckNo);
          setValueIfExists('edit-trailer-no', b.trailerNo);
          setValueIfExists('edit-vendor', b.vendor);
          setValueIfExists('edit-vendor-other', b.vendorOther);
          setValueIfExists('edit-phone', b.phone);
          setValueIfExists('edit-remark', b.remark);

          // ✅ โหลดรายชื่อ Customer แล้วเลือกค่าที่มี
          loadCustomerDropdownForEdit(b.customerName);

          // แสดง/ซ่อนพ่วง + vendor อื่นๆ
          if (typeof handleEditTruckTypeChange === 'function') {
            handleEditTruckTypeChange();
          }
          if (typeof handleEditVendorChange === 'function') {
            handleEditVendorChange();
          }

          // เปิด modal
          const modal = document.getElementById('edit-booking-modal');
          if (modal) {
            modal.classList.remove('hidden');
            document.body.classList.add('overflow-hidden');
          } else {
            console.error('❌ Modal #edit-booking-modal not found!');
            showToast('error', 'เกิดข้อผิดพลาด', 'ไม่พบ Modal แก้ไข');
            return;
          }

          if (typeof lucide !== 'undefined') lucide.createIcons();
        })
        .withFailureHandler((err) => {
          // ✅ ซ่อน Loading
          hideLoadingPopup();
          
          showToast('error', 'เกิดข้อผิดพลาด', err?.message || err);
        })
        .getBookingByUuid(currentService, uuid);
    }

