    /**
     * กรองตารางตามคำค้นหา (Shipment หรือทะเบียนรถ)
     */
    function filterNumberCheckinTable() {
      const searchInput = document.getElementById('number-checkin-search-input');
      if (!searchInput) return;
      
      const searchTerm = searchInput.value.toLowerCase().trim();
      
      // ถ้าไม่มีคำค้นหา แสดงทั้งหมด
      if (!searchTerm) {
        if (window.numberCheckinData) {
          renderNumberCheckinRows(window.numberCheckinData);
        }
        return;
      }
      
      // กรองข้อมูล
      if (window.numberCheckinData) {
        const filtered = window.numberCheckinData.filter(item => {
          const shipment = String(item.colC || '').toLowerCase();
          const licenseM = String(item.colM || '').toLowerCase();
          const licenseN = String(item.colN || '').toLowerCase();
          
          return shipment.includes(searchTerm) || 
                licenseM.includes(searchTerm) || 
                licenseN.includes(searchTerm);
        });
        
        renderNumberCheckinRows(filtered);
        
        // แสดงข้อความถ้าไม่พบ
        if (filtered.length === 0) {
          const tbody = document.getElementById('number-checkin-table-body');
          if (tbody) {
            tbody.innerHTML = `
              <tr>
                <td colspan="8" class="text-center py-8 text-slate-400">
                  <i data-lucide="search-x" class="w-12 h-12 mx-auto mb-2 opacity-50"></i>
