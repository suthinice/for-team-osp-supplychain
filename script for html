    function fetchCapacity(done) {
      // ✅ รีเซ็ตตัวกรองเมื่อเปลี่ยนวัน
      resetFilters();
    
      const bookDateEl = document.getElementById('book-date');
      const container = document.getElementById('slots-container');
      if (!bookDateEl || !container) {
        if (typeof done === 'function') done();
        return;
      }

      const date = normalizeDate(bookDateEl.value);
      console.log('📅 date:', date, '| currentService:', currentService); // ✅ เพิ่มตรงนี้

      // แสดงสถานะกำลังโหลด
      container.innerHTML =
        '<div class="col-span-full text-center py-10 text-slate-400 text-sm">กำลังโหลดข้อมูล...</div>';

      // กัน error ถ้าฟังก์ชันยังไม่มีจริง ๆ
      if (typeof closeForm === 'function') closeForm();
      if (typeof closeDetails === 'function') closeDetails();

      google.script.run
        .withSuccessHandler(function (response) {
          console.log('📦 Response keys:', response ? Object.keys(response) : 'null');
          console.log('📋 rawData length:', response?.rawData?.length, '| capacities keys:', response?.capacities ? Object.keys(response.capacities).length : 0);
          
          const capacities = (response && response.capacities) ? response.capacities : {};
          cachedBookings = (response && response.rawData) ? response.rawData : [];
          // ... โค้ดเดิม

          // ✅ (เพิ่ม) เก็บวันที่ที่โหลดล่าสุด เพื่อใช้กับ “ดู Slot ทั้งหมด”
          cachedBookingDate = date;

          // ✅ ถ้า server ส่ง capacities ว่าง ก็ยังให้กล่องขึ้น
          const finalCaps = (capacities && Object.keys(capacities).length)
            ? capacities
            : Object.fromEntries(getTimeSlots().map(s => [s, { totalPallets: 0, count: 0, max: 96 }]));

          // ✅ สำคัญ: เก็บไว้ใช้ตอนเปิด modal (เพื่อเช็คว่าเต็มไหม)
          currentCapacities = finalCaps;

          renderSlots(finalCaps);

          if (typeof lucide !== 'undefined') lucide.createIcons();

          // ✅ (เพิ่ม) callback หลังโหลดเสร็จ
          if (typeof done === 'function') done();
        })
        .withFailureHandler(function (err) {
          console.error('❌ Failure:', JSON.stringify(err)); // ✅ แก้บรรทัดนี้
          container.innerHTML =
            '<div class="col-span-full text-center py-10 text-red-600 text-sm">' +
            'โหลดช่วงเวลาไม่สำเร็จ: ' + (err && err.message ? err.message : err) +
            '</div>';

          // กันพัง: ถ้าโหลดไม่ได้ ให้เคลียร์ currentCapacities
          currentCapacities = {};

          // ✅ (เพิ่ม) callback กันค้าง
          if (typeof done === 'function') done();
        })
        .getSlotCapacities(currentService, date);
    }


