    function normalizeDate(dateStr) {
      // MM/DD/YYYY -> YYYY-MM-DD
      if (/^\d{2}\/\d{2}\/\d{4}$/.test(dateStr)) {
        const [m, d, y] = dateStr.split('/');
        return `${y}-${m}-${d}`;
      }
      return dateStr; // ถ้าเป็น YYYY-MM-DD อยู่แล้วก็ส่งต่อได้เลย
    }

