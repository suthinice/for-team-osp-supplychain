    // ===============================
    function openEditBookingModal(uuid) {
      if (!uuid) return;

      // ✅ เช็คว่าเป็น Admin หรือไม่
      if (!isAdminUser()) {
        showToast('error', 'ไม่มีสิทธิ์', 'เฉพาะ Admin เท่านั้นที่แก้ไขได้');
        return;
      }

      // ✅ แสดง Loading
