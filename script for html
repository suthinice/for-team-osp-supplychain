    // ===============================
    // ✅ Export ข้อมูลเป็น Excel (Admin Only)
    // ===============================
    function exportToExcel() {
      // ✅ เช็คว่าเป็น Admin หรือไม่
      const user = getCurrentUser();
      const role = String(user.role || '').trim().toLowerCase();
      
      if (role !== 'admin') {
        showToast('error', 'ไม่มีสิทธิ์', 'เฉพาะ Admin เท่านั้นที่สามารถ Export ได้');
        return;
      }

      const tbody = document.getElementById('details-tbody');
      if (!tbody) {
        showToast('warn', 'ไม่มีข้อมูล', 'กรุณาเลือกดูข้อมูลก่อน Export');
        return;
      }

      // ดึงเฉพาะแถวที่แสดงอยู่
      const rows = Array.from(tbody.querySelectorAll('tr')).filter(row => row.style.display !== 'none');

      if (rows.length === 0) {
        showToast('warn', 'ไม่มีข้อมูล', 'ไม่มีข้อมูลให้ Export');
        return;
      }

      // ✅ เช็คว่ามี XLSX library หรือไม่
      if (typeof XLSX === 'undefined') {
        showToast('error', 'ไม่พบ Library', 'กรุณารีโหลดหน้าเว็บแล้วลองใหม่');
        console.error('❌ XLSX library not loaded');
        return;
      }

      // เตรียมข้อมูล
      const exportData = [];

      // Header
      exportData.push([
        'วันที่จอง',
        'ช่วงเวลา',
        'สถานะงาน',
        'Shipment',
        'Pallet',
        'ประเภทรถ',
        'ทะเบียนรถ',
        'ทะเบียนพ่วง',
        'บริษัทขนส่ง',
        'เบอร์ติดต่อ',
        'ชื่อลูกค้า',
        'รายละเอียด'
      ]);

      // Data rows
      rows.forEach(row => {
        const uuid = row.dataset.uuid || '';
        const booking = cachedBookings.find(b => (b.uuid || b.id) === uuid);
        
        if (booking) {
          const bookingDate = booking.date || '';
          const timeSlot = booking.time || '-';
          
          exportData.push([
            bookingDate,
            timeSlot,
            booking.jobStatus || booking.status || '-',
            booking.shipment || booking.shipmentNo || '-',
            booking.pallets || booking.totalPallets || 0,
            booking.truckType || '-',
            booking.truckNo || '-',
            booking.trailerNo || '-',
            booking.company || booking.vendor || '-',
            booking.phone || '-',
            booking.customerName || '-',
            booking.remark || '-'
          ]);
        }
      });

      try {
        // แสดง Loading
        showLoadingPopup('กำลัง Export...', 'กรุณารอสักครู่');

        // สร้าง Workbook
        const wb = XLSX.utils.book_new();
        const ws = XLSX.utils.aoa_to_sheet(exportData);

        // กำหนดความกว้าง Column
        ws['!cols'] = [
          { wch: 12 }, // วันที่จอง
          { wch: 18 }, // ช่วงเวลา
          { wch: 20 }, // สถานะงาน
          { wch: 25 }, // Shipment
          { wch: 10 }, // Pallet
          { wch: 15 }, // ประเภทรถ
          { wch: 15 }, // ทะเบียนรถ
          { wch: 15 }, // ทะเบียนพ่วง
          { wch: 15 }, // บริษัทขนส่ง
          { wch: 15 }, // เบอร์ติดต่อ
          { wch: 25 }, // ชื่อลูกค้า
          { wch: 30 }  // รายละเอียด
        ];

        // เพิ่ม Worksheet เข้า Workbook
        XLSX.utils.book_append_sheet(wb, ws, 'Bookings');

        // สร้างชื่อไฟล์
        const bookDate = document.getElementById('book-date')?.value || '';
        const dateStr = bookDate ? `_${bookDate.replace(/-/g, '')}` : '';
        const companyFilter = currentCompanyFilter ? `_${currentCompanyFilter}` : '';
        const serviceType = currentService || 'All';
        const timestamp = new Date().toLocaleString('th-TH', {
          year: 'numeric',
          month: '2-digit',
          day: '2-digit',
          hour: '2-digit',
          minute: '2-digit'
        }).replace(/[/:]/g, '').replace(/\s/g, '_');
        
        const filename = `Booking_${serviceType}${dateStr}${companyFilter}_${timestamp}.xlsx`;

        // ดาวน์โหลดไฟล์
        XLSX.writeFile(wb, filename);

        // ซ่อน Loading
        setTimeout(() => {
          hideLoadingPopup();
          showCenterToast('success', 'Export สำเร็จ', `ดาวน์โหลดไฟล์แล้ว: ${filename}`);
        }, 500);

      } catch (error) {
        hideLoadingPopup();
        console.error('Export error:', error);
        showToast('error', 'Export ไม่สำเร็จ', error.message || 'เกิดข้อผิดพลาด');
      }
    }

