    // ===============================
    // ✅ CONFIRM LOADING NEW
    // ===============================

    function initConfirmLoadingNewPage() {
      const today = getLocalISODateString();
      const dateEl = document.getElementById('confirm-loading-new-date');
      if (dateEl && !dateEl.value) dateEl.value = today;
      loadConfirmLoadingNewData();
    }

    function loadConfirmLoadingNewData() {
      const serviceFilter = document.getElementById('confirm-loading-new-service')?.value || 'ALL';
      const dateFilter = document.getElementById('confirm-loading-new-date')?.value || getLocalISODateString();
      const tbody = document.getElementById('confirm-loading-new-tbody');

      if (tbody) tbody.innerHTML = `<tr><td colspan="7" class="px-4 py-8 text-center text-slate-400">กำลังโหลด...</td></tr>`;

      google.script.run
        .withSuccessHandler((res) => {
          if (!res?.success) {
            if (tbody) tbody.innerHTML = `<tr><td colspan="7" class="px-4 py-8 text-center text-red-400">${res?.message || 'โหลดไม่สำเร็จ'}</td></tr>`;
            return;
          }
          renderConfirmLoadingNewTable(res.data, res.completedToday);
        })
        .withFailureHandler((err) => {
          if (tbody) tbody.innerHTML = `<tr><td colspan="7" class="px-4 py-8 text-center text-red-400">เกิดข้อผิดพลาด</td></tr>`;
        })
        .getConfirmLoadingData(serviceFilter, dateFilter);
    }

    function renderConfirmLoadingNewTable(data, completedToday) {
      const tbody = document.getElementById('confirm-loading-new-tbody');
      const pendingCount = document.getElementById('confirm-loading-new-pending-count');
      const completedCount = document.getElementById('confirm-loading-new-completed-count');

      if (pendingCount) pendingCount.textContent = data.length;
      if (completedCount) completedCount.textContent = completedToday || 0;

      if (!tbody) return;

      if (data.length === 0) {
        tbody.innerHTML = `<tr><td colspan="6" class="px-4 py-8 text-center text-slate-400">ไม่มีรายการรอยืนยัน</td></tr>`;
        return;
      }

      tbody.innerHTML = data.map(item => `
        <tr class="hover:bg-slate-50 transition">
          <td class="px-4 py-3">
            <span class="px-2 py-1 rounded-full text-[10px] font-black bg-blue-100 text-blue-700">${escapeHtml(item.serviceType)}</span>
          </td>
          <td class="px-4 py-3 font-mono text-slate-700">${escapeHtml(String(item.colC || '-'))}</td>
          <td class="px-4 py-3 text-slate-600">${escapeHtml(String(item.colD || '-'))}</td>
          <td class="px-4 py-3 text-slate-600">${escapeHtml(String(item.colM || '-'))}</td>
          <td class="px-4 py-3 text-slate-600">${escapeHtml(String(item.colF || '-'))}</td>
          <td class="px-4 py-3 text-center">
            <button onclick="confirmLoadingNew('${item.sheetId}', ${item.rowIndex}, '${item.serviceType}')"
              class="px-3 py-1.5 bg-blue-600 text-white text-xs font-bold rounded-lg hover:bg-blue-700 transition">
              ยืนยัน
            </button>
          </td>
        </tr>
      `).join('');

      if (typeof lucide !== 'undefined') lucide.createIcons();
    }

    function confirmLoadingNew(sheetId, rowIndex, serviceType) {
      // ✅ แสดง Popup แทน confirm()
      const popup = document.getElementById('confirm-loading-new-popup');
      if (popup) {
        popup.classList.remove('hidden');
        popup.classList.add('flex');

        // ✅ เก็บค่าไว้ใช้ตอนกดยืนยัน
        popup.dataset.sheetId = sheetId;
        popup.dataset.rowIndex = rowIndex;
        popup.dataset.serviceType = serviceType;
      }
    }

    function closeConfirmLoadingNewPopup() {
      const popup = document.getElementById('confirm-loading-new-popup');
      if (popup) {
        popup.classList.add('hidden');
        popup.classList.remove('flex');
      }
    }

    function executeConfirmLoadingNew() {
      const popup = document.getElementById('confirm-loading-new-popup');
      if (!popup) return;

      const sheetId = popup.dataset.sheetId;
      const rowIndex = Number(popup.dataset.rowIndex);

      closeConfirmLoadingNewPopup();
      showLoadingPopup('กำลังยืนยัน...', 'กรุณารอสักครู่');

      google.script.run
        .withSuccessHandler((res) => {
          hideLoadingPopup();
          if (res?.success) {
            showToast('success', 'ยืนยันสำเร็จ', res.message);
            loadConfirmLoadingNewData();
          } else {
            showToast('error', 'ไม่สำเร็จ', res?.message || 'เกิดข้อผิดพลาด');
          }
        })
        .withFailureHandler((err) => {
          hideLoadingPopup();
          showToast('error', 'เกิดข้อผิดพลาด', err?.message || err);
        })
        .confirmLoadingNewTransaction(sheetId, rowIndex);
    }

    // ===============================
    // ✅ DAILY DASHBOARD
    // ===============================

    let dailyAgentChart = null;

    function toggleDashboardMenu() {
      const submenu = document.getElementById('nav-dashboard-submenu');
      const arrow = document.getElementById('nav-dashboard-arrow');
      if (!submenu) return;

      const isHidden = submenu.classList.contains('hidden');
      submenu.classList.toggle('hidden', !isHidden);
      if (arrow) arrow.style.transform = isHidden ? 'rotate(180deg)' : '';
    }

    function initDailyDashboard() {
      const today = getLocalISODateString();

      // ✅ วันที่ 1 ของเดือนปัจจุบัน
      const now = new Date();
      const y = now.getFullYear();
      const m = String(now.getMonth() + 1).padStart(2, '0');
      const firstDayStr = `${y}-${m}-01`;

      const startEl = document.getElementById('daily-dash-start');
      const endEl = document.getElementById('daily-dash-end');
      if (startEl) startEl.value = firstDayStr; // ✅ วันที่ 1 ของเดือน
      if (endEl) endEl.value = today;           // ✅ วันปัจจุบัน
      loadDailyDashboard();
    }

    function loadDailyDashboard() {
      const startDate = document.getElementById('daily-dash-start')?.value || getLocalISODateString();
      const endDate = document.getElementById('daily-dash-end')?.value || getLocalISODateString();

      const wrap = document.getElementById('daily-agent-chart-wrap');
      const tbody = document.getElementById('daily-agent-tbody');

      if (wrap) wrap.innerHTML = `<div class="animate-spin w-8 h-8 border-2 border-indigo-600 border-t-transparent rounded-full"></div>`;
      if (tbody) tbody.innerHTML = `<tr><td colspan="3" class="px-4 py-8 text-center text-slate-400">กำลังโหลด...</td></tr>`;

      google.script.run
        .withSuccessHandler((res) => {
          if (!res?.success) {
            if (wrap) wrap.innerHTML = `<p class="text-red-400 text-sm">${res?.message || 'โหลดไม่สำเร็จ'}</p>`;
            return;
          }
          renderDailyAgentChart(res.data);
        })
        .withFailureHandler((err) => {
          if (wrap) wrap.innerHTML = `<p class="text-red-400 text-sm">เกิดข้อผิดพลาด</p>`;
        })
        .getDailyDashboardData(startDate, endDate);
    }

    function renderDailyAgentChart(data) {
      const wrap = document.getElementById('daily-agent-chart-wrap');
      const tbody = document.getElementById('daily-agent-tbody');

      if (!data || data.length === 0) {
        if (wrap) wrap.innerHTML = `<p class="text-slate-400 text-sm">ไม่มีข้อมูลในช่วงวันที่เลือก</p>`;
        if (tbody) tbody.innerHTML = `<tr><td colspan="3" class="px-4 py-8 text-center text-slate-400">ไม่มีข้อมูล</td></tr>`;
        return;
      }

      const total = data.reduce((s, d) => s + d.value, 0);
      const labels = data.map(d => d.label);
      const values = data.map(d => d.value);

      // ✅ สร้าง Canvas
      if (wrap) {
        wrap.innerHTML = `<canvas id="daily-agent-canvas" style="max-height:256px;"></canvas>`;
      }

      // ✅ ลบ Chart เก่า
      if (dailyAgentChart) {
        dailyAgentChart.destroy();
        dailyAgentChart = null;
      }

      const ctx = document.getElementById('daily-agent-canvas')?.getContext('2d');
      if (!ctx) return;

      const colors = [
        '#6366f1','#8b5cf6','#ec4899','#f43f5e','#f97316',
        '#eab308','#22c55e','#14b8a6','#0ea5e9','#3b82f6'
      ];

      dailyAgentChart = new Chart(ctx, {
        type: 'doughnut',
        plugins: [ChartDataLabels], // ✅ เพิ่ม
        data: {
          labels,
          datasets: [{
            data: values,
            backgroundColor: colors.slice(0, data.length),
            borderWidth: 2,
            borderColor: '#fff'
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: true,
          plugins: {
            legend: { position: 'bottom', labels: { font: { size: 11 }, padding: 12 } },
            tooltip: {
              callbacks: {
                label: (ctx) => ` ${ctx.label}: ${ctx.raw.toLocaleString()} ขวด (${Math.round(ctx.raw / total * 100)}%)`
              }
            },
            datalabels: { // ✅ เพิ่ม
              color: '#fff',
              font: { size: 11, weight: 'bold' },
              formatter: (value, ctx) => {
                const pct = Math.round(value / total * 100);
                if (pct < 5) return ''; // ✅ ซ่อนถ้า slice เล็กเกินไป
                return `${pct}%`;
              },
              anchor: 'center',
              align: 'center'
            }
          }
        }
      });

      // ✅ Table Summary
      if (tbody) {
        tbody.innerHTML = data.map((d, i) => `
          <tr class="hover:bg-slate-50">
            <td class="px-4 py-2.5 flex items-center gap-2">
              <span class="w-3 h-3 rounded-full flex-shrink-0" style="background:${colors[i % colors.length]}"></span>
              <span class="text-slate-700 font-medium">${escapeHtml(d.label)}</span>
            </td>
            <td class="px-4 py-2.5 text-right font-bold text-slate-700">${d.value.toLocaleString()}</td>
            <td class="px-4 py-2.5 text-right text-slate-500">${Math.round(d.value / total * 100)}%</td>
          </tr>
        `).join('') + `
          <tr class="bg-slate-50 border-t-2 border-slate-200">
            <td class="px-4 py-2.5 font-bold text-slate-700">รวม</td>
            <td class="px-4 py-2.5 text-right font-black text-slate-800">${total.toLocaleString()}</td>
            <td class="px-4 py-2.5 text-right font-bold text-slate-700">100%</td>
          </tr>
        `;
      }
    }

    function formatNum(n) {
      if (n >= 1000000) return (n / 1000000).toFixed(1).replace(/\.0$/, '') + 'M';
      if (n >= 1000) return (n / 1000).toFixed(1).replace(/\.0$/, '') + 'K';
      return n.toLocaleString();
    }

    function loadDailyDashboard() {
      const startDate = document.getElementById('daily-dash-start')?.value || getLocalISODateString();
      const endDate = document.getElementById('daily-dash-end')?.value || getLocalISODateString();

      const wrap = document.getElementById('daily-agent-chart-wrap');
      const tbody = document.getElementById('daily-agent-tbody');

      if (wrap) wrap.innerHTML = `<div class="animate-spin w-8 h-8 border-2 border-indigo-600 border-t-transparent rounded-full"></div>`;
      if (tbody) tbody.innerHTML = `<tr><td colspan="3" class="px-4 py-8 text-center text-slate-400">กำลังโหลด...</td></tr>`;

      // ✅ Reset Cards
      ['card-so-total','card-sent','card-wait-billing','card-wait-shipment','card-wait-do',
      'card-today-shipment','card-today-qty','card-custc-qty','card-ay-qty','card-rj-qty'
      ].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.textContent = '-';
      });

      google.script.run
        .withSuccessHandler((res) => {
          if (!res?.success) {
            if (wrap) wrap.innerHTML = `<p class="text-red-400 text-sm">${res?.message || 'โหลดไม่สำเร็จ'}</p>`;
            return;
          }

          // ✅ Render Cards
          const c = res.cards || {};
          const setCard = (id, val) => {
            const el = document.getElementById(id);
            if (el) el.textContent = formatNum(val || 0);
          };
          setCard('card-so-total',      c.soTotal);
          setCard('card-sent',          c.sent);
          setCard('card-wait-billing',  c.waitBilling);
          setCard('card-wait-shipment', c.waitShipment);
          setCard('card-wait-do',       c.waitDO);
          setCard('card-today-shipment',c.todayShipment);
          setCard('card-today-qty',     c.todayQty);
          setCard('card-custc-qty',     c.custcQty);
          setCard('card-ay-qty',        c.ayQty);
          setCard('card-rj-qty',        c.rjQty);

          // ✅ Render Chart
          renderDailyAgentChart(res.data);

          // ✅ Render Today Table
          renderTodayTable(res.todayTable || []);
        })
        .withFailureHandler((err) => {
          if (wrap) wrap.innerHTML = `<p class="text-red-400 text-sm">เกิดข้อผิดพลาด</p>`;
        })
        .getDailyDashboardData(startDate, endDate);
    }

    function renderTodayTable(data) {
      const wrap = document.getElementById('daily-today-table-wrap');
      if (!wrap) return;

      if (data.length === 0) {
        wrap.innerHTML = `<tr><td colspan="4" class="px-4 py-8 text-center text-slate-400">ไม่มีข้อมูลวันนี้</td></tr>`;
        return;
      }

      // ✅ คำนวณ Total
      const totalQty = data.reduce((s, r) => s + (Number(r.qty) || 0), 0);

      wrap.innerHTML = data.map(r => {
        const isCompleted = r.status === 'Completed';
        return `
          <tr class="${isCompleted ? 'bg-green-50' : 'hover:bg-slate-50'} border-b border-slate-100">
            <td class="px-4 py-2.5 text-slate-700 font-medium">${escapeHtml(r.shopName || '-')}</td>
            <td class="px-4 py-2.5 text-slate-600 whitespace-nowrap">${escapeHtml(r.timeSlot || '-')}</td>
            <td class="px-4 py-2.5 text-right font-bold text-slate-700">${Number(r.qty || 0).toLocaleString()}</td>
            <td class="px-4 py-2.5 text-center">
              ${isCompleted
                ? `<span class="px-2 py-1 rounded-full text-[10px] font-black bg-green-100 text-green-700 border border-green-200">Completed</span>`
                : `<span class="px-2 py-1 rounded-full text-[10px] font-black bg-slate-100 text-slate-500">${escapeHtml(r.status || '-')}</span>`
              }
            </td>
          </tr>
        `;
      }).join('') + `
        <tr class="bg-slate-800 text-white">
          <td colspan="2" class="px-4 py-2.5 font-bold">รวมทั้งหมด</td>
          <td class="px-4 py-2.5 text-right font-black">${totalQty.toLocaleString()}</td>
          <td></td>
        </tr>
      `;
    }


  </script>
