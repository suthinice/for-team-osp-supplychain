    function applyBookingDateWindow() {
      // ใช้เวลาไทย
      const now = new Date();
      const currentHour = parseInt(
        now.toLocaleTimeString('en-US', {
          hour: '2-digit',
          hour12: false,
          timeZone: 'Asia/Bangkok'
        }),
        10
      );

      // ===== minDate =====
      let minDate = new Date();

      // ✅ AY Export: จองวันปัจจุบันได้ตลอด ไม่มี cutoff 09:00
      const isAyExport = (currentService === 'AY_EXPORT');

      if (!isAyExport && currentHour >= 9) {
        minDate.setDate(minDate.getDate() + 1);
      }

      const yyyy_min = minDate.getFullYear();
      const mm_min = String(minDate.getMonth() + 1).padStart(2, '0');
      const dd_min = String(minDate.getDate()).padStart(2, '0');
      const minDateString = `${yyyy_min}-${mm_min}-${dd_min}`;

      // ===== maxDate (4 วันรวม minDate) =====
      let maxDate = new Date(minDate);
      maxDate.setDate(maxDate.getDate() + 3);

      const maxYYYY = maxDate.getFullYear();
      const maxMM = String(maxDate.getMonth() + 1).padStart(2, '0');
      const maxDD = String(maxDate.getDate()).padStart(2, '0');
      const maxDateString = `${maxYYYY}-${maxMM}-${maxDD}`;

      // ✅ ข้อความช่วงวันที่ที่จองได้ (ไว้ใช้ทั้ง notice + popup)
      const rangeText = `โปรดจอง ${dd_min}/${mm_min}/${yyyy_min} - ${maxDD}/${maxMM}/${maxYYYY}`;

      // ✅ 1) คุมช่วงจองจริงเฉพาะ job-date (ใน modal)
      const jobDateEl = document.getElementById('job-date');
      if (jobDateEl) {
        jobDateEl.min = minDateString;
        jobDateEl.max = maxDateString;

        const v = jobDateEl.value;
        if (!v || v < minDateString || v > maxDateString) {
          jobDateEl.value = minDateString;
        }
      }

      // ✅ 2) แบบ A: book-date เลือกย้อนหลังได้ (ไม่ตั้ง min/max)
      const bookDateEl = document.getElementById('book-date');
      if (bookDateEl) {
        bookDateEl.removeAttribute('min');
        bookDateEl.removeAttribute('max');
      }

      // ✅ 3) Dynamic Notice
      const rangeEl = document.getElementById('bookingDateRange');
      if (rangeEl) {
        rangeEl.textContent = rangeText;
        rangeEl.classList.remove('hidden');
      }

      // ✅ return ให้ popup ใช้ได้
      return { minDateString, maxDateString, rangeText };
    }

