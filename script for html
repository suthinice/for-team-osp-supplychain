    /**
     * ตั้งค่าช่วงวันที่ = สัปดาห์นี้ (จันทร์ - วันนี้)
     */
    function setThisWeekRange() {
      const today = new Date();
      const dayOfWeek = today.getDay(); // 0=อาทิตย์, 1=จันทร์, ...
      
      // หาวันจันทร์
      const monday = new Date(today);
      const diff = dayOfWeek === 0 ? -6 : 1 - dayOfWeek; // ถ้าวันอาทิตย์ ให้ย้อนกลับ 6 วัน
      monday.setDate(today.getDate() + diff);
      
      const startEl = document.getElementById('dash-start-date');
      const endEl = document.getElementById('dash-end-date');
      const monthEl = document.getElementById('dash-month');
      
      if (startEl) startEl.value = getLocalISODateString(monday);
      if (endEl) endEl.value = getLocalISODateString(today);
      if (monthEl) monthEl.value = '';
    }

