    // helper: badge สีสถานะ (ไม่มี icon)
    function getStatusBadge(jobStatus = '') {
      const s = String(jobStatus || '').trim();

      // ปรับคำตามที่คุณใช้จริง
      const isOut = s.includes('รับสินค้าออกจากคลัง');
      const isIn  = s.includes('ส่งสินค้าเข้าคลัง');

      const base = 'inline-flex items-center justify-center px-3 py-1 rounded-full text-[11px] font-black';
      if (isOut) return `<span class="${base} bg-emerald-50 text-emerald-700 border border-emerald-200">รับสินค้าออกจากคลัง</span>`;
      if (isIn)  return `<span class="${base} bg-blue-50 text-blue-700 border border-blue-200">ส่งสินค้าเข้าคลัง</span>`;
      return `<span class="${base} bg-slate-50 text-slate-600 border border-slate-200">${s || '-'}</span>`;
    }

    // helper: badge บริษัท
    function getCompanyBadge(company='') {
      const c = String(company || '').trim().toUpperCase();
      const base = 'inline-flex items-center px-3 py-1 rounded-full text-[11px] font-black border';

      if (c === 'DHL') return `<span class="${base} bg-yellow-50 text-yellow-800 border-yellow-200">DHL</span>`;
      if (c === 'TVN' || c === 'TNV') return `<span class="${base} bg-purple-50 text-purple-700 border-purple-200">TVN</span>`;
      if (c === 'TRL') return `<span class="${base} bg-sky-50 text-sky-700 border-sky-200">TRL</span>`;
      if (c === 'OSP') return `<span class="${base} bg-emerald-50 text-emerald-700 border-emerald-200">OSP</span>`;
      return `<span class="${base} bg-slate-50 text-slate-700 border-slate-200">${company || '-'}</span>`;
    }

