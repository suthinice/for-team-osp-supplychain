      // คุณเคยใช้ b.company ในตารางเดิม แต่บางที data อาจเป็น vendor
      return normalizeCompanyName(b.company || b.vendor || '');
    }

    function formatDateDMY(dateStr) {
      if (!dateStr) return '';
      const [y, m, d] = dateStr.split('-');
      return `${d}/${m}/${y}`;
