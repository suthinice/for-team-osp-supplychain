    function handleLoginSuccess(userData) {
      sessionStorage.setItem('isLoggedIn', 'true');
      sessionStorage.setItem('user', JSON.stringify(userData));

      // ✅ แสดง Loading ทันที
      showLoadingPopup('กำลังโหลดข้อมูล...', 'กรุณารอสักครู่');

      // ✅ นับว่าโหลดเสร็จกี่อัน (Holiday 5 service + SystemClose 1 = 6)
      let loadedCount = 0;
      const totalToLoad = 6;

      function checkAllLoaded() {
        loadedCount++;
        if (loadedCount >= totalToLoad) {
          hideLoadingPopup();
          showMainApp();
          initSidebar();
          showPage('dash');
          initFilters();
          if (typeof lucide !== 'undefined') lucide.createIcons();
        }
      }

      // ✅ Preload Holiday ทุก Service
      const services = ['AY', 'RJ', 'AY_EXPORT', 'AY_OEM', 'AY_FOC'];
      services.forEach(serviceType => {
        google.script.run
          .withSuccessHandler((res) => {
            if (res?.success) {
              const closedDates = new Set(
                (res.data || [])
                  .filter(h => h.status === 'ปิด')
                  .map(h => h.date)
              );
              cachedHolidays[serviceType] = closedDates;
            }
            checkAllLoaded();
          })
          .withFailureHandler(() => checkAllLoaded())
          .adminGetHolidays(userData.id, serviceType);
      });

      // ✅ Preload System Close
      google.script.run
        .withSuccessHandler((res) => {
          if (res?.success) cachedSystemClose = res.data;
          checkAllLoaded();
        })
        .withFailureHandler(() => checkAllLoaded())
        .getSystemCloseForUser();
    }

