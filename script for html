    function switchView(view) {
      const views = ['login', 'register', 'forgot'];
      views.forEach(v => {
        document.getElementById('view-' + v)?.classList.remove('active');
        document.getElementById('tab-' + v)?.classList.remove('bg-white', 'shadow-sm', 'text-slate-700');
        document.getElementById('tab-' + v)?.classList.add('text-slate-600');
      });

      document.getElementById('view-' + view)?.classList.add('active');
      const tab = document.getElementById('tab-' + view);
      if (tab) {
        tab.classList.add('bg-white', 'shadow-sm', 'text-slate-700');
        tab.classList.remove('text-slate-600');
      }

      hideAlert();
    }

    function showAlert(type, title, msg) {
      const el = document.getElementById('alert');
      const t = document.getElementById('alert-title');
      const m = document.getElementById('alert-msg');
      if (!el || !t || !m) return;

      el.className = 'fade-in mb-4 rounded-2xl border px-4 py-3 text-sm';

      if (type === 'success') {
        el.classList.add('bg-emerald-50', 'border-emerald-200');
        t.className = 'font-black text-emerald-700';
        m.className = 'text-emerald-700/80 mt-0.5';
      } else {
        el.classList.add('bg-rose-50', 'border-rose-200');
        t.className = 'font-black text-rose-700';
        m.className = 'text-rose-700/80 mt-0.5';
      }

      t.textContent = title;
      m.textContent = msg;
      el.classList.remove('hidden');
    }

    function hideAlert() {
      document.getElementById('alert')?.classList.add('hidden');
    }

    function setLoading(btnId, spinnerId, textId, isLoading, loadingText) {
      const btn = document.getElementById(btnId);
      const sp = document.getElementById(spinnerId);
      const tx = document.getElementById(textId);
      if (!btn || !sp || !tx) return;

      if (isLoading) {
        btn.classList.add('btn-disabled');
        sp.classList.remove('hidden');
        tx.textContent = loadingText || 'กำลังทำรายการ...';
      } else {
        btn.classList.remove('btn-disabled');
        sp.classList.add('hidden');
      }
    }

    let isLoggingIn = false;
    let loginRetryCount = 0;
    const MAX_LOGIN_RETRY = 1;
    const LOGIN_TIMEOUT_MS = 3000;

    function handleLogin(autoRetry = false) {
      if (isLoggingIn) return;
      isLoggingIn = true;

      const id = document.getElementById('login-id')?.value?.trim();
      const pass = document.getElementById('login-pass')?.value || '';

      if (!id || !pass) {
        isLoggingIn = false;
        showAlert('error', 'ข้อมูลไม่ครบ', 'กรุณากรอก ID และรหัสผ่าน');
        return;
      }

      hideAlert();
      setLoading('btn-login', 'login-spinner', 'login-btn-text', true, 'กำลังเข้าสู่ระบบ...');

      let finished = false;

      const finishWithError = (title, msg) => {
        finished = true;
        isLoggingIn = false;
        setLoading('btn-login', 'login-spinner', 'login-btn-text', false, 'เข้าสู่ระบบ');
        showAlert('error', title, msg);
      };

      const timeoutId = setTimeout(() => {
        if (finished) return;
        isLoggingIn = false;

        if (loginRetryCount < MAX_LOGIN_RETRY) {
          loginRetryCount++;
          setLoading('btn-login', 'login-spinner', 'login-btn-text', true, 'กำลังลองใหม่...');
          setTimeout(() => handleLogin(true), 300);
          return;
        }

        loginRetryCount = 0;
        finishWithError('เข้าสู่ระบบไม่สำเร็จ', 'การเชื่อมต่อช้าเกินไป กรุณากดเข้าสู่ระบบใหม่อีกครั้ง');
      }, LOGIN_TIMEOUT_MS);

      google.script.run
        .withSuccessHandler((res) => {
          if (finished) return;
          finished = true;
          clearTimeout(timeoutId);

          if (!res?.success) {
            loginRetryCount = 0;
            isLoggingIn = false;
            setLoading('btn-login', 'login-spinner', 'login-btn-text', false, 'เข้าสู่ระบบ');
            showAlert('error', 'เข้าสู่ระบบไม่สำเร็จ', res?.message || 'กรุณาลองใหม่');
            return;
          }

          loginRetryCount = 0;

          // ✅ บันทึก session (หายเมื่อปิด Browser)
          sessionStorage.setItem('user', JSON.stringify(res.user || {}));
          sessionStorage.setItem('isLoggedIn', 'true');

          // ✅ Preload Holiday Cache ทุก Service ตอน Login สำเร็จ
          preloadAllHolidays(res.user?.id);

          // แสดงหน้าหลัก
          showMainApp();
        })
        .withFailureHandler((err) => {
          if (finished) return;
          finished = true;
          clearTimeout(timeoutId);

          loginRetryCount = 0;
          isLoggingIn = false;
          setLoading('btn-login', 'login-spinner', 'login-btn-text', false, 'เข้าสู่ระบบ');
          showAlert('error', 'เชื่อมต่อไม่สำเร็จ', err?.message || String(err));
        })
        .loginUser(id, pass);
    }

    function handleRegister() {
      const id = document.getElementById('reg-id')?.value?.trim();
      const firstName = document.getElementById('reg-first')?.value?.trim();
      const lastName = document.getElementById('reg-last')?.value?.trim();
      const emailRaw = document.getElementById('reg-email')?.value ?? '';
      const phoneRaw = document.getElementById('reg-phone')?.value ?? '';
      const company = document.getElementById('reg-company')?.value?.trim();
      const department = document.getElementById('reg-department')?.value?.trim() || ''; // ✅ เพิ่ม

      const pass = document.getElementById('reg-pass')?.value || '';
      const pass2 = document.getElementById('reg-pass2')?.value || '';

      if (!id || !firstName || !lastName || !emailRaw.trim() || !phoneRaw.trim() || !company || !pass || !pass2) {
        showAlert('error', 'ข้อมูลไม่ครบ', 'กรุณากรอกข้อมูลให้ครบทุกช่อง');
        return;
      }

      // ✅ เพิ่มบรรทัดนี้หลัง validate ด้านบน
      if (company === 'OSP' && !department) {
        showAlert('error', 'ข้อมูลไม่ครบ', 'กรุณาเลือกแผนก');
        return;
      }

      const emailClean = String(emailRaw).replace(/\u00A0/g, ' ').trim().toLowerCase();

      const emailOk =
        emailClean.includes('@') &&
        emailClean.includes('.') &&
        !/\s/.test(emailClean);

      if (!emailOk) {
        showAlert('error', 'อีเมลไม่ถูกต้อง', 'กรุณากรอกอีเมลให้ถูกต้อง');
        return;
      }

      const phoneDigits = String(phoneRaw).replace(/\D/g, '');
      if (phoneDigits.length < 9) {
        showAlert('error', 'เบอร์โทรไม่ถูกต้อง', 'กรุณากรอกเบอร์โทรให้ถูกต้อง');
        return;
      }

      if (pass.length < 6) {
        showAlert('error', 'รหัสผ่านสั้นเกินไป', 'กรุณาตั้งรหัสผ่านอย่างน้อย 6 ตัว');
        return;
      }
      if (pass !== pass2) {
        showAlert('error', 'รหัสผ่านไม่ตรงกัน', 'กรุณายืนยันรหัสผ่านให้ตรงกัน');
        return;
      }

      hideAlert();
      setLoading('btn-register', 'reg-spinner', 'reg-btn-text', true, 'กำลังสมัครสมาชิก...');

      google.script.run
        .withSuccessHandler(function (res) {
          setLoading('btn-register', 'reg-spinner', 'reg-btn-text', false, 'สมัครสมาชิก');

          if (res && res.success) {
            showAlert('success', 'สมัครสมาชิกสำเร็จ', 'สถานะ: Waiting รอผู้ดูแลอนุมัติ');

            setTimeout(() => {
              switchView('login');
              document.getElementById('login-id').value = id;
              document.getElementById('login-pass').value = '';
            }, 700);
          } else {
            showAlert('error', 'สมัครสมาชิกไม่สำเร็จ', (res && res.message) ? res.message : 'ไม่สามารถสมัครได้');
          }
        })
        .withFailureHandler(function (err) {
          setLoading('btn-register', 'reg-spinner', 'reg-btn-text', false, 'สมัครสมาชิก');
          showAlert('error', 'เชื่อมต่อไม่สำเร็จ', err && err.message ? err.message : String(err));
        })
        .registerUser({
          id,
          password: pass,
          company,
          department, // ✅ เพิ่ม
          firstName,
          lastName,
          email: emailClean,
          phone: phoneDigits
        });
    }

