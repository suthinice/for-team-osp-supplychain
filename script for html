    function confirmBooking() {
      const btn = document.getElementById('btn-save');
      if (!btn) return;

      const user = getCurrentUser();

      // helper: ถ้าไม่มี showToast ให้ fallback เป็น alert
      const notify = (type, title, msg) => {
        if (typeof showToast === 'function') showToast(type, title, msg);
        else alert(`${title}\n${msg || ''}`);
      };

      // ✅ ใช้วันที่จากฟอร์มเป็นหลัก
      const jobDate = document.getElementById('job-date').value;
      const bookDate = document.getElementById('book-date').value;

      // ✅ กันพลาด: ถ้าผู้ใช้เลือก job-date แล้ว ให้ sync book-date ตาม
      if (jobDate && jobDate !== bookDate) {
        document.getElementById('book-date').value = jobDate;
      }

      // ✅ อ่านค่า shipment แล้วตรวจสอบตามเงื่อนไข (ตัวเลขล้วน, >=7, หาร 7 ลงตัว)
      const shipmentRaw = document.getElementById('shipment-no').value || "";
      const shipmentDigits = shipmentRaw.replace(/[^0-9]/g, ""); // ตัด , เว้นวรรค ออก

      if (shipmentDigits.length < 7 || shipmentDigits.length % 7 !== 0) {
        notify('warn', 'Shipment ไม่ถูกต้อง', 'เลข Shipment ต้องเป็นตัวเลขอย่างน้อย 7 หลัก และจำนวนหลักต้องหาร 7 ลงตัว (7, 14, 21, …)');
        return;
      }

      const data = {
        serviceType: currentService,
        date: jobDate,
        jobDate: jobDate,
        userId: user?.id || '',
        bookingPermission: user?.bookingPermission || '', // ✅ เพิ่มบรรทัดนี้
        time: document.getElementById('truck-time-select').value,
        jobStatus: document.getElementById('job-status').value,
        shipmentNo: shipmentRaw,
        truckNo: document.getElementById('truck-no').value,
        trailerNo: document.getElementById('trailer-no').value,
        truckType: document.getElementById('truck-type').value,
        vendor: document.getElementById('vendor').value,
        vendorOther: document.getElementById('vendor-other').value,
        phone: document.getElementById('phone').value,
        remark: document.getElementById('remark').value,
        customerName: document.getElementById('customer-name').value || '', // ✅ ไม่บังคับ (ว่างได้)
        driverName: document.getElementById('driver-name').value || ''  // ✅ เพิ่ม
      };

      // ✅ NEW: บังคับให้เลือก Dropdown (กันค่า default = "")
      if (!data.jobStatus) {
        notify('warn', 'ข้อมูลไม่ครบ', 'กรุณาเลือกสถานะงาน');
        return;
      }
      if (!data.truckType) {
        notify('warn', 'ข้อมูลไม่ครบ', 'กรุณาเลือกประเภทรถ');
        return;
      }
      if (!data.vendor) {
        notify('warn', 'ข้อมูลไม่ครบ', 'กรุณาเลือกบริษัทขนส่ง');
        return;
      }

      if (data.truckType === '22W' && !data.trailerNo) {
        notify('warn', 'ข้อมูลไม่ครบ', 'กรุณากรอกทะเบียนพ่วง สำหรับรถ 22W');
        return;
      }

      // ✅ validate พื้นฐาน (เพิ่ม driverName)
      if (!data.jobDate || !data.jobStatus || !data.truckType || !data.vendor || !data.shipmentNo || !data.truckNo || !data.phone || !data.driverName) {
        notify('warn', 'ข้อมูลไม่ครบ', 'กรุณากรอกข้อมูลที่สำคัญให้ครบถ้วน (ที่มีเครื่องหมาย *)');
        return;
      }

      if (data.vendor === 'อื่นๆ' && !data.vendorOther) {
        notify('warn', 'ข้อมูลไม่ครบ', 'กรุณาระบุชื่อบริษัทขนส่งอื่นๆ');
        return;
      }

      // ✅ เพิ่ม Timeout (30 วินาที)
      const timeoutId = setTimeout(() => {
        if (typeof hideLoadingPopup === 'function') {
          hideLoadingPopup();
        }
        notify('error', 'หมดเวลา', 'การบันทึกใช้เวลานานเกินไป กรุณาลองใหม่');
      }, 60000); // 30 วินาที

      // ✅ แสดง Loading
      if (typeof showLoadingPopup === 'function') {
        showLoadingPopup('กำลังบันทึกข้อมูล...', 'กรุณารอสักครู่');
      } else {
        btn.disabled = true;
        btn.innerHTML = '<span class="animate-spin border-2 border-white border-t-transparent rounded-full w-4 h-4 mr-2"></span> บันทึก...';
      }

      // ✅ เช็ค System Close และ Holiday จาก Cache ก่อนส่ง Server
      const today = getLocalISODateString();

      if (cachedSystemClose) {
        const closed = cachedSystemClose.some(r =>
          r.date === today && r.serviceKey === currentService && r.status === 'ปิด'
        );
        if (closed) {
          clearTimeout(timeoutId);
          hideLoadingPopup();
          showSystemClosePopup();
          return;
        }
      }

      // ✅ ถ้ามีสิทธิ์ตลอดเวลา ข้ามการเช็ค System Close และ Holiday
      if (!hasUnlimitedBooking()) {
        if (cachedSystemClose) {
          const closed = cachedSystemClose.some(r =>
            r.date === today && r.serviceKey === currentService && r.status === 'ปิด'
          );
          if (closed) {
            clearTimeout(timeoutId);
            hideLoadingPopup();
            showSystemClosePopup();
            return;
          }
        }

        if (cachedHolidays[currentService]) {
          if (cachedHolidays[currentService].has(data.jobDate)) {
            clearTimeout(timeoutId);
            hideLoadingPopup();
            showHolidayPopup(data.jobDate);
            return;
          }
        }
      }

      google.script.run
        .withSuccessHandler(function (response) {
          // ✅ ยกเลิก timeout
          clearTimeout(timeoutId);

          // ✅ ซ่อน Loading
          if (typeof hideLoadingPopup === 'function') {
            hideLoadingPopup();
          } else {
            btn.disabled = false;
            btn.innerHTML = '<span>บันทึกข้อมูล</span>';
          }

          if (response.success) {
            if (typeof showCenterToast === 'function') {
              showCenterToast('success', 'บันทึกสำเร็จ', 'ระบบบันทึกข้อมูลเรียบร้อย');
            } else {
              notify('success', 'บันทึกสำเร็จ', 'ระบบบันทึกข้อมูลเรียบร้อย');
            }

            if (typeof closeForm === 'function') closeForm();
            if (typeof fetchCapacity === 'function') fetchCapacity();
          } else {
            if (typeof showCenterToast === 'function') {
              showCenterToast('error', 'บันทึกไม่สำเร็จ', response.message);
            } else {
              notify('error', 'บันทึกไม่สำเร็จ', response.message);
            }
          }

        })
        .withFailureHandler(function (err) {
          // ✅ ยกเลิก timeout
          clearTimeout(timeoutId);

          // ✅ ซ่อน Loading
          if (typeof hideLoadingPopup === 'function') {
            hideLoadingPopup();
          } else {
            btn.disabled = false;
            btn.innerHTML = '<span>บันทึกข้อมูล</span>';
          }

          notify('error', 'เกิดข้อผิดพลาด', err && err.message ? err.message : String(err));
        })
        .saveBookingData(data);
    }


