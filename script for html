    function updateTruckTypeOptions() {
      const timeSelect = document.getElementById('truck-time-select');
      const truckTypeSelect = document.getElementById('truck-type');
      if (!timeSelect || !truckTypeSelect) return;

      const slot = timeSelect.value;
      const slotData = currentCapacities && currentCapacities[slot];

      // ถ้าไม่เจอข้อมูล slot ให้เปิดทุก option ไว้ก่อน
      if (!slotData || slotData.max == null) {
        Array.from(truckTypeSelect.options).forEach(opt => {
          opt.disabled = false;
          opt.text = opt.text.replace(/\s*\(เต็ม\)$/, '');
        });
        return;
      }

      const maxVal = Number(slotData.max);
      const totalVal = Number(slotData.totalPallets) || 0;

      // max=0 = ปิดรับ
      const remaining = (maxVal > 0) ? (maxVal - totalVal) : 0;

      let firstEnabledValue = null;

      Array.from(truckTypeSelect.options).forEach(opt => {
        const type = opt.value;
        const need = TRUCK_PALLETS[type] || 0;

        const disabled = (maxVal === 0) || (need > remaining);

        opt.disabled = disabled;

        // ใส่ label (เต็ม) เฉพาะ option ที่กดไม่ได้
        opt.text = opt.text.replace(/\s*\(เต็ม\)$/, '');
        if (disabled) opt.text += ' (เต็ม)';

        if (!disabled && !firstEnabledValue) firstEnabledValue = opt.value;
      });

      // ถ้าค่าที่เลือกอยู่ ถูกปิดแล้ว → เปลี่ยนไปค่าที่เลือกได้ตัวแรก
      if (truckTypeSelect.selectedOptions[0]?.disabled && firstEnabledValue) {
        truckTypeSelect.value = firstEnabledValue;
      }

      // ถ้าทุก option ถูกปิด → disable dropdown ทั้งก้อน
      const allDisabled = Array.from(truckTypeSelect.options).every(o => o.disabled);
      truckTypeSelect.disabled = allDisabled;
    }


    function renderSlots(capacities) {
      const container = document.getElementById('slots-container');
      if (!container) return;

      if (!Array.isArray(getTimeSlots()) || getTimeSlots().length === 0) {
        container.innerHTML =
          '<div class="col-span-full text-center py-10 text-red-600 text-sm">timeSlots ว่าง</div>';
        return;
      }

      // ✅ เก็บไว้ใช้ตอน openBookingForm / updateTruckTypeOptions
      window.currentCapacities = capacities;

      container.innerHTML = '';

      getTimeSlots().forEach(slot => {
        const data = capacities[slot] || { totalPallets: 0, count: 0, max: 96 };

        // ✅ ถ้า max = 0 ไม่แสดง Slot นั้น
        if (Number(data.max) === 0) return;

        const maxVal = Number(data.max);
        const totalVal = Number(data.totalPallets) || 0;

        // ✅ เต็มเมื่อ max=0 (ปิดรับ) หรือ total >= max
        const isFull = (maxVal === 0) || (!isNaN(maxVal) && totalVal >= maxVal);

        // ✅ กันหาร 0
        const percent = (!isNaN(maxVal) && maxVal > 0)
          ? Math.min(Math.round((totalVal / maxVal) * 100), 100)
          : 100;

        const card = document.createElement('div');

        // ✅ เต็ม "กดดูได้" → cursor-pointer (ไม่ใช้ not-allowed)
        card.className = `slot-card group p-4 rounded-2xl border transition-all flex flex-col items-center justify-center text-center cursor-pointer
          ${isFull
            ? 'bg-slate-50 border-slate-200 opacity-80 hover:border-slate-300'
            : 'bg-white border-slate-100 hover:border-primary/30'
          }`;

        // ✅ label แสดงเต็ม
        const fullLabel = isFull ? `<div class="mt-2 text-[11px] font-black text-danger">(เต็ม)</div>` : ``;

        // ✅ แสดง total/max จะเข้าใจง่ายกว่า
        const maxText = (!isNaN(maxVal)) ? maxVal : 0;

        card.innerHTML = `
          <span class="text-[10px] font-bold text-slate-400 mb-0.5">${slot.split(' - ')[0]}</span>
          <span class="text-sm font-black ${isFull ? 'text-slate-400' : 'text-slate-700'}">${slot.split(' - ')[1]}</span>

          ${fullLabel}

          <div class="w-full mt-2.5 bg-slate-100 h-1.5 rounded-full overflow-hidden">
            <div class="h-full rounded-full ${isFull ? 'bg-danger' : (percent > 80 ? 'bg-warning' : 'bg-success')}"
                style="width: ${percent}%"></div>
          </div>

          <div class="flex items-center justify-between w-full mt-2 px-1">
            <span class="text-[11px] font-bold ${isFull ? 'text-slate-500' : 'text-slate-500'}">${totalVal} / ${maxText} PLT</span>
            <span class="text-[10px] text-slate-400">${Number(data.count) || 0} คัน</span>
          </div>
        `;

        // ✅ เต็มก็คลิกได้ → เปิดรายละเอียด
        card.onclick = () => showSlotDetails(slot, card);

        container.appendChild(card);
      });

      if (typeof lucide !== 'undefined') lucide.createIcons();
    }

