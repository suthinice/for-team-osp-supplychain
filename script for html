    /**
     * แสดงตารางรายการลงทะเบียน (เฉพาะ In Progress)
     */
    function renderRegisterTable(data, totalBookings, checkedInCount, completedCount) {
      const tbody = document.getElementById('register-table-body');
      const totalCountEl = document.getElementById('register-total-count');
      const waitingCountEl = document.getElementById('register-waiting-count');
      const waitingPercentEl = document.getElementById('register-waiting-percent');
      const progressCountEl = document.getElementById('register-progress-count');
      const progressPercentEl = document.getElementById('register-progress-percent');
      const completedCountEl = document.getElementById('register-completed-count');
      const completedPercentEl = document.getElementById('register-completed-percent');
      
      if (!tbody) return;
      
      const total = totalBookings || 0;
      const checkedIn = checkedInCount || 0;
      const completed = completedCount || 0;
      
      // ✅ Stats
      if (totalCountEl) totalCountEl.textContent = total;
      
      // กำลังดำเนินการ = data.length
      const progressCount = data.length;
      if (progressCountEl) progressCountEl.textContent = progressCount;
      const progressPercent = total > 0 ? Math.round((progressCount / total) * 100) : 0;
      if (progressPercentEl) progressPercentEl.textContent = progressPercent + '%';
      
      // เสร็จสมบูรณ์
      if (completedCountEl) completedCountEl.textContent = completed;
      const completedPercent = total > 0 ? Math.round((completed / total) * 100) : 0;
      if (completedPercentEl) completedPercentEl.textContent = completedPercent + '%';
      
      // รอการเช็คอิน = Total - CheckedIn
      const waitingCount = total - checkedIn;
      if (waitingCountEl) waitingCountEl.textContent = waitingCount;
      const waitingPercent = total > 0 ? Math.round((waitingCount / total) * 100) : 0;
      if (waitingPercentEl) waitingPercentEl.textContent = waitingPercent + '%';
      
      // Empty State
      if (data.length === 0) {
        tbody.innerHTML = `
          <tr>
            <td colspan="5" class="text-center py-8 text-slate-400">
              <i data-lucide="inbox" class="w-12 h-12 mx-auto mb-2 opacity-50"></i>
