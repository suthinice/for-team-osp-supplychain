    // ===============================
    function saveCapacityData() {
      const btn = document.getElementById('btn-save-capacity');
      if (!btn) return;

      const user = getCurrentUser();
      const adminId = user.id;
      const serviceType = window.currentCapacityServiceType;

      if (!serviceType) {
        showToast('error', 'เกิดข้อผิดพลาด', 'ไม่พบข้อมูล serviceType');
        return;
      }

      // รวบรวมข้อมูลจาก input ทั้งหมด
      const inputs = document.querySelectorAll('.capacity-input');
      const updatedData = JSON.parse(JSON.stringify(window.capacityDataOriginal));

      inputs.forEach(input => {
        const rowIndex = parseInt(input.dataset.row);
        const day = input.dataset.day;
        const value = input.value.trim();

        if (!isNaN(rowIndex) && updatedData[rowIndex]) {
