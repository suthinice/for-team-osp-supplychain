    let toastTimer = null;

    function showToast(type = 'success', title = 'แจ้งเตือน', msg = '', ms = 2200) {
      const el = document.getElementById('toast');
      const dot = document.getElementById('toast-dot');
      const t = document.getElementById('toast-title');
      const m = document.getElementById('toast-msg');
      if (!el || !dot || !t || !m) return;

      const map = {
        success: { dot: 'bg-emerald-500', border: 'border-emerald-200', bg: 'bg-white' },
        error:   { dot: 'bg-rose-500',    border: 'border-rose-200',    bg: 'bg-white' },
        warn:    { dot: 'bg-amber-500',   border: 'border-amber-200',   bg: 'bg-white' },
        info:    { dot: 'bg-blue-500',    border: 'border-blue-200',    bg: 'bg-white' },
      };

      const s = map[type] || map.info;

      dot.className = `h-2.5 w-2.5 rounded-full ${s.dot}`;
      el.className = `fixed top-4 right-4 z-[999] flex items-center gap-3 rounded-2xl border ${s.border} ${s.bg} px-4 py-3 shadow-lg`;

      t.textContent = title;
      m.textContent = msg;

      el.classList.remove('hidden');
      el.classList.add('animate-zoom-in');

      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => {
        el.classList.add('hidden');
        el.classList.remove('animate-zoom-in');
      }, ms);
    }

    function showCenterToast(type = 'success', title = '', message = '', autoClose = 1600) {
      const wrapper = document.getElementById('center-toast');
      const box = document.getElementById('center-toast-box');
      const icon = document.getElementById('center-toast-icon');
      const titleEl = document.getElementById('center-toast-title');
      const msgEl = document.getElementById('center-toast-message');

      if (!wrapper || !box) return;

      // reset
      icon.className = 'mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full';
      icon.innerHTML = '';

      if (type === 'success') {
        icon.classList.add('bg-emerald-100', 'text-emerald-600');
        icon.innerHTML = '✓';
      } else if (type === 'error') {
        icon.classList.add('bg-red-100', 'text-red-600');
        icon.innerHTML = '✕';
      } else {
        icon.classList.add('bg-yellow-100', 'text-yellow-600');
        icon.innerHTML = '!';
      }

      titleEl.textContent = title || '';
      msgEl.textContent = message || '';

      wrapper.classList.remove('hidden');
      wrapper.classList.add('flex');

      requestAnimationFrame(() => {
        box.classList.remove('scale-95', 'opacity-0');
        box.classList.add('scale-100', 'opacity-100');
      });

      setTimeout(() => {
        box.classList.add('scale-95', 'opacity-0');
        setTimeout(() => {
          wrapper.classList.add('hidden');
          wrapper.classList.remove('flex');
        }, 250);
      }, autoClose);
    }

