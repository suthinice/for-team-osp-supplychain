    // ✅ เปิดฟอร์มการจอง (เช็คสิทธิ์ก่อน)
    // ===============================
    function openBookingForm() {
      // ✅ ถ้ามีสิทธิ์ตลอดเวลา → ข้ามทุกเงื่อนไข
      if (hasUnlimitedBooking()) {
        proceedToOpenBookingForm();
        return;
      }

      const user = getCurrentUser();
      const userId = user?.id;

      if (userId && user.stopBooking) {
        const canBook = checkUserCanBookLocal(user.stopBooking, user.startBooking);
        if (!canBook.allowed) {
          showBookingBlockedPopup(canBook.message, canBook.nextAvailable);
          return;
        }
      }

      checkHolidayBeforeBook(() => proceedToOpenBookingForm());
    }

    // ===============================
    // ✅ เปิดฟอร์มการจองจริง ๆ (หลังเช็คสิทธิ์แล้ว)
    // ===============================
    function proceedToOpenBookingForm() {
      const windowInfo = applyBookingDateWindow();
      const minDateString = windowInfo?.minDateString || '';
      const maxDateString = windowInfo?.maxDateString || '';
      const rangeText = windowInfo?.rangeText || '';

      const bookDate = document.getElementById('book-date')?.value || '';

      // ✅ ถ้ามีสิทธิ์ตลอดเวลา → ข้ามเงื่อนไขวันที่
      if (!hasUnlimitedBooking()) {
        if (bookDate && minDateString && maxDateString) {
          if (bookDate < minDateString || bookDate > maxDateString) {
            if (typeof showBookingRulePopup === 'function') {
              showBookingRulePopup(rangeText);
            } else {
              alert(`กรุณาเลือกวันที่ใหม่อีกครั้ง\n${rangeText}`);
            }
            return;
          }
        }
      } else {
        // ✅ Unlimited → set job-date เป็นวันที่เลือกใน book-date
        const jobDateEl = document.getElementById('job-date');
        if (jobDateEl) {
          jobDateEl.removeAttribute('min');
          jobDateEl.removeAttribute('max');
          jobDateEl.value = bookDate || getLocalISODateString();
        }
      }

      // 2) ต้องเลือก slot ก่อน
      if (!selectedSlot) {
        if (typeof showSelectSlotPopup === 'function') {
          showSelectSlotPopup();
        } else {
          alert('กรุณาเลือกช่วงเวลาก่อน');
        }
        return;
      }

      const slotData = currentCapacities?.[selectedSlot];

      // 3) เช็ค slot เต็ม
      const isFull =
        !!slotData &&
        (Number(slotData.max) === 0 ||
        Number(slotData.totalPallets) >= Number(slotData.max));

      if (isFull) {
        const msg = `ช่วงเวลา ${selectedSlot} เต็มแล้ว กรุณาเลือกช่วงเวลาอื่น`;
        if (typeof showSlotFullPopup === 'function') {
          showSlotFullPopup(msg);
        } else {
          alert(msg);
        }
        return;
      }

      // 4) เปิด modal + ล็อก scroll
      const modal = document.getElementById('booking-modal');
      if (modal) modal.classList.remove('hidden');
      document.body.classList.add('overflow-hidden');

      // 5) แสดง Notice
      document.getElementById('booking-notice')?.classList.remove('hidden');

      // 6) Clear form ทุกครั้ง
      if (typeof clearBookingForm === 'function') clearBookingForm();
      if (typeof initShipmentLogic === 'function') initShipmentLogic();

      // 7) ล็อกช่วงเวลาเป็น slot ที่เลือก
      const timeSelect = document.getElementById('truck-time-select');
      if (timeSelect) {
        timeSelect.value = selectedSlot;
        timeSelect.disabled = true;
      }

      // 8) sync job-date = book-date
      const jobDateEl = document.getElementById('job-date');
      if (jobDateEl && bookDate) {
        jobDateEl.value = bookDate;

        if (minDateString && maxDateString) {
          if (jobDateEl.value < minDateString || jobDateEl.value > maxDateString) {
            jobDateEl.value = minDateString;
          }
        }
      }

      // 9) เปิดประเภทรถ + กรองตาม capacity คงเหลือ
      const truckTypeSelect = document.getElementById('truck-type');
      if (truckTypeSelect) truckTypeSelect.disabled = false;

      if (typeof updateTruckTypeOptions === 'function') {
        updateTruckTypeOptions();
      }

      if (typeof handleTruckTypeChange === 'function') handleTruckTypeChange();
      if (typeof handleVendorChange === 'function') handleVendorChange();

      // ✅ โหลดรายชื่อ Customer
      loadCustomerDropdown();

      if (typeof lucide !== 'undefined') lucide.createIcons();
    }

