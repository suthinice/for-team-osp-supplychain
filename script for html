    function handleEditTruckTypeChange() {
      const truckType = document.getElementById('edit-truck-type')?.value;
      const container = document.getElementById('edit-trailer-no-container');
      const input = document.getElementById('edit-trailer-no');

      if (truckType === '22W') {
        container?.classList.remove('hidden');
        if (input) {
          input.disabled = false;  // ✅ เปิดให้แก้ได้
          input.required = true;
        }
      } else {
        container?.classList.add('hidden');
        if (input) {
          input.required = false;
          input.disabled = true;
          input.value = '';
        }
      }
    }

    function handleEditVendorChange() {
      const vendor = document.getElementById('edit-vendor')?.value;
      const container = document.getElementById('edit-vendor-other-container');

      if (vendor === 'อื่นๆ') {
        container?.classList.remove('hidden');
