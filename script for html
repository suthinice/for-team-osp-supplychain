    // ฟังก์ชันกรองตาราง
    function applyFilters() {
      const tbody = document.getElementById('details-tbody');
      if (!tbody) {
        console.warn('⚠️ ไม่พบ tbody'); // ✅ Debug
        return;
      }

      const rows = tbody.querySelectorAll('tr');
      let visibleCount = 0;

      console.log('📊 จำนวนแถวทั้งหมด:', rows.length); // ✅ Debug

      rows.forEach((row) => {
        // ดึงข้อมูลจาก data attribute ที่เราจะเพิ่มไว้
        const rowCompany = row.dataset.company || '';
        const rowShipment = row.dataset.shipment || '';

        let showRow = true;

        // กรองบริษัทขนส่ง
        if (currentCompanyFilter) {
          const normalizedRowCompany = normalizeCompanyName(rowCompany);
          const normalizedFilter = normalizeCompanyName(currentCompanyFilter);
          
          console.log('  🏢 เปรียบเทียบ:', normalizedRowCompany, 'vs', normalizedFilter); // ✅ Debug
          
          if (normalizedRowCompany !== normalizedFilter) {
            showRow = false;
          }
        }

        // กรอง Shipment
        if (currentShipmentFilter && showRow) {
          // ค้นหาแบบ partial match (ไม่ต้องพิมพ์ตรงทั้งหมด)
          if (!rowShipment.includes(currentShipmentFilter)) {
            showRow = false;
          }
        }

        // แสดง/ซ่อนแถว
        if (showRow) {
          row.style.display = '';
          visibleCount++;
        } else {
          row.style.display = 'none';
        }
