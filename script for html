    // ✅ FIX: เอาวันที่ “local” (ไม่ใช้ UTC ของ toISOString ตรง ๆ)
    function getLocalISODateString(d = new Date()) {
      const local = new Date(d.getTime() - d.getTimezoneOffset() * 60000);
