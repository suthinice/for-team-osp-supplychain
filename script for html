    // ✅ แสดงทั้งหมดลง table ด้านล่าง
    function escapeHtml(str = '') {
      return String(str)
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');
    }

    function normalizeCompanyName(v = '') {
      const s = String(v || '').trim();
      if (!s) return '';
      const upper = s.toUpperCase();
      if (upper === 'TVN' || upper === 'TNV') return 'TNV';
      return s;
    }

    function getJobStatusLabel(b) {
      return (b.jobStatus || b.status || '').trim();
