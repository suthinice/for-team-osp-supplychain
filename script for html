    function doExportExcel(data, service, startDate, endDate) {
      if (typeof XLSX === 'undefined') {
        showToast('error', 'ไม่พบ Library', 'กรุณารีโหลดหน้าเว็บ');
        return;
      }

      const headers = ['วันที่', 'Service', 'ช่วงเวลา', 'สถานะ', 'Shipment',
        'Pallet', 'ประเภทรถ', 'ทะเบียนรถ', 'ทะเบียนพ่วง', 'บริษัทขนส่ง',
        'เบอร์ติดต่อ', 'ชื่อลูกค้า', 'รายละเอียด',
        'BookDateTime', 'RegisterDateTime', 'BillingDateTime', 'Status ขนส่ง',
        'LoadingDateTime' // ✅ เพิ่ม
      ];

      const rows = data.map(r => [
        r.date || '', r.serviceType || '', r.time || '', r.status || '',
        r.shipment || '', r.pallets || 0, r.truckType || '', r.truckNo || '',
        r.trailerNo || '', r.vendor || '', r.phone || '', r.customerName || '',
        r.remark || '',
        r.bookDateTime || '', r.registerDateTime || '', r.confirmDateTime || '', r.statusTransport || '',
        r.loadingDateTime || '' // ✅ เพิ่ม
      ]);

      const wb = XLSX.utils.book_new();
      const ws = XLSX.utils.aoa_to_sheet([headers, ...rows]);
      ws['!cols'] = headers.map((_, i) => ({ wch: i === 4 ? 25 : i === 12 ? 30 : 15 }));

      XLSX.utils.book_append_sheet(wb, ws, 'Export');

      const filename = `Export_${service}_${startDate}_${endDate}.xlsx`;
      XLSX.writeFile(wb, filename);
      showCenterToast('success', 'Export สำเร็จ', filename);
    }

    function doExportCSV(data, service, startDate, endDate) {
      const headers = ['วันที่', 'Service', 'ช่วงเวลา', 'สถานะ', 'Shipment',
        'Pallet', 'ประเภทรถ', 'ทะเบียนรถ', 'ทะเบียนพ่วง', 'บริษัทขนส่ง',
        'เบอร์ติดต่อ', 'ชื่อลูกค้า', 'รายละเอียด'];

      const rows = data.map(r => [
        r.date || '', r.serviceType || '', r.time || '', r.status || '',
        r.shipment || '', r.pallets || 0, r.truckType || '', r.truckNo || '',
        r.trailerNo || '', r.vendor || '', r.phone || '', r.customerName || '',
        r.remark || ''
      ].map(v => `"${String(v).replace(/"/g, '""')}"`).join(','));

      const csv = '\uFEFF' + [headers.join(','), ...rows].join('\n');
      const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `Export_${service}_${startDate}_${endDate}.csv`;
      a.click();
      URL.revokeObjectURL(url);
      showCenterToast('success', 'Export สำเร็จ', a.download);
    }

