    /**
     * โหลด Holiday ของ Service นั้นมา Cache ไว้ครั้งเดียว
     * แล้วเช็คจาก Cache เลย ไม่ต้อง call Server ทุกครั้ง
     */
    function checkHolidayBeforeBook(callback) {
      const bookDate = document.getElementById('book-date')?.value;
      if (!bookDate) { callback(); return; }

      // Step 1: เช็ค System Close
      if (cachedSystemClose) {
        const today = getLocalISODateString();
        const closed = cachedSystemClose.some(r =>
          r.date === today && r.serviceKey === currentService && r.status === 'ปิด'
        );
        if (closed) { showSystemClosePopup(); return; }
      } else {
        const today = getLocalISODateString(); // ✅ เพิ่มบรรทัดนี้
        google.script.run
          .withSuccessHandler((res) => {
            if (res?.success) cachedSystemClose = res.data;
            const closed = (res?.data || []).some(r =>
              r.date === today && r.serviceKey === currentService && r.status === 'ปิด'
            );
            if (closed) {
              showToast('error', 'ระบบปิด', 'ระบบจองถูกปิดชั่วคราววันนี้ กรุณาติดต่อเจ้าหน้าที่');
              return;
            }
            checkHolidayBeforeBook(callback);
          })
          .withFailureHandler(() => callback())
          .getSystemCloseForUser();
        return;
      }

      // ✅ Step 2: เช็ค Holiday — ถ้ามี cache แล้วข้ามเลย
      if (cachedHolidays[currentService]) {
        if (cachedHolidays[currentService].has(bookDate)) {
          showHolidayPopup(bookDate);
        } else {
          callback(); // ✅ เปิดฟอร์มทันที
        }
        return; // ✅ ต้อง return ไม่ให้ไป call server
      }

      // ยังไม่มี cache → call server แล้วเก็บ cache
      google.script.run
        .withSuccessHandler((res) => {
          const closedDates = new Set(
            (res?.data || [])
              .filter(h => h.status === 'ปิด')
              .map(h => h.date)
          );
          cachedHolidays[currentService] = closedDates;

          if (cachedHolidays[currentService].has(bookDate)) {
            showHolidayPopup(bookDate);
          } else {
            callback();
          }
        })
        .withFailureHandler(() => callback())
        .adminGetHolidays(getCurrentUser().id, currentService);
    }

