    // ✅ Map ชื่อไฟล์ปลายทาง
    const FILE_NAME_MAP = {
      'tt-so':      'ZSDR_SO',
      'tt-do':      'ZSDR_DO',
      'tt-billing': 'Billing_TT',
      'mt-so':      'ZSDRSO_MT',
      'mt-do':      'ZSDRDO_MT',
      'mt-billing': 'Billing_MT'
    };

    const UPLOAD_FOLDER_ID = '12qphW30157Qk2OqJJxjRzv3IQRHdSFU-';

    function uploadFiles(tradeType) {
      const prefix = tradeType === 'TT' ? 'tt' : 'mt';
      const keys = [`${prefix}-so`, `${prefix}-do`, `${prefix}-billing`];

      // ✅ เช็คว่ามีไฟล์อย่างน้อย 1 ไฟล์
      const filesToUpload = keys.filter(k => selectedFiles[k]);
      if (filesToUpload.length === 0) {
        showToast('warn', 'ไม่มีไฟล์', 'กรุณาเลือกไฟล์อย่างน้อย 1 ไฟล์');
        return;
      }

      showLoadingPopup('กำลัง Upload...', 'กรุณารอสักครู่');

      // ✅ อ่านไฟล์เป็น base64 ทีละไฟล์แล้วส่งไป Backend
      const uploads = filesToUpload.map(key => {
        return new Promise((resolve) => {
          const file = selectedFiles[key];
          const reader = new FileReader();
          reader.onload = (e) => {
            const base64 = e.target.result.split(',')[1];
            resolve({
              key,
              fileName: FILE_NAME_MAP[key],
              mimeType: file.type || 'application/octet-stream',
              base64
            });
          };
          reader.readAsDataURL(file);
        });
      });

      Promise.all(uploads).then(fileDataList => {
        google.script.run
          .withSuccessHandler((res) => {
            hideLoadingPopup();
            if (res?.success) {
              showToast('success', 'Upload สำเร็จ', res.message);
              // ✅ Reset ไฟล์ที่ Upload แล้ว
              filesToUpload.forEach(key => {
                delete selectedFiles[key];
                const label = document.getElementById(`${key}-label`);
                const drop = document.getElementById(`${key}-drop`);
                if (label) {
                  label.textContent = 'คลิกหรือลากไฟล์มาวาง';
                  label.className = 'text-xs text-slate-400';
                }
                if (drop) {
                  drop.classList.remove('border-green-400', 'bg-green-50/50');
                  drop.classList.add('border-slate-200');
                }
                const input = document.getElementById(`${key}-input`);
                if (input) input.value = '';
              });
            } else {
              showToast('error', 'Upload ไม่สำเร็จ', res?.message || 'เกิดข้อผิดพลาด');
            }
          })
          .withFailureHandler((err) => {
            hideLoadingPopup();
            showToast('error', 'เกิดข้อผิดพลาด', err?.message || err);
          })
          .uploadFilesToDrive(fileDataList, UPLOAD_FOLDER_ID);
      });
    }

