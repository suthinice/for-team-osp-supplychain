        return;
      }

      setLoading('btn-reset', 'reset-spinner', 'reset-btn-text', true, 'กำลังอัปเดต...');

      google.script.run
        .withSuccessHandler(function (res) {
          setLoading('btn-reset', 'reset-spinner', 'reset-btn-text', false, 'อัปเดตรหัสผ่าน');

          if (res && res.success) {
            showAlert('success', 'สำเร็จ', 'เปลี่ยนรหัสผ่านเรียบร้อย');
            setTimeout(() => switchView('login'), 700);
          } else {
            showAlert(
              'error',
              'ไม่สำเร็จ',
              (res && res.message) ? res.message : 'ไม่สามารถเปลี่ยนรหัสผ่านได้'
            );
          }
        })
        .withFailureHandler(function (err) {
          setLoading('btn-reset', 'reset-spinner', 'reset-btn-text', false, 'อัปเดตรหัสผ่าน');
          showAlert('error', 'เชื่อมต่อไม่สำเร็จ', err?.message || String(err));
        })
        .resetPasswordWithOld(id, oldPass, newPass);
    }

    document.addEventListener('keydown', (e) => {
