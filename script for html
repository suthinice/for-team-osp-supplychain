    /**
     * อัปเดต Overview Cards
     */
    function updateOverviewCards(data) {
      // Total
      const totalEl = document.getElementById('dash-total-count');
      if (totalEl) totalEl.textContent = data.total || 0;
      
      // Receive
      if (receiveEl) receiveEl.textContent = data.receive || 0;
      if (receivePercentEl) {
        const percent = data.total > 0 
          ? Math.round((data.receive / data.total) * 100) 
          : 0;
        receivePercentEl.textContent = percent;
      }
      
      // Send
      if (sendEl) sendEl.textContent = data.send || 0;
      if (sendPercentEl) {
        const percent = data.total > 0 
          ? Math.round((data.send / data.total) * 100) 
          : 0;
        sendPercentEl.textContent = percent;
      }
      
      // Utilization
      // dash-utilization ถูกแทนที่ด้วย loadCapacityUtilize() แล้ว
      const utilizationEl = null;
      const palletsTextEl = document.getElementById('dash-pallets-text');
      if (utilizationEl) utilizationEl.textContent = (data.utilization || 0) + '%';
      if (palletsTextEl) {
        palletsTextEl.textContent = `${data.totalPallets || 0}/${data.maxCapacity || 0} PLT`;
      }
      
      // ✅ Comparison (อัปเดตจริง)
      const changeEl = document.getElementById('dash-total-change');
      if (changeEl && data.comparison) {
        const diff = data.comparison.difference || 0;
        const percent = data.comparison.percentage || 0;
        
        if (diff > 0) {
          changeEl.textContent = `+${diff} (+${percent}%)`;
          changeEl.className = 'text-xs font-bold text-green-600';
          changeEl.title = `เพิ่มขึ้น ${diff} คัน เมื่อเทียบกับช่วง ${data.comparison.previousPeriod?.start || ''} - ${data.comparison.previousPeriod?.end || ''}`;
        } else if (diff < 0) {
          changeEl.textContent = `${diff} (${percent}%)`;
          changeEl.className = 'text-xs font-bold text-red-600';
          changeEl.title = `ลดลง ${Math.abs(diff)} คัน เมื่อเทียบกับช่วง ${data.comparison.previousPeriod?.start || ''} - ${data.comparison.previousPeriod?.end || ''}`;
        } else {
          changeEl.textContent = '0 (0%)';
          changeEl.className = 'text-xs font-bold text-slate-400';
          changeEl.title = `ไม่เปลี่ยนแปลง เมื่อเทียบกับช่วง ${data.comparison.previousPeriod?.start || ''} - ${data.comparison.previousPeriod?.end || ''}`;
        }
      }
    }

    /**
     * อัปเดต Donut Chart พร้อมแสดงรายละเอียด "ว่าง"
     */
    function updateDonutChart(data) {
      const canvas = document.getElementById('donut-chart');
      if (!canvas) return;
      
      // ทำลาย Chart เก่า
      if (dashboardCharts.donut) {
        dashboardCharts.donut.destroy();
      }
      
      const truckTypes = data.truckTypes || [];
      
      // ✅ เตรียมข้อมูลสำหรับ Chart
      const labels = [];
      const values = [];
      const pallets = [];
      
      // เพิ่มข้อมูลรถแต่ละประเภท
      truckTypes.forEach(t => {
        if (t.count > 0) {  // แสดงเฉพาะที่มีจำนวน > 0
          labels.push(t.type);
          values.push(t.count);
          pallets.push(t.pallets);
        }
      });
      
      // ✅ เพิ่ม "ว่าง" (Available) ถ้ามี
      const availablePallets = data.availablePallets || 0;
      const availablePercentage = data.availablePercentage || 0;
      
      if (availablePallets > 0) {
        labels.push('ว่าง');
        values.push(availablePercentage);  // ใช้ % แทนจำนวนคัน
        pallets.push(availablePallets);
      }
      
      // ตรวจสอบว่ามีข้อมูลหรือไม่
      if (labels.length === 0) {
        const ctx = canvas.getContext('2d');
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.font = '14px Sarabun, sans-serif';
        ctx.fillStyle = '#94a3b8';
        ctx.textAlign = 'center';
        ctx.fillText('ไม่มีข้อมูล', canvas.width / 2, canvas.height / 2);
        return;
      }
      
      // ✅ กำหนดสี
      const colors = {
        '4W': '#3B82F6',    // Blue
        '6W': '#8B5CF6',    // Purple
        '10W': '#10B981',   // Green
        '22W': '#F59E0B',   // Orange
        'ว่าง': '#E5E7EB'   // Light Gray
      };
      
      const backgroundColors = labels.map(l => colors[l] || '#9CA3AF');
      
      dashboardCharts.donut = new Chart(canvas, {
        type: 'doughnut',
        data: {
          labels: labels,
          datasets: [{
            data: values,
            backgroundColor: backgroundColors,
            borderWidth: 2,
            borderColor: '#fff'
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              position: 'bottom',
              labels: {
                padding: 15,
                font: {
                  size: 12,
                  family: 'Sarabun, sans-serif',
                  weight: 'bold'
                },
                // ✅ แสดงจำนวน PLT ใน Legend
                generateLabels: function(chart) {
                  const data = chart.data;
                  return data.labels.map((label, i) => {
                    const value = data.datasets[0].data[i];
                    const pallet = pallets[i];
                    
                    // ถ้าเป็น "ว่าง" แสดง % และ PLT
                    if (label === 'ว่าง') {
                      return {
                        text: `${label} (${value}% | ${pallet.toLocaleString()} PLT)`,
                        fillStyle: backgroundColors[i],
                        hidden: false,
                        index: i
                      };
                    }
                    
                    // ถ้าเป็นประเภทรถ แสดงจำนวนคันและ PLT
                    const truckInfo = truckTypes.find(t => t.type === label);
                    const count = truckInfo ? truckInfo.count : value;
                    
                    return {
                      text: `${label} (${count} คัน | ${pallet} PLT)`,
                      fillStyle: backgroundColors[i],
                      hidden: false,
                      index: i
                    };
                  });
                }
              }
            },
            tooltip: {
              callbacks: {
                label: function(context) {
                  const label = context.label || '';
                  const index = context.dataIndex;
                  const pallet = pallets[index];
                  
                  // ✅ Tooltip สำหรับ "ว่าง"
                  if (label === 'ว่าง') {
                    const percent = context.parsed || 0;
                    return `${label}: ${percent}% (${pallet.toLocaleString()} PLT ว่าง)`;
                  }
                  
                  // Tooltip สำหรับประเภทรถ
                  const truck = truckTypes.find(t => t.type === label);
                  if (truck) {
                    return `${label}: ${truck.count} คัน (${pallet} PLT)`;
                  }
                  
                  return `${label}: ${context.parsed}`;
                }
              }
            }
          }
        }
      });
    }

    /**
     * อัปเดต Bar Chart
     */
    function updateBarChart(data) {
      const canvas = document.getElementById('bar-chart');
      if (!canvas) return;
      
      // ทำลาย Chart เก่า
      if (dashboardCharts.bar) {
        dashboardCharts.bar.destroy();
      }
      
      const truckTypes = data.truckTypes || [];
      const labels = truckTypes.map(t => t.type);
      const values = truckTypes.map(t => t.count);
      
      const colors = {
        '4W': '#3B82F6',
        '6W': '#8B5CF6',
        '10W': '#10B981',
        '22W': '#F59E0B'
      };
      
      const backgroundColors = labels.map(l => colors[l] || '#9CA3AF');
      
      dashboardCharts.bar = new Chart(canvas, {
        type: 'bar',
        data: {
          labels: labels,
          datasets: [{
            label: 'จำนวนคัน',
            data: values,
            backgroundColor: backgroundColors,
            borderWidth: 0,
            borderRadius: 8
          }]
        },
        options: {
          indexAxis: 'y', // Horizontal bar
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              display: false
            },
            tooltip: {
              callbacks: {
                label: function(context) {
                  const value = context.parsed.x || 0;
                  const truck = truckTypes[context.dataIndex];
                  return `${value} คัน (${truck?.pallets || 0} PLT)`;
                }
              }
            }
          },
          scales: {
            x: {
              beginAtZero: true,
              ticks: {
                stepSize: 5,
                font: {
                  family: 'Sarabun, sans-serif'
                }
              }
            },
            y: {
              ticks: {
                font: {
                  family: 'Sarabun, sans-serif',
                  weight: 'bold'
                }
              }
            }
          }
        }
      });
    }

    /**
     * อัปเดต Full Slots พร้อมรายละเอียดประเภทรถ
     */
    function updateFullSlots(slots) {
      const container = document.getElementById('full-slots-container');
