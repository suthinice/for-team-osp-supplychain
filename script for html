      const vendors = ['DHL', 'TNV', 'เก้าเลี้ยว', 'TRL', 'ลูกค้ารับเอง'];
      const colors = [
        { start: 'rgba(239, 68, 68, 0.9)',   end: 'rgba(239, 68, 68, 0.5)',   border: 'rgba(239, 68, 68, 1)'   },
        { start: 'rgba(245, 158, 11, 0.9)',  end: 'rgba(245, 158, 11, 0.5)',  border: 'rgba(245, 158, 11, 1)'  },
        { start: 'rgba(16, 185, 129, 0.9)',  end: 'rgba(16, 185, 129, 0.5)',  border: 'rgba(16, 185, 129, 1)'  },
        { start: 'rgba(99, 102, 241, 0.9)',  end: 'rgba(99, 102, 241, 0.5)',  border: 'rgba(99, 102, 241, 1)'  },
