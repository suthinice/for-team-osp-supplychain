    /**
     * สร้าง Pie Chart - สัดส่วนประเภทรถ (Modern Colors)
     */
    function createPieChart(data) {
      const ctx = document.getElementById('pie-chart');
      if (!ctx) return;
      
      // ทำลายกราฟเก่า (ถ้ามี)
      if (pieChart) {
        pieChart.destroy();
      }
      
      // ✨ Modern Color Palette - Gradient Style
      const chartData = {
        labels: ['4 ล้อ', '6 ล้อ', '10 ล้อ', '22 ล้อ'],
        datasets: [{
          data: [
            data?.truck4w || 0,
            data?.truck6w || 0,
            data?.truck10w || 0,
            data?.truck22w || 0
          ],
          backgroundColor: [
            'rgba(168, 85, 247, 0.85)',   // Purple - 4W
            'rgba(59, 130, 246, 0.85)',   // Blue - 6W
            'rgba(34, 197, 94, 0.85)',    // Green - 10W
            'rgba(251, 146, 60, 0.85)'    // Orange - 22W
          ],
          borderColor: [
            'rgba(168, 85, 247, 1)',
            'rgba(59, 130, 246, 1)',
            'rgba(34, 197, 94, 1)',
            'rgba(251, 146, 60, 1)'
          ],
          borderWidth: 3,
          hoverOffset: 15,
          hoverBorderWidth: 4,
          hoverBorderColor: '#ffffff'
        }]
      };
      
      // สร้างกราฟ
      pieChart = new Chart(ctx, {
        type: 'pie',
        data: chartData,
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              position: 'bottom',
              labels: {
                padding: 20,
                font: {
                  size: 13,
                  weight: '600',
                  family: "'Sarabun', sans-serif"
                },
                usePointStyle: true,
                pointStyle: 'circle',
                color: '#475569',
                generateLabels: function(chart) {
                  const data = chart.data;
                  return data.labels.map((label, i) => {
                    const value = data.datasets[0].data[i];
                    const total = data.datasets[0].data.reduce((a, b) => a + b, 0);
                    const percentage = total > 0 ? Math.round((value / total) * 100) : 0;
                    return {
                      text: `${label} (${percentage}%)`,
                      fillStyle: data.datasets[0].backgroundColor[i],
                      hidden: false,
                      index: i
                    };
                  });
                }
              }
            },
            tooltip: {
              backgroundColor: 'rgba(15, 23, 42, 0.95)',
              padding: 16,
              cornerRadius: 12,
              titleFont: {
                size: 15,
                weight: 'bold'
              },
              bodyFont: {
                size: 14
              },
              borderColor: 'rgba(255, 255, 255, 0.1)',
              borderWidth: 1,
              callbacks: {
                label: function(context) {
                  const label = context.label || '';
                  const value = context.parsed || 0;
                  const total = context.dataset.data.reduce((a, b) => a + b, 0);
                  const percentage = total > 0 ? Math.round((value / total) * 100) : 0;
                  return `${label}: ${value} คัน (${percentage}%)`;
                }
              }
            }
          },
          animation: {
            animateRotate: true,
            animateScale: true,
            duration: 1200,
            easing: 'easeInOutQuart'
          }
        }
      });
      
      console.log('✅ Pie Chart created with modern colors');
    }

