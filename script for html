    function initShipmentLogic() {
      const shipmentInput = document.getElementById('shipment-no');
      if (!shipmentInput) return;

      // ✅ Reset ทุกครั้ง เพื่อให้ bind ใหม่ตาม currentService
      shipmentInput.dataset.bound = '0';
      
      // ลบ event listener เก่าออกก่อน
      const newInput = shipmentInput.cloneNode(true);
      shipmentInput.parentNode.replaceChild(newInput, shipmentInput);

      // ✅ ถ้าเป็น AY_OEM ไม่ต้องทำ comma format
      if (currentService === 'AY_OEM') return;

      newInput.addEventListener('input', () => {
        let digits = newInput.value.replace(/\D/g, '');
        let groups = [];
        for (let i = 0; i < digits.length; i += 7) {
          groups.push(digits.slice(i, i + 7));
        }
        newInput.value = groups.join(',');
        newInput.setSelectionRange(newInput.value.length, newInput.value.length);
      });
    }

    window.onload = () => {
      initShipmentLogic();
    };

    function handleTruckTypeChange() {
      const truckTypeEl = document.getElementById('truck-type');
      const trailerContainer = document.getElementById('trailer-no-container');
      const trailerInput = document.getElementById('trailer-no');

      if (!truckTypeEl || !trailerContainer || !trailerInput) return;

      const needTrailer = truckTypeEl.value === '22W';

      if (needTrailer) {
        trailerContainer.classList.remove('hidden');
        trailerInput.disabled = false;
        trailerInput.required = true; // ✅ บังคับกรอกจริง
      } else {
        trailerContainer.classList.add('hidden');
        trailerInput.required = false;
        trailerInput.disabled = true;  // ✅ กันโดน validate ตอนซ่อน
        trailerInput.value = '';
      }
    }



