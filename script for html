    // ✅ เก็บ Sort State แยกแต่ละตาราง
    const ontimeSortState = {
      scheduled:  { col: null, dir: 0 },
      inprogress: { col: null, dir: 0 },
      completed:  { col: null, dir: 0 }
    };

    function sortOntimeTable(tableKey, col) {
      const state = ontimeSortState[tableKey];

      // ✅ วน cycle: 0 (ปกติ) → 1 (↑) → -1 (↓) → 0
      if (state.col === col) {
        state.dir = state.dir === 0 ? 1 : state.dir === 1 ? -1 : 0;
      } else {
        state.col = col;
        state.dir = 1;
      }

      // ✅ อัปเดต Icon ทุกตัวในตารางนี้
      ['shipment', 'time'].forEach(c => {
        const el = document.getElementById(`${tableKey}-sort-${c}`);
        if (el) el.textContent = '↕';
      });

      const iconEl = document.getElementById(`${tableKey}-sort-${col}`);
      if (iconEl) {
        iconEl.textContent = state.dir === 1 ? '↑' : state.dir === -1 ? '↓' : '↕';
      }

      // ✅ Sort Rows
      const tbody = document.getElementById(`${tableKey}-ontime-tbody`);
      if (!tbody) return;

      const rows = Array.from(tbody.querySelectorAll('tr')).filter(r => r.cells.length > 1);
      if (rows.length === 0) return;

      if (state.dir === 0) {
        // ✅ คืนค่าเดิม (เรียงตาม index เดิม)
        rows.sort((a, b) => Number(a.dataset.index || 0) - Number(b.dataset.index || 0));
      } else {
        const colIndex = col === 'shipment' ? 0 : 2; // Shipment=0, ช่วงเวลา=2
        rows.sort((a, b) => {
          const aVal = a.cells[colIndex]?.textContent?.trim() || '';
          const bVal = b.cells[colIndex]?.textContent?.trim() || '';
          return state.dir * aVal.localeCompare(bVal, 'th');
        });
      }

      rows.forEach(r => tbody.appendChild(r));
    }

